---
interface ConceptListItem {
  id: string;
  data: {
    title: string;
    description: string;
    tags?: string[];
    routeSlug?: string;
  };
}

interface Props {
  entries: ConceptListItem[];
  basePath: string;
  label: string;
  linkLabel: string;
  tagFilterLabel?: string;
  emptyLabel?: string;
  emptyMessage?: string;
}

const {
  entries,
  basePath,
  label,
  linkLabel,
  tagFilterLabel = 'Filter by topic',
  emptyLabel = label,
  emptyMessage = 'Public writing is being prepared.'
} = Astro.props;

function getTagHref(tag: string) {
  return `${basePath}/?${new URLSearchParams({ tag }).toString()}`;
}
---

{
  entries.length === 0 ? (
    <div class="empty-state publication-empty">
      <span class="dossier-stamp" aria-hidden="true">PP</span>
      <p class="small-label">{emptyLabel}</p>
      <p>{emptyMessage}</p>
    </div>
  ) : (
    <div class="concept-list">
      {entries.map((entry, index) => {
        const tags = entry.data.tags ?? [];
        const entrySlug = entry.data.routeSlug ?? entry.id;
        const href = `${basePath}/${entrySlug}/`;
        const itemNumber = String(index + 1).padStart(2, '0');

        return (
          <article class="concept-card" data-qa="concept-card" data-concept-tags={tags.join('|')}>
            <p class="concept-kicker">
              <span>{itemNumber}</span>
              {label}
            </p>
            <h2>
              <a href={href}>{entry.data.title}</a>
            </h2>
            <p>{entry.data.description}</p>
            {tags.length > 0 && (
              <ul class="concept-tag-list" aria-label="Topics">
                {tags.map((tag) => (
                  <li data-qa="concept-tag">
                    <a
                      href={getTagHref(tag)}
                      aria-label={`${tagFilterLabel}: ${tag}`}
                      data-concept-tag-link
                    >
                      {tag}
                    </a>
                  </li>
                ))}
              </ul>
            )}
            <a class="concept-card-link" data-qa="concept-read-more" href={href}>{linkLabel}</a>
          </article>
        );
      })}
    </div>
  )
}

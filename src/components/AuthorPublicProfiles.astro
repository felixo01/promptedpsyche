---
import type { Locale } from '../lib/i18n';
import { authorPublicProfiles } from '../lib/site';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const heading = lang === 'pl' ? 'Profile publiczne' : 'Public profiles';
const headingId = `author-public-profiles-${lang}`;
---

<section
  class="author-profile-panel"
  aria-labelledby={headingId}
  data-qa="author-public-profiles"
>
  <h3 id={headingId}>{heading}</h3>
  <ul>
    {authorPublicProfiles.map((profile) => (
      <li>
        <a href={profile.url} rel="me noopener">
          <span>{profile.label[lang]}</span>
          <span aria-hidden="true">↗</span>
        </a>
      </li>
    ))}
  </ul>
</section>

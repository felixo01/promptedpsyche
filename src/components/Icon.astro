---
type IconName =
  | 'article'
  | 'attachment'
  | 'check'
  | 'concept'
  | 'culture'
  | 'decision'
  | 'dialogue'
  | 'emotion'
  | 'note'
  | 'spark'
  | 'trust'
  | 'work';

interface Props {
  name: IconName;
  label?: string;
}

const { name, label } = Astro.props;
const decorative = !label;
---

<svg
  class:list={['line-icon', `line-icon-${name}`]}
  viewBox="0 0 24 24"
  fill="none"
  aria-hidden={decorative ? 'true' : undefined}
  role={decorative ? undefined : 'img'}
  aria-label={label}
>
  {
    name === 'article' && (
      <>
        <path d="M7 4.5h7l3 3v12H7z" />
        <path d="M14 4.5v3h3" />
        <path d="M9.5 11h5" />
        <path d="M9.5 14h5" />
      </>
    )
  }
  {
    name === 'attachment' && (
      <>
        <path d="M8 12.5l3.2-3.2a3 3 0 0 1 4.2 4.2l-4.1 4.1a4.2 4.2 0 0 1-5.9-5.9l4.5-4.5" />
        <path d="M13.2 11.1l-4.1 4.1" />
      </>
    )
  }
  {name === 'check' && <path d="M5.5 12.5l4 4 9-9" />}
  {
    name === 'concept' && (
      <>
        <circle cx="7" cy="7" r="2" />
        <circle cx="17" cy="8" r="2" />
        <circle cx="12" cy="17" r="2" />
        <path d="M9 7.3l6 .4" />
        <path d="M8.2 8.7l2.8 6.5" />
        <path d="M15.8 9.6l-2.7 5.7" />
      </>
    )
  }
  {
    name === 'culture' && (
      <>
        <circle cx="12" cy="12" r="7" />
        <path d="M5.5 12h13" />
        <path d="M12 5.5c2 2.2 2 10.8 0 13" />
        <path d="M12 5.5c-2 2.2-2 10.8 0 13" />
      </>
    )
  }
  {
    name === 'decision' && (
      <>
        <path d="M6 6h4v4H6z" />
        <path d="M14 4h4v4h-4z" />
        <path d="M14 16h4v4h-4z" />
        <path d="M10 8h2.5c1.7 0 2.2-1 2.2-2" />
        <path d="M10 8h2.5c1.7 0 2.2 10 2.2 10" />
      </>
    )
  }
  {
    name === 'dialogue' && (
      <>
        <path d="M5 6.5h9a3 3 0 0 1 3 3v1.8a3 3 0 0 1-3 3h-3.8L6 17v-2.7H5a3 3 0 0 1-3-3V9.5a3 3 0 0 1 3-3z" />
        <path d="M15 10.5h4a3 3 0 0 1 3 3v1.2a3 3 0 0 1-3 3h-.8V20L15 17.7h-2.5" />
      </>
    )
  }
  {
    name === 'emotion' && (
      <>
        <circle cx="12" cy="12" r="7" />
        <path d="M8.2 11c1.4-1 2.6-1 3.8 0s2.4 1 3.8 0" />
        <path d="M8.5 15c2.2 1.4 4.8 1.4 7 0" />
      </>
    )
  }
  {
    name === 'note' && (
      <>
        <path d="M6 5h12v14H6z" />
        <path d="M9 9h6" />
        <path d="M9 12h6" />
        <path d="M9 15h3" />
      </>
    )
  }
  {
    name === 'spark' && (
      <>
        <path d="M12 4.5v4" />
        <path d="M12 15.5v4" />
        <path d="M4.5 12h4" />
        <path d="M15.5 12h4" />
        <path d="M9.2 9.2l-2.8-2.8" />
        <path d="M14.8 14.8l2.8 2.8" />
        <path d="M14.8 9.2l2.8-2.8" />
        <path d="M9.2 14.8l-2.8 2.8" />
      </>
    )
  }
  {
    name === 'trust' && (
      <>
        <path d="M12 4.5l6 2.5v4.2c0 4-2.3 6.7-6 8.3-3.7-1.6-6-4.3-6-8.3V7z" />
        <path d="M9 12l2 2 4-4" />
      </>
    )
  }
  {
    name === 'work' && (
      <>
        <path d="M6 8h12v10H6z" />
        <path d="M9.5 8V6h5v2" />
        <path d="M6 12.5h12" />
      </>
    )
  }
</svg>

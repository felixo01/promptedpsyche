---
import { site } from '../lib/site';

interface Props {
  href?: string;
  label?: string;
  line?: string;
  compact?: boolean;
}

const { href, label = site.name, line = site.tagline, compact = false } = Astro.props;
---

{
  href ? (
    <a class:list={['brand-lockup', { 'brand-lockup-compact': compact }]} href={href} aria-label={label}>
      <span class="brand-symbol" aria-hidden="true">PP</span>
      <span class="brand-copy">
        <span class="brand-name">{site.name}</span>
        {!compact && <span class="brand-line">{line}</span>}
      </span>
    </a>
  ) : (
    <div class:list={['brand-lockup', { 'brand-lockup-compact': compact }]}>
      <span class="brand-symbol" aria-hidden="true">PP</span>
      <span class="brand-copy">
        <span class="brand-name">{site.name}</span>
        {!compact && <span class="brand-line">{line}</span>}
      </span>
    </div>
  )
}

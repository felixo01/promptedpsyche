---
import BrandMark from './BrandMark.astro';
import {
  getAlternatePath,
  getLangFromPath,
  getNavItems,
  normalizePath,
  type AlternateLinks,
  type Locale
} from '../lib/i18n';
import { site } from '../lib/site';

interface Props {
  lang?: Locale;
  alternateLinks?: AlternateLinks;
}

const activeLang = Astro.props.lang ?? getLangFromPath(Astro.url.pathname);
const providedAlternateLinks = Astro.props.alternateLinks;
const currentPath = Astro.url.pathname;
const normalizedCurrentPath = normalizePath(currentPath);
const headerOrder = activeLang === 'pl'
  ? ['/pl/concepts/', '/pl/consulting/', '/pl/about/', '/pl/contact/']
  : ['/concepts/', '/consulting/', '/about/', '/contact/'];
const navItems = headerOrder
  .map((href) => getNavItems(activeLang).find((item) => item.href === href))
  .filter((item): item is { label: string; href: string } => Boolean(item));
const enPath = providedAlternateLinks?.en ?? getAlternatePath(currentPath, 'en');
const plPath = providedAlternateLinks?.pl ?? getAlternatePath(currentPath, 'pl');
const homePath = activeLang === 'pl' ? '/pl/' : '/';
const homeLabel = activeLang === 'pl' ? `${site.name} - strona główna` : `${site.name} home`;

function isCurrentPath(href: string) {
  const normalizedHref = normalizePath(href);

  if (normalizedHref === '/' || normalizedHref === '/pl') {
    return normalizedCurrentPath === normalizedHref;
  }

  return normalizedCurrentPath === normalizedHref || normalizedCurrentPath.startsWith(`${normalizedHref}/`);
}
---

<header class="site-header">
  <BrandMark href={homePath} label={homeLabel} compact />

  <div class="header-actions">
    <nav class="site-nav" aria-label={activeLang === 'pl' ? 'Nawigacja główna' : 'Primary navigation'}>
      {
        navItems.map((item) => (
          <a href={item.href} aria-current={isCurrentPath(item.href) ? 'page' : undefined}>
            {item.label}
          </a>
        ))
      }
    </nav>

    <nav
      class="language-switcher"
      aria-label={activeLang === 'pl' ? 'Przełącznik języka' : 'Language switcher'}
    >
      <a href={enPath} aria-current={activeLang === 'en' ? 'page' : undefined}>EN</a>
      <span aria-hidden="true">/</span>
      <a href={plPath} aria-current={activeLang === 'pl' ? 'page' : undefined}>PL</a>
    </nav>
  </div>
</header>

---
import Icon from './Icon.astro';

type IconName =
  | 'article'
  | 'attachment'
  | 'check'
  | 'concept'
  | 'culture'
  | 'decision'
  | 'dialogue'
  | 'emotion'
  | 'note'
  | 'spark'
  | 'trust'
  | 'work';

interface Props {
  icon: IconName;
  title: string;
  href?: string;
  linkLabel?: string;
  kicker?: string;
  number?: string;
  class?: string;
}

const {
  icon,
  title,
  href,
  linkLabel,
  kicker,
  number,
  class: className
} = Astro.props;
---

{
  href ? (
    <a class:list={['icon-card', 'icon-card-link', className]} href={href}>
      <span class="card-topline">
        {number && <span>{number}</span>}
        <Icon name={icon} />
      </span>
      {kicker && <p class="small-label">{kicker}</p>}
      <h3>{title}</h3>
      <p><slot /></p>
      {linkLabel && <span class="card-link-label">{linkLabel}</span>}
    </a>
  ) : (
    <article class:list={['icon-card', className]}>
      <span class="card-topline">
        {number && <span>{number}</span>}
        <Icon name={icon} />
      </span>
      {kicker && <p class="small-label">{kicker}</p>}
      <h3>{title}</h3>
      <p><slot /></p>
    </article>
  )
}

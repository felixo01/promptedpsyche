---
import type { Locale } from '../lib/i18n';

interface Props {
  lang: Locale;
  title: string;
  author: string;
  year: number;
  citationDate?: Date;
  siteName: string;
  canonicalUrl: string;
  doi?: string;
  doiUrl?: string;
  version?: string;
}

const { lang, title, author, year, citationDate, siteName, canonicalUrl, doiUrl } = Astro.props;
const label = lang === 'pl' ? 'Jak cytować' : 'Suggested citation';
const authorCitation = author === 'Feliks Mamczur' ? 'Mamczur, F.' : author;
const titleText = title.trim();
const titleWithStop = /[.!?]$/.test(titleText) ? titleText : `${titleText}.`;
const citationUrl = doiUrl ?? canonicalUrl;
const publicationDate = citationDate
  ? `${citationDate.getUTCFullYear()}, ${new Intl.DateTimeFormat(lang === 'pl' ? 'pl-PL' : 'en-US', {
      month: 'long',
      day: 'numeric',
      timeZone: 'UTC'
    }).format(citationDate)}`
  : String(year);
const citation = `${authorCitation} (${publicationDate}). ${titleWithStop} ${siteName}. ${citationUrl}`;
---

<section class="suggested-citation" data-qa="suggested-citation" aria-labelledby="suggested-citation-title">
  <h2 id="suggested-citation-title">{label}</h2>
  <p>{citation}</p>
</section>

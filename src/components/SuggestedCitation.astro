---
import type { Locale } from '../lib/i18n';

interface Props {
  lang: Locale;
  title: string;
  author: string;
  year: number;
  siteName: string;
  canonicalUrl: string;
}

const { lang, title, author, year, siteName, canonicalUrl } = Astro.props;
const label = lang === 'pl' ? 'Jak cytować' : 'Suggested citation';
const authorCitation = author === 'Feliks Mamczur' ? 'Mamczur, F.' : author;
const citation = `${authorCitation} (${year}). ${title}. ${siteName}. ${canonicalUrl}`;
---

<section class="suggested-citation" data-qa="suggested-citation" aria-labelledby="suggested-citation-title">
  <h2 id="suggested-citation-title">{label}</h2>
  <p>{citation}</p>
</section>

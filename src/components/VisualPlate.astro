---
type VisualVariant =
  | 'field-map'
  | 'process-flow'
  | 'concept-map'
  | 'note-stack'
  | 'attention-frame';

type Locale = 'en' | 'pl';

interface Props {
  variant: VisualVariant;
  lang?: Locale;
  caption?: string;
  class?: string;
}

const { variant, lang = 'en', caption, class: className } = Astro.props;
const titleId = `${variant}-${lang}-${Math.random().toString(36).slice(2)}-title`;
const title = lang === 'pl' ? 'Diagram pola Prompted Psyche' : 'Prompted Psyche field diagram';
---

<figure class:list={['visual-plate', `visual-plate-${variant}`, className]}>
  <svg
    viewBox="0 0 320 200"
    fill="none"
    stroke="currentColor"
    stroke-width="0.75"
    aria-labelledby={titleId}
    role="img"
  >
    <title id={titleId}>{title}</title>
    <circle cx="160" cy="100" r="72" opacity="0.35" />
    <circle cx="160" cy="100" r="44" opacity="0.55" />
    <circle cx="160" cy="100" r="18" opacity="0.9" />
    <line x1="10" y1="100" x2="310" y2="100" opacity="0.2" />
    <line x1="160" y1="10" x2="160" y2="190" opacity="0.2" />
    <line x1="52" y1="30" x2="268" y2="170" opacity="0.15" />
    <line x1="52" y1="170" x2="268" y2="30" opacity="0.15" />
    <circle cx="88" cy="100" r="2.5" fill="currentColor" />
    <circle cx="232" cy="100" r="2.5" fill="currentColor" />
    <circle cx="160" cy="28" r="2.5" fill="currentColor" />
    <circle cx="160" cy="172" r="2.5" fill="currentColor" />
    <circle cx="160" cy="100" r="4" fill="#3d5a5c" stroke="#3d5a5c" />
    <g
      font-family="JetBrains Mono, monospace"
      font-size="6"
      fill="currentColor"
      opacity="0.55"
      stroke="none"
    >
      <text x="10" y="96">TRUST</text>
      <text x="278" y="96">WORK</text>
      <text x="146" y="20">EMOTION</text>
      <text x="140" y="188">CULTURE</text>
    </g>
  </svg>
  {caption && <figcaption class="visual-plate-label">{caption}</figcaption>}
</figure>

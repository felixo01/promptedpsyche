---
type VisualVariant =
  | 'field-map'
  | 'process-flow'
  | 'concept-map'
  | 'note-stack'
  | 'attention-frame';

type Locale = 'en' | 'pl';

interface Props {
  variant: VisualVariant;
  lang?: Locale;
  caption?: string;
  class?: string;
}

const { variant, lang = 'en', caption, class: className } = Astro.props;
const titleId = `${variant}-${lang}-${Math.random().toString(36).slice(2)}-title`;

const labels = {
  en: {
    'field-map': {
      title: 'Field map of human-AI trust',
      items: ['person', 'AI answer', 'trust', 'decision', 'responsibility']
    },
    'process-flow': {
      title: 'Human-AI work flow',
      items: ['task', 'AI draft', 'verify', 'decide', 'team result']
    },
    'concept-map': {
      title: 'Concept map',
      items: ['AI literacy', 'trust', 'work', 'responsibility', 'emotion']
    },
    'note-stack': {
      title: 'Editorial notes stack',
      items: ['essays', 'notes', 'concepts']
    },
    'attention-frame': {
      title: 'Attention frame',
      items: ['narrative', 'attention', 'image', 'emotion']
    }
  },
  pl: {
    'field-map': {
      title: 'Mapa relacji człowiek-AI',
      items: ['człowiek', 'odpowiedź AI', 'zaufanie', 'decyzja', 'odpowiedzialność']
    },
    'process-flow': {
      title: 'Przepływ pracy człowiek-AI',
      items: ['zadanie', 'szkic AI', 'weryfikacja', 'decyzja', 'wynik zespołu']
    },
    'concept-map': {
      title: 'Mapa pojęć',
      items: ['kompetencje AI', 'zaufanie', 'praca', 'odpowiedzialność', 'emocje']
    },
    'note-stack': {
      title: 'Stos notatek redakcyjnych',
      items: ['teksty', 'notatki', 'pojęcia']
    },
    'attention-frame': {
      title: 'Rama uwagi',
      items: ['narracja', 'uwaga', 'obraz', 'emocje']
    }
  }
} as const;

const copy = labels[lang][variant];
---

<figure class:list={['visual-plate', `visual-plate-${variant}`, className]}>
  <svg
    viewBox="0 0 320 180"
    fill="none"
    stroke="currentColor"
    aria-labelledby={titleId}
    role="img"
  >
    <title id={titleId}>{copy.title}</title>

    {
      variant === 'field-map' && (
        <>
          <path class="diagram-line visual-muted" d="M69 84 C99 52 132 46 160 74" />
          <path class="diagram-line visual-muted" d="M177 76 C204 50 235 55 258 84" />
          <path class="diagram-line visual-muted" d="M160 96 C145 122 119 135 91 125" />
          <path class="diagram-line visual-muted" d="M175 98 C190 126 217 137 244 126" />
          <circle class="diagram-node diagram-node-primary" cx="60" cy="90" r="21" />
          <circle class="diagram-node" cx="160" cy="88" r="25" />
          <circle class="diagram-node" cx="267" cy="91" r="21" />
          <circle class="diagram-node" cx="88" cy="128" r="15" />
          <circle class="diagram-node" cx="244" cy="128" r="15" />
          <path class="diagram-line" d="M51 88h18" />
          <path class="diagram-line" d="M60 79v18" />
          <path class="diagram-line" d="M149 84h22" />
          <path class="diagram-line" d="M149 93h17" />
          <path class="diagram-line" d="M258 89l7 7 14-17" />
          <text class="diagram-caption" x="60" y="42" text-anchor="middle">{copy.items[0]}</text>
          <text class="diagram-caption" x="160" y="44" text-anchor="middle">{copy.items[1]}</text>
          <text class="diagram-caption" x="267" y="43" text-anchor="middle">{copy.items[2]}</text>
          <text class="diagram-caption" x="88" y="159" text-anchor="middle">{copy.items[3]}</text>
          <text class="diagram-caption" x="244" y="159" text-anchor="middle">{copy.items[4]}</text>
        </>
      )
    }

    {
      variant === 'process-flow' && (
        <>
          {[48, 104, 160, 216, 272].map((x, index) => (
            <>
              {index < 4 && <path class="diagram-line visual-muted" d={`M${x + 18} 88 H${x + 38}`} />}
              <rect class="diagram-node" x={x - 18} y="66" width="36" height="44" rx="7" />
            </>
          ))}
          <path class="diagram-line" d="M40 82h16" />
          <path class="diagram-line" d="M40 91h12" />
          <path class="diagram-line" d="M96 82h16" />
          <path class="diagram-line" d="M96 91h12" />
          <path class="diagram-line" d="M151 88l7 7 13-18" />
          <path class="diagram-line" d="M209 82h14" />
          <path class="diagram-line" d="M209 94h14" />
          <path class="diagram-line" d="M264 82h16" />
          <path class="diagram-line" d="M264 91h16" />
          <path class="diagram-line" d="M264 100h11" />
          {copy.items.map((item, index) => (
            <text class="diagram-caption" x={48 + index * 56} y="136" text-anchor="middle">{item}</text>
          ))}
        </>
      )
    }

    {
      variant === 'concept-map' && (
        <>
          <circle class="diagram-node diagram-node-primary" cx="160" cy="88" r="31" />
          <circle class="diagram-node" cx="83" cy="58" r="22" />
          <circle class="diagram-node" cx="238" cy="58" r="22" />
          <circle class="diagram-node" cx="93" cy="132" r="22" />
          <circle class="diagram-node" cx="230" cy="132" r="22" />
          <path class="diagram-line visual-muted" d="M106 65 L132 77" />
          <path class="diagram-line visual-muted" d="M214 65 L188 77" />
          <path class="diagram-line visual-muted" d="M114 125 L133 104" />
          <path class="diagram-line visual-muted" d="M211 125 L188 103" />
          <text class="diagram-caption diagram-caption-strong" x="160" y="92" text-anchor="middle">{copy.items[0]}</text>
          <text class="diagram-caption" x="83" y="61" text-anchor="middle">{copy.items[1]}</text>
          <text class="diagram-caption" x="238" y="61" text-anchor="middle">{copy.items[2]}</text>
          <text class="diagram-caption" x="93" y="135" text-anchor="middle">{copy.items[3]}</text>
          <text class="diagram-caption" x="230" y="135" text-anchor="middle">{copy.items[4]}</text>
        </>
      )
    }

    {
      variant === 'note-stack' && (
        <>
          <rect class="diagram-node visual-muted" x="86" y="42" width="150" height="88" rx="8" />
          <rect class="diagram-node visual-muted" x="72" y="58" width="150" height="88" rx="8" />
          <rect class="diagram-node diagram-node-primary" x="98" y="70" width="150" height="88" rx="8" />
          <path class="diagram-line" d="M120 94h76" />
          <path class="diagram-line" d="M120 112h96" />
          <path class="diagram-line" d="M120 130h55" />
          <circle class="diagram-node" cx="218" cy="126" r="13" />
          <path class="diagram-line" d="M212 126h12" />
          <path class="diagram-line" d="M218 120v12" />
          <text class="diagram-caption" x="101" y="32">{copy.items[0]}</text>
          <text class="diagram-caption" x="67" y="159">{copy.items[1]}</text>
          <text class="diagram-caption" x="207" y="168">{copy.items[2]}</text>
        </>
      )
    }

    {
      variant === 'attention-frame' && (
        <>
          <rect class="diagram-node diagram-node-primary" x="58" y="42" width="204" height="102" rx="10" />
          <path class="diagram-line visual-muted" d="M86 42v102" />
          <path class="diagram-line visual-muted" d="M234 42v102" />
          <path class="diagram-line visual-muted" d="M58 72h204" />
          <path class="diagram-line visual-muted" d="M58 114h204" />
          <circle class="diagram-node" cx="138" cy="90" r="17" />
          <circle class="diagram-node" cx="190" cy="90" r="11" />
          <path class="diagram-line" d="M126 86 C143 72 166 74 181 87" />
          <path class="diagram-line" d="M126 99 C145 113 169 111 184 97" />
          <text class="diagram-caption" x="60" y="28">{copy.items[0]}</text>
          <text class="diagram-caption" x="203" y="28">{copy.items[1]}</text>
          <text class="diagram-caption" x="60" y="166">{copy.items[2]}</text>
          <text class="diagram-caption" x="211" y="166">{copy.items[3]}</text>
        </>
      )
    }
  </svg>
  {caption && <figcaption class="visual-plate-label">{caption}</figcaption>}
</figure>

---
import Icon from './Icon.astro';
import TagList from './TagList.astro';
import { formatDate } from '../lib/content';
import type { Locale } from '../lib/i18n';

interface EntryListItem {
  id: string;
  data: {
    title: string;
    description: string;
    publishedAt: Date;
    draft?: boolean;
    tags?: string[];
    routeSlug?: string;
    readingTime?: string;
  };
}

interface Props {
  entries: EntryListItem[];
  basePath: string;
  label: string;
  dateLocale?: Locale;
  emptyLabel?: string;
  emptyMessage?: string;
  emptyNote?: string;
  emptyIcon?: 'article' | 'note' | 'concept';
  ctaLabel?: string;
}

const {
  entries,
  basePath,
  label,
  dateLocale = 'en',
  emptyLabel = `${label} archive`,
  emptyMessage = 'Public writing is being prepared.',
  emptyNote = 'Essays, notes and concepts are being edited before they are published here.',
  emptyIcon,
  ctaLabel
} = Astro.props;
---

{
  entries.length === 0 ? (
    <div class="empty-state publication-empty">
      <span class="dossier-stamp" aria-hidden="true">PP</span>
      {emptyIcon && <Icon name={emptyIcon} />}
      <p class="small-label">{emptyLabel}</p>
      <p>{emptyMessage}</p>
      {emptyNote && <p class="empty-state-note">{emptyNote}</p>}
    </div>
  ) : (
    <div class="entry-list">
      {entries.map((entry) => {
        const tags = entry.data.tags ?? [];
        const entrySlug = entry.data.routeSlug ?? entry.id;
        const href = `${basePath}/${entrySlug}/`;

        return (
          <article class:list={['entry-item', ctaLabel && 'entry-item--actionable']}>
            <div class="entry-meta">
              <span>{label}</span>
              <time datetime={entry.data.publishedAt.toISOString()}>
                {formatDate(entry.data.publishedAt, dateLocale)}
              </time>
              {entry.data.readingTime && <span>{entry.data.readingTime}</span>}
            </div>
            <div class="entry-body">
              <h2>
                <a class="entry-title-link" href={href}>{entry.data.title}</a>
              </h2>
              <p>{entry.data.description}</p>
              {ctaLabel && (
                <a class="entry-cta" href={href} aria-label={`${ctaLabel}: ${entry.data.title}`}>
                  <span>{ctaLabel}</span>
                  <span aria-hidden="true">-&gt;</span>
                </a>
              )}
              <TagList tags={tags} lang={dateLocale} dataQa="publication-tag" />
            </div>
          </article>
        );
      })}
    </div>
  )
}

---
import Icon from './Icon.astro';
import { formatDate } from '../lib/content';
import type { Locale } from '../lib/i18n';

interface EntryListItem {
  id: string;
  data: {
    title: string;
    description: string;
    publishedAt: Date;
    draft?: boolean;
    tags?: string[];
  };
}

interface Props {
  entries: EntryListItem[];
  basePath: string;
  label: string;
  dateLocale?: Locale;
  emptyLabel?: string;
  emptyMessage?: string;
  emptyNote?: string;
  emptyIcon?: 'article' | 'note' | 'concept';
}

const {
  entries,
  basePath,
  label,
  dateLocale = 'en',
  emptyLabel = `${label} archive`,
  emptyMessage = 'Public writing is being prepared.',
  emptyNote = 'Essays, notes and concepts are being edited before they are published here.',
  emptyIcon
} = Astro.props;
---

{
  entries.length === 0 ? (
    <div class="empty-state publication-empty">
      <span class="dossier-stamp" aria-hidden="true">PP</span>
      {emptyIcon && <Icon name={emptyIcon} />}
      <p class="small-label">{emptyLabel}</p>
      <p>{emptyMessage}</p>
      {emptyNote && <p class="empty-state-note">{emptyNote}</p>}
    </div>
  ) : (
    <div class="entry-list">
      {entries.map((entry) => {
        const tags = entry.data.tags ?? [];

        return (
          <article class="entry-item">
            <div class="entry-meta">
              <span>{label}</span>
              <time datetime={entry.data.publishedAt.toISOString()}>
                {formatDate(entry.data.publishedAt, dateLocale)}
              </time>
            </div>
            <h2>
              <a href={`${basePath}/${entry.id}/`}>{entry.data.title}</a>
            </h2>
            <p>{entry.data.description}</p>
            {tags.length > 0 && (
              <ul class="tag-list" aria-label="Topics">
                {tags.map((tag) => (
                  <li>{tag}</li>
                ))}
              </ul>
            )}
          </article>
        );
      })}
    </div>
  )
}

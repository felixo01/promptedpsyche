---
import { formatDate } from '../lib/content';

interface EntryListItem {
  id: string;
  data: {
    title: string;
    description: string;
    publishedAt: Date;
    draft?: boolean;
    tags?: string[];
  };
}

interface Props {
  entries: EntryListItem[];
  basePath: string;
  label: string;
}

const { entries, basePath, label } = Astro.props;
---

{
  entries.length === 0 ? (
    <div class="empty-state">
      <p class="small-label">Pre-launch archive</p>
      <p>Public writing is being prepared.</p>
    </div>
  ) : (
    <div class="entry-list">
      {entries.map((entry) => {
        const tags = entry.data.tags ?? [];

        return (
          <article class="entry-item">
            <div class="entry-meta">
              <span>{label}</span>
              <time datetime={entry.data.publishedAt.toISOString()}>
                {formatDate(entry.data.publishedAt)}
              </time>
            </div>
            <h2>
              <a href={`${basePath}/${entry.id}/`}>{entry.data.title}</a>
            </h2>
            <p>{entry.data.description}</p>
            {tags.length > 0 && (
              <ul class="tag-list" aria-label="Topics">
                {tags.map((tag) => (
                  <li>{tag}</li>
                ))}
              </ul>
            )}
          </article>
        );
      })}
    </div>
  )
}

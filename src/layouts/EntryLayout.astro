---
import BaseLayout from './BaseLayout.astro';
import { formatDate } from '../lib/content';

const { entry, label } = Astro.props;
const tags: string[] = entry.data.tags ?? [];
const readingTime = entry.data.readingTime;
---

<BaseLayout title={entry.data.title} description={entry.data.description} type="article">
  <article class="article-shell">
    <header class="content-header">
      <p class="eyebrow">{label}</p>
      <h1>{entry.data.title}</h1>
      <p class="lede">{entry.data.description}</p>
      <div class="content-meta">
        <span>{entry.data.author}</span>
        <time datetime={entry.data.publishedAt.toISOString()}>
          {formatDate(entry.data.publishedAt)}
        </time>
        {readingTime && <span>{readingTime}</span>}
      </div>
      {tags.length > 0 && (
        <ul class="tag-list content-tags" aria-label="Topics">
          {tags.map((tag) => (
            <li>{tag}</li>
          ))}
        </ul>
      )}
    </header>

    <div class="article-grid">
      <aside class="article-aside" aria-label="Article structure">
        <p class="small-label">Prepared for</p>
        <ul>
          <li>sources</li>
          <li>further reading</li>
          <li>related notes</li>
        </ul>
      </aside>

      <div class="prose">
        <slot />
      </div>
    </div>
  </article>
</BaseLayout>

---
import BaseLayout from './BaseLayout.astro';
import RightsNotice from '../components/RightsNotice.astro';
import { formatDate } from '../lib/content';
import type { AlternateLinks, Locale } from '../lib/i18n';

interface Props {
  entry: {
    data: {
      title: string;
      description: string;
      author: string;
      publishedAt: Date;
      readingTime?: string;
      tags?: string[];
    };
  };
  label: string;
  lang?: Locale;
  alternateLinks?: AlternateLinks;
  showPublishedAt?: boolean;
  showRightsNotice?: boolean;
}

const {
  entry,
  label,
  lang = 'en',
  alternateLinks,
  showPublishedAt = true,
  showRightsNotice = true
} = Astro.props;
const tags: string[] = entry.data.tags ?? [];
const readingTime = entry.data.readingTime;
const isConceptEntry = !showPublishedAt;
const conceptBackHref = lang === 'pl' ? '/pl/concepts/' : '/concepts/';
const conceptBackLabel = lang === 'pl' ? 'Wróć do pojęć' : 'Back to concepts';
// Tags are informational for now. Add tag routes or filtering before making them interactive.
const asideLabels = lang === 'pl'
  ? {
      aria: 'Struktura wpisu',
      preparedFor: 'Przygotowane pod',
      items: ['źródła', 'kontekst', 'powiązane pojęcia']
    }
  : {
      aria: 'Entry structure',
      preparedFor: 'Prepared for',
      items: ['sources', 'context', 'related concepts']
    };
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.description}
  type="article"
  lang={lang}
  alternateLinks={alternateLinks}
>
  <article class="article-shell">
    <header class="content-header">
      {
        isConceptEntry ? (
          <div class="content-topline">
            <a href={conceptBackHref}>{conceptBackLabel}</a>
            <span>{label}</span>
          </div>
        ) : (
          <p class="eyebrow">{label}</p>
        )
      }
      <h1>{entry.data.title}</h1>
      <p class="lede">{entry.data.description}</p>
      {
        (!isConceptEntry || readingTime) && (
          <div class="content-meta">
            {!isConceptEntry && <span>{entry.data.author}</span>}
            {showPublishedAt && (
              <time datetime={entry.data.publishedAt.toISOString()}>
                {formatDate(entry.data.publishedAt, lang)}
              </time>
            )}
            {readingTime && <span>{readingTime}</span>}
          </div>
        )
      }
      {tags.length > 0 && (
        <ul class="tag-list content-tags" aria-label="Topics">
          {tags.map((tag) => (
            <li data-qa="concept-tag">{tag}</li>
          ))}
        </ul>
      )}
    </header>

    <div class="article-grid">
      <aside class="article-aside" aria-label={asideLabels.aria}>
        <p class="small-label">{asideLabels.preparedFor}</p>
        <ul>
          {asideLabels.items.map((item) => <li>{item}</li>)}
        </ul>
      </aside>

      <div class="prose">
        <slot />
        {showRightsNotice && <RightsNotice lang={lang} variant="content" title={entry.data.title} />}
      </div>
    </div>
  </article>
</BaseLayout>

---
import BaseLayout from './BaseLayout.astro';
import { formatDate } from '../lib/content';

const { entry, label } = Astro.props;
---

<BaseLayout title={entry.data.title} description={entry.data.description} type="article">
  <article class="content-shell">
    <header class="content-header">
      <p class="eyebrow">{label}</p>
      <h1>{entry.data.title}</h1>
      <p class="lede">{entry.data.description}</p>
      <div class="content-meta">
        <span>{entry.data.author}</span>
        <time datetime={entry.data.publishedAt.toISOString()}>
          {formatDate(entry.data.publishedAt)}
        </time>
        {entry.data.draft && <span>Draft</span>}
      </div>
    </header>

    <div class="prose">
      <slot />
    </div>
  </article>
</BaseLayout>

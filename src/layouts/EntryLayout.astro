---
import BaseLayout from './BaseLayout.astro';
import ConsultingCTA from '../components/ConsultingCTA.astro';
import InBrief from '../components/InBrief.astro';
import ContinueExploring from '../components/ContinueExploring.astro';
import RightsNotice from '../components/RightsNotice.astro';
import SuggestedCitation from '../components/SuggestedCitation.astro';
import TagList from '../components/TagList.astro';
import { formatDate } from '../lib/content';
import type { AlternateLinks, Locale } from '../lib/i18n';
import { absoluteUrl, getAuthorEntity, getAuthorUrl, site } from '../lib/site';
import type { TopicResource } from '../lib/topics';

interface Props {
  entry: {
    data: {
      title: string;
      description: string;
      author: string;
      publishedAt: Date;
      updatedAt?: Date;
      readingTime?: string;
      image?: string;
      imageWidth?: number;
      imageHeight?: number;
      imageType?: string;
      imageAlt?: string;
      imageCaption?: string;
      socialImage?: string;
      socialImageWidth?: number;
      socialImageHeight?: number;
      socialImageType?: string;
      doi?: string;
      doiUrl?: string;
      version?: string;
      relatedDoi?: string;
      relatedDoiUrl?: string;
      relatedVersion?: string;
      relatedDoiLabel?: string;
      licenseName?: string;
      licenseUrl?: string;
      audioUrl?: string;
      inBrief?: string[];
      tags?: string[];
    };
  };
  label: string;
  lang?: Locale;
  alternateLinks?: AlternateLinks;
  robots?: string;
  showPublishedAt?: boolean;
  showRightsNotice?: boolean;
  explorationLinks?: TopicResource[];
}

const {
  entry,
  label,
  lang = 'en',
  alternateLinks,
  robots,
  showPublishedAt = true,
  showRightsNotice = true,
  explorationLinks = []
} = Astro.props;
const tags: string[] = entry.data.tags ?? [];
const readingTime = entry.data.readingTime;
const isConceptEntry = !showPublishedAt;
const isArticleEntry = label === 'Article' || label === 'Artykuł';
const isNoteEntry = label === 'Note' || label === 'Notatka';
const showConsultingCta = isArticleEntry || isNoteEntry;
const conceptBackHref = lang === 'pl' ? '/pl/concepts/' : '/concepts/';
const conceptBackLabel = lang === 'pl' ? 'Wróć do pojęć' : 'Back to concepts';
const aboutHref = getAuthorUrl(lang);
const authorLabel = lang === 'pl' ? 'Autor:' : 'By';
const publishedLabel = lang === 'pl' ? 'Opublikowano:' : 'Published:';
const updatedLabel = lang === 'pl' ? 'Aktualizacja:' : 'Updated:';
const canonicalUrl = new URL(Astro.url.pathname, site.url).toString();
const heroImage = !isConceptEntry ? entry.data.image : undefined;
const heroImageWidth = entry.data.imageWidth;
const heroImageHeight = entry.data.imageHeight;
const heroImageAlt = entry.data.imageAlt ?? entry.data.title;
const heroImageCaption = entry.data.imageCaption;
const socialImage = !isConceptEntry ? (entry.data.socialImage ?? heroImage) : undefined;
const socialImageWidth = entry.data.socialImageWidth ?? (socialImage === heroImage ? heroImageWidth : undefined);
const socialImageHeight = entry.data.socialImageHeight ?? (socialImage === heroImage ? heroImageHeight : undefined);
const socialImageType = entry.data.socialImageType ?? (socialImage === heroImage ? entry.data.imageType : undefined);
const doi = isArticleEntry ? entry.data.doi : undefined;
const doiUrl = doi ? (entry.data.doiUrl ?? `https://doi.org/${doi}`) : undefined;
const version = isArticleEntry ? entry.data.version : undefined;
const relatedDoi = isArticleEntry ? entry.data.relatedDoi : undefined;
const relatedDoiUrl = relatedDoi ? (entry.data.relatedDoiUrl ?? `https://doi.org/${relatedDoi}`) : undefined;
const relatedVersion = isArticleEntry ? entry.data.relatedVersion : undefined;
const relatedDoiLabel = entry.data.relatedDoiLabel ?? (lang === 'pl' ? 'DOI wersji angielskiej' : 'English version DOI');
const licenseName = isArticleEntry ? entry.data.licenseName : undefined;
const licenseUrl = isArticleEntry ? entry.data.licenseUrl : undefined;
const audioUrl = !isConceptEntry ? entry.data.audioUrl : undefined;
const inBriefItems = isArticleEntry ? (entry.data.inBrief ?? []) : [];
const citableVersionLabel = lang === 'pl' ? 'Wersja do cytowania' : 'Citable version';
const visibleDoi = doi ?? relatedDoi;
const visibleDoiUrl = doiUrl ?? relatedDoiUrl;
const visibleDoiVersion = doi ? version : relatedVersion;
const visibleDoiLabel = doi ? citableVersionLabel : relatedDoiLabel;
const articleStructuredData = isArticleEntry
  ? {
      '@context': 'https://schema.org',
      '@type': 'Article',
      headline: entry.data.title,
      description: entry.data.description,
      url: canonicalUrl,
      mainEntityOfPage: {
        '@type': 'WebPage',
        '@id': canonicalUrl
      },
      datePublished: entry.data.publishedAt.toISOString(),
      ...(entry.data.updatedAt ? { dateModified: entry.data.updatedAt.toISOString() } : {}),
      author: getAuthorEntity(lang),
      inLanguage: lang,
      isPartOf: {
        '@type': 'WebSite',
        name: site.name,
        url: site.url
      },
      ...(doi
        ? {
            identifier: {
              '@type': 'PropertyValue',
              propertyID: 'DOI',
              value: doi
            }
          }
        : {}),
      ...(doiUrl ? { sameAs: doiUrl } : {}),
      ...(licenseUrl ? { license: licenseUrl } : {}),
      ...(version ? { version } : {}),
      ...(socialImage ? { image: absoluteUrl(socialImage) } : {})
    }
  : undefined;
const audioLabel = lang === 'pl' ? 'Wersja audio' : 'Audio version';
const audioFallback =
  lang === 'pl'
    ? 'Twoja przeglądarka nie obsługuje odtwarzacza audio.'
    : 'Your browser does not support the audio player.';
const asideLabels = isConceptEntry
  ? lang === 'pl'
    ? {
        aria: 'Informacje o haśle',
        label: 'W haśle',
        items: ['Definicja', 'Źródła', 'Powiązane pojęcia']
      }
    : {
        aria: 'Entry information',
        label: 'In this entry',
        items: ['Definition', 'Sources', 'Related concepts']
      }
  : lang === 'pl'
    ? {
        aria: 'Informacje o tekście',
        label: 'W tekście',
        items: ['Kontekst', 'Źródła', 'Powiązane pojęcia']
      }
    : {
        aria: 'Article information',
        label: 'In this article',
        items: ['Context', 'Sources', 'Related concepts']
      };
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.description}
  image={socialImage}
  imageWidth={socialImageWidth}
  imageHeight={socialImageHeight}
  imageType={socialImageType}
  imageAlt={socialImage ? heroImageAlt : undefined}
  type="article"
  lang={lang}
  alternateLinks={alternateLinks}
  robots={robots}
  structuredData={articleStructuredData}
  citationDoi={doi}
>
  <article class:list={['article-shell', isConceptEntry ? 'article-shell--concept' : 'article-shell--publication']}>
    <header class="content-header">
      <div class="content-header-inner">
        {
          isConceptEntry ? (
            <div class="content-topline">
              <a href={conceptBackHref}>{conceptBackLabel}</a>
              <span>{label}</span>
            </div>
          ) : (
            <p class="eyebrow">{label}</p>
          )
        }
        <h1>{entry.data.title}</h1>
        <p class="lede">{entry.data.description}</p>
        <InBrief items={inBriefItems} lang={lang} />
        {!isConceptEntry && (
          <div class="article-byline" data-qa="article-byline">
            <p>
              <span>{authorLabel}</span>{' '}
              <a href={aboutHref}>{entry.data.author}</a>
            </p>
            <p>{site.name}</p>
            <p>
              <span>{publishedLabel}</span>{' '}
              <time datetime={entry.data.publishedAt.toISOString()}>
                {formatDate(entry.data.publishedAt, lang)}
              </time>
            </p>
            {entry.data.updatedAt && (
              <p>
                <span>{updatedLabel}</span>{' '}
                <time datetime={entry.data.updatedAt.toISOString()}>
                  {formatDate(entry.data.updatedAt, lang)}
                </time>
              </p>
            )}
            {readingTime && <p>{readingTime}</p>}
            {visibleDoi && visibleDoiUrl && (
              <p class="article-byline__citable">
                <span>{visibleDoiLabel}{visibleDoiVersion ? ` (v${visibleDoiVersion})` : ''}:</span>{' '}
                <a href={visibleDoiUrl} aria-label={`DOI ${visibleDoi}`}>
                  DOI {visibleDoi}
                </a>
              </p>
            )}
          </div>
        )}
        {isConceptEntry && readingTime && (
          <div class="content-meta">
            <span>{readingTime}</span>
          </div>
        )}
        <TagList
          tags={tags}
          lang={lang}
          linked={!isConceptEntry}
          className="content-tags"
          dataQa={isConceptEntry ? 'concept-tag' : 'publication-tag'}
        />
      </div>
    </header>

    {heroImage && (
      <figure class="article-hero-figure" data-qa="article-hero-figure">
        <img
          src={heroImage}
          alt={heroImageAlt}
          width={heroImageWidth}
          height={heroImageHeight}
          loading="eager"
          decoding="async"
          data-qa="article-hero-image"
        />
        {heroImageCaption && <figcaption>{heroImageCaption}</figcaption>}
      </figure>
    )}

    {audioUrl && (
      <section class="article-audio" aria-label={audioLabel} data-qa="article-audio">
        <p class="small-label">{audioLabel}</p>
        <audio controls preload="none" src={audioUrl}>
          {audioFallback}
        </audio>
      </section>
    )}

    <div class="article-grid">
      <aside class="article-aside" aria-label={asideLabels.aria}>
        <p class="small-label" data-qa="article-aside-label">{asideLabels.label}</p>
        <ul>
          {asideLabels.items.map((item) => <li>{item}</li>)}
        </ul>
      </aside>

      <div class="prose">
        <slot />
        <ContinueExploring links={explorationLinks} lang={lang} />
        {showConsultingCta && <ConsultingCTA lang={lang} />}
        {!isConceptEntry && (
          <SuggestedCitation
            lang={lang}
            title={entry.data.title}
            author={entry.data.author}
            year={entry.data.publishedAt.getFullYear()}
            citationDate={entry.data.publishedAt}
            siteName={site.name}
            canonicalUrl={canonicalUrl}
            doi={doi}
            doiUrl={doiUrl}
            version={version}
          />
        )}
        {showRightsNotice && (
          <RightsNotice
            lang={lang}
            variant="content"
            title={entry.data.title}
            licenseName={licenseName}
            licenseUrl={licenseUrl}
          />
        )}
      </div>
    </div>
  </article>

  <script is:inline>
    (() => {
      const enhanceMarkdownPromptBlocks = () => {
        const lang = document.documentElement.lang === 'pl' ? 'pl' : 'en';
        const label = lang === 'pl' ? 'Przykładowy prompt' : 'Example prompt';
        const copyLabel = lang === 'pl' ? 'Kopiuj' : 'Copy';
        const copiedLabel = lang === 'pl' ? 'Skopiowano' : 'Copied';
        const ariaLabel = lang === 'pl' ? 'Kopiuj przykładowy prompt' : 'Copy example prompt';

        document.querySelectorAll('.prose > pre').forEach((pre) => {
          if (pre.closest('[data-copyable-prompt]') || pre.dataset.promptEnhanced === 'true') {
            return;
          }

          pre.dataset.promptEnhanced = 'true';
          pre.classList.add('prompt-example__body');

          const code = pre.querySelector('code');
          if (code && !code.hasAttribute('data-prompt-text')) {
            code.setAttribute('data-prompt-text', '');
          }

          const wrapper = document.createElement('div');
          wrapper.className = 'prompt-example prompt-example--better';
          wrapper.setAttribute('data-copyable-prompt', '');

          const header = document.createElement('div');
          header.className = 'prompt-example__header';

          const labelElement = document.createElement('p');
          labelElement.className = 'prompt-example__label';
          labelElement.textContent = label;

          const button = document.createElement('button');
          button.className = 'prompt-example__copy';
          button.type = 'button';
          button.setAttribute('aria-label', ariaLabel);
          button.setAttribute('data-copy-label', copyLabel);
          button.setAttribute('data-copied-label', copiedLabel);
          button.textContent = copyLabel;

          header.append(labelElement, button);
          pre.before(wrapper);
          wrapper.append(header, pre);
        });
      };

      const initializePromptCopy = () => {
        document.querySelectorAll('[data-copyable-prompt]').forEach((box) => {
          const button = box.querySelector('.prompt-example__copy');
          const promptBody = box.querySelector('[data-prompt-text]');

          if (!button || !promptBody || button.dataset.promptCopyReady === 'true') {
            return;
          }

          button.dataset.promptCopyReady = 'true';
          const copyLabel = button.getAttribute('data-copy-label') || button.textContent || 'Copy';
          const copiedLabel = button.getAttribute('data-copied-label') || 'Copied';

          button.addEventListener('click', async () => {
            const promptText = (promptBody.textContent || '').trim();

            try {
              if (!navigator.clipboard?.writeText) {
                throw new Error('Clipboard API unavailable');
              }

              await navigator.clipboard.writeText(promptText);
              button.textContent = copiedLabel;
              button.dataset.copyState = 'copied';

              window.setTimeout(() => {
                button.textContent = copyLabel;
                button.dataset.copyState = 'ready';
              }, 1600);
            } catch {
              button.dataset.copyState = 'unavailable';
            }
          });
        });
      };

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', () => {
          enhanceMarkdownPromptBlocks();
          initializePromptCopy();
        }, { once: true });
      } else {
        enhanceMarkdownPromptBlocks();
        initializePromptCopy();
      }
    })();
  </script>
</BaseLayout>

---
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { getAlternateLinks, getLangFromPath, type Locale } from '../lib/i18n';
import { site } from '../lib/site';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  lang?: Locale;
}

const {
  title = site.name,
  description = site.description,
  image = '/images/prompted-psyche-editorial.png',
  type = 'website',
  lang = getLangFromPath(Astro.url.pathname)
} = Astro.props;

const pageTitle = title === site.name ? `${site.name} | ${site.tagline}` : `${title} | ${site.name}`;
const canonicalUrl = new URL(Astro.url.pathname, site.url).toString();
const imageUrl = new URL(image, site.url).toString();
const rssUrl = new URL('/rss.xml', site.url).toString();
const alternateLinks = getAlternateLinks(Astro.url.pathname);
const skipLinkLabel = lang === 'pl' ? 'Przejdź do treści' : 'Skip to content';
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="noindex, nofollow, noarchive, nosnippet" />
    <meta name="googlebot" content="noindex, nofollow, noarchive, nosnippet" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang="en" href={new URL(alternateLinks.en, site.url).toString()} />
    <link rel="alternate" hreflang="pl" href={new URL(alternateLinks.pl, site.url).toString()} />
    <link rel="alternate" hreflang="x-default" href={new URL(alternateLinks.xDefault, site.url).toString()} />
    <link rel="alternate" type="application/rss+xml" title={`${site.name} RSS`} href={rssUrl} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    <meta property="og:site_name" content={site.name} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={imageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
  </head>
  <body>
    <a class="skip-link" href="#main">{skipLinkLabel}</a>
    <Header lang={lang} />
    <main id="main">
      <slot />
    </main>
    <Footer lang={lang} />
  </body>
</html>

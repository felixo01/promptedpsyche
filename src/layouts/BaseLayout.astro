---
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import Analytics from '@vercel/analytics/astro';
import { getAlternateLinks, getLangFromPath, type AlternateLinks, type Locale } from '../lib/i18n';
import { getPublisherEntity, getWebsiteEntity, site } from '../lib/site';
import '../styles/global.css';
import '../styles/content-enhancements.css';

type StructuredData = Record<string, unknown>;

interface Props {
  title?: string;
  appendSiteName?: boolean;
  description?: string;
  image?: string;
  imageWidth?: number;
  imageHeight?: number;
  imageType?: string;
  imageAlt?: string;
  type?: 'website' | 'article';
  lang?: Locale;
  alternateLinks?: AlternateLinks;
  robots?: string;
  structuredData?: StructuredData | StructuredData[];
  citationDoi?: string;
}

const {
  title = site.name,
  appendSiteName = true,
  description = site.description,
  image = '/images/social/prompted-psyche-home-social-1200x630.png',
  imageWidth,
  imageHeight,
  imageType,
  imageAlt,
  type = 'website',
  lang = getLangFromPath(Astro.url.pathname),
  alternateLinks: providedAlternateLinks,
  robots,
  structuredData,
  citationDoi
} = Astro.props;

const pageTitle = title === site.name
  ? `${site.name} | ${site.tagline}`
  : appendSiteName
    ? `${title} | ${site.name}`
    : title;
const canonicalUrl = new URL(Astro.url.pathname, site.url).toString();
const imageUrl = new URL(image, site.url).toString();
const defaultSocialImage = '/images/social/prompted-psyche-home-social-1200x630.png';
const usesDefaultSocialImage = image === defaultSocialImage;
const resolvedImageWidth = imageWidth ?? (usesDefaultSocialImage ? 1200 : undefined);
const resolvedImageHeight = imageHeight ?? (usesDefaultSocialImage ? 630 : undefined);
const resolvedImageType = imageType ?? (usesDefaultSocialImage ? 'image/png' : undefined);
const resolvedImageAlt =
  imageAlt ?? (usesDefaultSocialImage ? 'Prompted Psyche - The human side of AI' : undefined);
const rssUrl = new URL('/rss.xml', site.url).toString();
const fallbackAlternateLinks = getAlternateLinks(Astro.url.pathname);
const alternateLinks = {
  en: providedAlternateLinks?.en ?? fallbackAlternateLinks.en,
  pl: providedAlternateLinks?.pl ?? fallbackAlternateLinks.pl,
  xDefault: providedAlternateLinks?.xDefault ?? providedAlternateLinks?.en ?? fallbackAlternateLinks.xDefault
};
const skipLinkLabel = lang === 'pl' ? 'Przejdź do treści' : 'Skip to content';
const structuredDataItems = structuredData
  ? Array.isArray(structuredData)
    ? structuredData
    : [structuredData]
  : [];
const pageStructuredDataNodes = structuredDataItems.flatMap((item) => {
  const { ['@context']: _context, ['@graph']: graph, ...node } = item;

  return Array.isArray(graph) ? (graph as StructuredData[]) : [node];
});
const structuredDataGraph = {
  '@context': 'https://schema.org',
  '@graph': [getWebsiteEntity(), getPublisherEntity(), ...pageStructuredDataNodes]
};
const structuredDataJson = JSON.stringify(structuredDataGraph).replace(/</g, '\\u003c');
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    {robots && <meta name="robots" content={robots} />}
    {robots && <meta name="googlebot" content={robots} />}
    {citationDoi && <meta name="citation_doi" content={citationDoi} />}
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang="en" href={new URL(alternateLinks.en, site.url).toString()} />
    <link rel="alternate" hreflang="pl" href={new URL(alternateLinks.pl, site.url).toString()} />
    <link rel="alternate" hreflang="x-default" href={new URL(alternateLinks.xDefault, site.url).toString()} />
    <link rel="alternate" type="application/rss+xml" title={`${site.name} RSS`} href={rssUrl} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    <meta property="og:site_name" content={site.name} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={imageUrl} />
    {resolvedImageWidth && <meta property="og:image:width" content={String(resolvedImageWidth)} />}
    {resolvedImageHeight && <meta property="og:image:height" content={String(resolvedImageHeight)} />}
    {resolvedImageType && <meta property="og:image:type" content={resolvedImageType} />}
    {resolvedImageAlt && <meta property="og:image:alt" content={resolvedImageAlt} />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    {resolvedImageAlt && <meta name="twitter:image:alt" content={resolvedImageAlt} />}
    <script is:inline type="application/ld+json" set:html={structuredDataJson} />
    <script is:inline src="/scripts/content-enhancements.js" defer></script>
  </head>
  <body>
    <a class="skip-link" href="#main">{skipLinkLabel}</a>
    <Header lang={lang} alternateLinks={alternateLinks} />
    <main id="main">
      <slot />
    </main>
    <Footer lang={lang} />
    <Analytics />
  </body>
</html>

---
import BaseLayout from '../../layouts/BaseLayout.astro';

const projectSections = [
  {
    eyebrow: 'Aktywne kierunki',
    title: 'Kierunki, które porządkują dalszą pracę',
    description:
      'To obszary rozwijane przez teksty, analizę źródeł, rozmowy i ostrożne prototypowanie. Publicznie pokazują sens pracy, nie prywatną mechanikę rozwiązań.',
    projects: [
      {
        title: 'AI i psychoedukacja',
        summary:
          'Kierunek o tym, jak AI może pomagać porządkować doświadczenie i przygotowywać rozmowę z człowiekiem bez udawania terapii.',
        status: 'Kierunek badawczo-praktyczny',
        focus:
          'język rozmowy z AI, granice odpowiedzialności, nadmierne zaufanie, przygotowanie do rozmowy',
        output:
          'teksty, modele pracy, warsztaty i ostrożne prototypy edukacyjne',
        stage: 'rozwijane przez artykuły, notatki i analizę ryzyk',
        boundary:
          'Nie jest terapią, diagnozą ani zamiennikiem kontaktu ze specjalistą.',
        link: undefined
      },
      {
        title: 'AI jako wsparcie rozumowania diagnostycznego',
        summary:
          'Kierunek o użyciu AI do porządkowania informacji, pytań i hipotez w pracy specjalistycznej.',
        status: 'Kierunek badawczo-praktyczny',
        focus:
          'oddzielanie faktów od hipotez, braki informacji, dokumentacja, pytania kontrolne',
        output:
          'schematy analizy, materiały edukacyjne i formaty wspierające decyzje człowieka',
        stage: 'publicznie opisane jako kierunek, nie jako gotowy system diagnostyczny',
        boundary:
          'AI nie podejmuje decyzji diagnostycznych i nie zastępuje odpowiedzialności specjalisty.',
        link: undefined
      },
      {
        title: 'HumanAI research',
        summary:
          'Kierunek analityczny o tym, jak ludzie ufają AI, antropomorfizują ją i włączają do pracy, komunikacji oraz decyzji.',
        status: 'Badania i analiza',
        focus:
          'zaufanie, antropomorfizacja, komunikacja, kreatywność, decyzje i praca',
        output:
          'ankiety, przeglądy źródeł, eseje analityczne i publiczne raporty',
        stage: 'rozwijane jako pytania badawcze i baza do publikacji',
        boundary:
          'Nie jest rankingiem narzędzi AI ani prostą oceną, czy AI jest dobra albo zła.',
        link: undefined
      }
    ]
  },
  {
    eyebrow: 'Format w rozwoju',
    title: 'Język dla artykułów, pojęć i praktyki',
    description:
      'Nie każdy projekt musi być produktem. Część pracy Prompted Psyche polega na budowaniu wspólnego języka, który ułatwia czytanie tekstów, pracę z AI i rozmowę o odpowiedzialności.',
    projects: [
      {
        title: 'Słownik Prompted Psyche',
        summary:
          'Publiczny format, który porządkuje pojęcia potrzebne do rozmowy o ludzkiej stronie AI.',
        status: 'Rozwijany format publiczny',
        focus:
          'AI literacy, Human-AI Interaction, zaufanie, cognitive load, antropomorfizacja, context window',
        output:
          'słownik, linkowane pojęcia i wspólny język dla tekstów oraz konsultingu',
        stage: 'opublikowany i rozwijany',
        boundary:
          'Nie udaje kompletnej encyklopedii AI ani formalnego standardu badawczego.',
        link: {
          href: '/pl/concepts/',
          label: 'Zobacz pojęcia'
        }
      }
    ]
  }
];

const archivedProject = {
  title: 'HumanAI Lab',
  summary:
    'Zakończony projekt badawczy o konwersacyjnej AI, zaufaniu, doświadczeniach emocjonalnych i codziennym podejmowaniu decyzji.',
  status: 'Archiwalny · Rekrutacja zakończona',
  boundary:
    'Rekrutacja została zakończona, a ankieta nie przyjmuje już odpowiedzi.',
  link: {
    href: '/pl/projects/humanai-lab/',
    label: 'Zobacz archiwum projektu'
  }
};
---

<BaseLayout
  lang="pl"
  title="Projekty"
  description="Publiczne kierunki Prompted Psyche: miejsca, w których teksty, pojęcia i praktyka zaczynają układać się w badania, narzędzia i formaty edukacyjne."
>
  <div class="lovable-page projects-page">
    <header class="lovable-page-hero projects-hero">
      <div class="lovable-container projects-hero__inner">
        <div>
          <p class="eyebrow">Projekty</p>
          <h1>Projekty</h1>
          <p class="lede">
            Projekty pokazują, jak myślenie rozwijane w Prompted Psyche może
            przechodzić w badania, narzędzia, formaty edukacyjne i praktykę pracy
            z AI.
          </p>
          <p class="hero-subnote">
            To robocze i publiczne kierunki: dojrzałe na tyle, żeby opisać ich
            sens, ale nie przedstawiane jako gotowe produkty. Łączą artykuły,
            pojęcia i praktyczne zastosowania.
          </p>
        </div>

        <aside class="projects-principle" aria-labelledby="projects-principle-title">
          <p class="small-label">Granica</p>
          <h2 id="projects-principle-title">Granice i dojrzałość</h2>
          <p>
            Publicznie pokazuję problem, kierunek i możliwy rezultat. Nie pokazuję
            prywatnej mechaniki, nazw roboczych ani obietnic produktu.
          </p>
        </aside>
      </div>
    </header>

    <section class="lovable-section" aria-label="Kierunki projektów">
      <div class="lovable-container">
        {
          projectSections.map((section, sectionIndex) => (
            <section
              class="projects-section"
              aria-labelledby={`projects-section-${sectionIndex}`}
            >
              <div class="lovable-section-header projects-section__header">
                <div>
                  <p class="section-kicker">{section.eyebrow}</p>
                  <h2 id={`projects-section-${sectionIndex}`}>{section.title}</h2>
                </div>
                <p>{section.description}</p>
              </div>

              <div class="projects-grid">
                {
                  section.projects.map((project) => (
                    <article class="project-card">
                      <p class="project-card__status">{project.status}</p>
                      <h3>{project.title}</h3>
                      <p class="project-card__summary">{project.summary}</p>

                      <dl class="project-card__details">
                        <div>
                          <dt>O czym jest</dt>
                          <dd>{project.focus}</dd>
                        </div>
                        <div>
                          <dt>Możliwy rezultat</dt>
                          <dd>{project.output}</dd>
                        </div>
                        <div>
                          <dt>Etap</dt>
                          <dd>{project.stage}</dd>
                        </div>
                      </dl>

                      <p class="project-card__boundary">{project.boundary}</p>

                      {project.link && (
                        <a class="text-link" href={project.link.href}>{project.link.label}</a>
                      )}
                    </article>
                  ))
                }
              </div>
            </section>
          ))
        }

        <section
          class="projects-section projects-section--archived"
          aria-labelledby="archived-projects-title"
        >
          <div class="lovable-section-header projects-section__header">
            <div>
              <p class="section-kicker">Archiwum projektów</p>
              <h2 id="archived-projects-title">Projekty archiwalne</h2>
            </div>
            <p>
              Zakończone inicjatywy pozostają tutaj jako publiczny zapis ich zakresu
              i statusu. Nie są to strony aktywnej rekrutacji.
            </p>
          </div>

          <div class="projects-grid">
            <article class="project-card project-card--archived">
              <p class="project-card__status">{archivedProject.status}</p>
              <h3>{archivedProject.title}</h3>
              <p class="project-card__summary">{archivedProject.summary}</p>
              <p class="project-card__boundary">{archivedProject.boundary}</p>
              <a class="text-link" href={archivedProject.link.href}>{archivedProject.link.label}</a>
            </article>
          </div>
        </section>
      </div>
    </section>

    <section class="lovable-section projects-cta-section tinted-section" aria-labelledby="projects-cta-title">
      <div class="lovable-container projects-cta">
        <div>
          <p class="eyebrow">Kontakt</p>
          <h2 id="projects-cta-title">Rozmowa i współpraca</h2>
        </div>
        <div>
          <p>
            Jeśli któryś kierunek pasuje do Twojej organizacji, najlepiej zacząć
            od rozmowy o kontekście, ryzykach i granicach. Dopiero potem można
            zdecydować, czy właściwą formą są warsztat, konsulting, publikacja,
            badanie albo prototyp.
          </p>
          <div class="consulting-actions">
            <a class="hero-button hero-button-primary" href="/pl/consulting/"><span aria-hidden="true"></span>Konsulting</a>
            <a class="hero-button hero-button-secondary" href="/pl/contact/">Kontakt</a>
          </div>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>

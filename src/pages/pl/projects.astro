---
import BaseLayout from '../../layouts/BaseLayout.astro';

const projects = [
  {
    title: 'AI i psychoedukacja',
    status: 'Status: kierunek pracy',
    description:
      'Obszar dotyczący tego, jak rozmowa z systemem AI może wspierać porządkowanie emocji, refleksję i lepsze nazywanie własnych reakcji.',
    concerns:
      'Interesuje mnie język rozmowy z AI, granice odpowiedzialności, ryzyko nadmiernego zaufania i to, kiedy technologia może pomagać w przygotowaniu do rozmowy z człowiekiem, a kiedy może ją zastępować w niebezpieczny sposób.',
    doesNotDo:
      'To nie jest terapia, diagnoza ani zamiennik kontaktu ze specjalistą.'
  },
  {
    title: 'AI jako wsparcie rozumowania diagnostycznego',
    status: 'Status: kierunek badawczo-praktyczny',
    description:
      'Obszar dotyczący tego, jak AI może pomagać porządkować informacje, pytania, hipotezy i dokumentację w pracy specjalistycznej.',
    concerns:
      'Nie chodzi o diagnozowanie przez AI, ale o wsparcie myślenia człowieka: oddzielanie faktów od hipotez, wskazywanie braków informacji, porządkowanie materiału i przygotowanie lepszych pytań.',
    doesNotDo:
      'AI nie podejmuje decyzji diagnostycznej i nie zastępuje odpowiedzialności specjalisty.'
  },
  {
    title: 'HumanAI research',
    status: 'Status: badania i analiza',
    description:
      'Badania i analizy dotyczące tego, jak ludzie korzystają z AI, kiedy jej ufają, kiedy ją antropomorfizują i jak technologia wpływa na pracę, twórczość, komunikację oraz podejmowanie decyzji.',
    concerns:
      'Ten obszar obejmuje ankiety, analizę zachowań, przegląd źródeł i pytania badawcze z pogranicza cyberpsychologii, Human-AI Interaction i psychologii poznawczej.',
    doesNotDo:
      'To nie jest ranking narzędzi AI ani publicystyczna ocena, czy AI jest dobra albo zła.'
  },
  {
    title: 'Słownik Prompted Psyche',
    status: 'Status: rozwijane',
    description:
      'Rozwijany słownik pojęć potrzebnych do rozmowy o ludzkiej stronie AI: od AI literacy i Human-AI Interaction po zaufanie, obciążenie poznawcze, antropomorfizację i okno kontekstu.',
    concerns:
      'To warstwa pojęciowa projektu. Pomaga budować wspólny język dla artykułów, notatek, konsultingu i przyszłych badań.',
    doesNotDo:
      'Słownik nie udaje kompletnej encyklopedii AI. Jest roboczym, rozwijanym językiem Prompted Psyche.',
    link: {
      href: '/pl/concepts/',
      label: 'Zobacz pojęcia'
    }
  }
];
---

<BaseLayout
  lang="pl"
  title="Projekty"
  description="Kierunki pracy badawczo-praktycznej Prompted Psyche: AI, psychoedukacja, rozumowanie diagnostyczne, badania HumanAI i słownik pojęć."
>
  <div class="lovable-page projects-page">
    <header class="lovable-page-hero projects-hero">
      <div class="lovable-container projects-hero__inner">
        <div>
          <p class="eyebrow">Projekty</p>
          <h1>Projekty</h1>
          <p class="lede">
            Kierunki pracy badawczo-praktycznej dotyczące ludzkiej strony AI:
            psychoedukacji, rozumowania diagnostycznego, zaufania, komunikacji,
            decyzji, twórczości i pracy ze specjalistyczną wiedzą.
          </p>
          <p class="hero-subnote">
            Nie wszystkie projekty są produktami komercyjnymi. Część z nich to
            badania, prototypy, modele pojęciowe i narzędzia do myślenia.
            Publicznie opisuję kierunek pracy, nie pełną mechanikę rozwiązań.
          </p>
        </div>

        <aside class="projects-principle" aria-labelledby="projects-principle-title">
          <p class="small-label">Zasada</p>
          <h2 id="projects-principle-title">Granice odpowiedzialności</h2>
          <p>
            Te projekty nie zastępują terapii, diagnozy ani decyzji specjalisty.
            Interesuje mnie to, jak AI może wspierać refleksję, porządkowanie
            informacji, odpowiedzialne użycie wiedzy i lepsze rozumienie kontekstu.
          </p>
        </aside>
      </div>
    </header>

    <section class="lovable-section" aria-labelledby="projects-list-title">
      <div class="lovable-container">
        <div class="lovable-section-header">
          <h2 id="projects-list-title">Kierunki pracy</h2>
          <p>
            Opisy są publiczne i celowo ogólne. Pokazują obszar myślenia, nie
            prywatne szczegóły zaplecza ani mechanikę prototypów.
          </p>
        </div>

        <div class="projects-grid">
          {
            projects.map((project) => (
              <article class="project-card">
                <p class="project-card__status">{project.status}</p>
                <h3>{project.title}</h3>
                <p>{project.description}</p>
                <div class="project-card__section">
                  <h4>Czego dotyczy</h4>
                  <p>{project.concerns}</p>
                </div>
                <div class="project-card__section">
                  <h4>Czego nie robi</h4>
                  <p>{project.doesNotDo}</p>
                </div>
                {project.link && (
                  <a class="text-link" href={project.link.href}>{project.link.label}</a>
                )}
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section class="lovable-section projects-cta-section tinted-section" aria-labelledby="projects-cta-title">
      <div class="lovable-container projects-cta">
        <div>
          <p class="eyebrow">Współpraca</p>
          <h2 id="projects-cta-title">Współpraca</h2>
        </div>
        <div>
          <p>
            Część tych kierunków może stać się podstawą warsztatów, konsultingu,
            badań, publikacji albo prototypów. Najważniejsze jest jednak to, żeby
            rozwijać je odpowiedzialnie: z jasnymi granicami, źródłami i świadomością
            konsekwencji.
          </p>
          <div class="consulting-actions">
            <a class="hero-button hero-button-primary" href="/pl/consulting/"><span aria-hidden="true"></span>Konsulting</a>
            <a class="hero-button hero-button-secondary" href="/pl/contact/">Kontakt</a>
          </div>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>

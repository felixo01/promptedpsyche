---
import IconCard from '../../components/IconCard.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { site } from '../../lib/site';

const contactEmail = site.email?.trim();
---

<BaseLayout
  lang="pl"
  title="Kontakt"
  description="Kontakt w sprawie konsultingu, warsztatów, wystąpień, komentarzy medialnych albo rozmów badawczych."
>
  <section class="page-shell contact-shell">
    <header class="page-header">
      <div>
        <p class="eyebrow">Kontakt</p>
        <h1>Porozmawiajmy o ludzkiej stronie AI</h1>
      </div>
      <p>
        Napisz krótko, czego dotyczy sprawa, jaki jest kontekst i jaki termin Cię
        interesuje.
      </p>
    </header>

    <div class="contact-grid">
      <IconCard icon="dialogue" title="Konsulting dla organizacji">
        Analiza używania AI, zasady, mapowanie procesów i przepływy człowiek-AI.
      </IconCard>
      <IconCard icon="work" title="Warsztaty i briefingi">
        Praktyczne spotkania dla zespołów, liderów i instytucji.
      </IconCard>
      <IconCard icon="spark" title="Wystąpienia i wykłady">
        Publiczne lub wewnętrzne wystąpienia o AI, cyberpsychologii i Human-AI Interaction.
      </IconCard>
      <IconCard icon="article" title="Komentarze medialne">
        Komentarze o ludzkiej, psychologicznej i kulturowej stronie AI.
      </IconCard>
      <IconCard icon="concept" title="Rozmowy badawcze">
        Rozmowy wokół pojęć, pytań i rozwijających się kierunków badań.
      </IconCard>
      <IconCard icon="trust" title="Współpraca przy treściach">
        Treści oparte na źródłach, recenzje i współpraca wokół AI oraz cyberpsychologii.
      </IconCard>
    </div>

    <section class="hero-panel contact-intro" aria-label="Dane kontaktowe">
      <p>
        Możesz napisać w sprawie konsultingu, warsztatów, wystąpień, komentarza
        medialnego, rozmowy badawczej albo współpracy przy treściach.
      </p>
      {
        contactEmail ? (
          <p>
            Email: <a href={`mailto:${contactEmail}`}>{contactEmail}</a>
          </p>
        ) : (
          <p>Dane kontaktowe zostaną dodane wkrótce.</p>
        )
      }
      <p>
        Prompted Psyche jest obecnie w trybie pre-launch, więc publiczne dane kontaktowe
        mogą się jeszcze zmienić.
      </p>
    </section>
  </section>
</BaseLayout>

---
import Icon from '../../components/Icon.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { site } from '../../lib/site';

const contactEmail = site.email?.trim();
---

<BaseLayout
  lang="pl"
  title="Kontakt"
  description="Kontakt w sprawie konsultingu, warsztatów, wystąpień, komentarzy medialnych albo rozmów badawczych."
>
  <section class="page-shell contact-shell">
    <header class="page-header">
      <div>
        <p class="eyebrow">Kontakt</p>
        <h1>Kontakt w sprawie konsultingu, warsztatów, wystąpień albo rozmów badawczych.</h1>
      </div>
      <p>
        Przygotuj krótką wiadomość z kontekstem, terminem i rodzajem wsparcia, którego
        szukasz.
      </p>
    </header>

    <div class="hero-panel contact-intro">
      <div class="prose">
        <p>
          Prompted Psyche jest obecnie w trybie pre-launch, więc publiczne dane
          kontaktowe mogą się jeszcze zmienić.
        </p>
        {
          contactEmail ? (
            <p>
              Email: <a href={`mailto:${contactEmail}`}>{contactEmail}</a>
            </p>
          ) : (
            <p>Dane kontaktowe zostaną dodane wkrótce.</p>
          )
        }
      </div>
    </div>

    <section aria-labelledby="contact-categories-title">
      <div class="compact-section-header">
        <p class="section-kicker">Tematy kontaktu</p>
        <h2 id="contact-categories-title">W jakich sprawach możesz napisać</h2>
      </div>
      <div class="contact-grid">
        <article class="icon-card">
          <Icon name="dialogue" />
          <h2>Konsulting dla organizacji</h2>
        </article>
        <article class="icon-card">
          <Icon name="work" />
          <h2>Warsztaty i briefingi</h2>
        </article>
        <article class="icon-card">
          <Icon name="spark" />
          <h2>Wystąpienia i wykłady</h2>
        </article>
        <article class="icon-card">
          <Icon name="article" />
          <h2>Komentarze medialne</h2>
        </article>
        <article class="icon-card">
          <Icon name="concept" />
          <h2>Rozmowy badawcze</h2>
        </article>
        <article class="icon-card">
          <Icon name="trust" />
          <h2>Współpraca przy treściach</h2>
        </article>
      </div>
    </section>
  </section>
</BaseLayout>

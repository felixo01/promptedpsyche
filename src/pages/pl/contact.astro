---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { site } from '../../lib/site';

const contactEmail = site.email?.trim();
---

<BaseLayout
  lang="pl"
  title="Kontakt"
  description="Kontakt w sprawie współpracy, konsultingu, warsztatów, komentarza eksperckiego albo projektów związanych z AI i komunikacją."
>
  <div class="lovable-page contact-page">
    <header class="lovable-page-hero contact-hero">
      <div class="lovable-container contact-hero__inner">
        <div class="lovable-heading-narrow">
          <p class="eyebrow">Kontakt</p>
          <h1>Napisz do mnie</h1>
          <p class="lede">
            Jeśli chcesz porozmawiać o współpracy, konsultingu, warsztacie,
            komentarzu eksperckim albo projekcie związanym z AI i komunikacją,
            napisz bezpośrednio.
          </p>
        </div>

        <div class="contact-email-card" data-qa="contact-email-card">
          <p class="eyebrow">E-mail</p>
          {
            contactEmail ? (
              <>
                <a
                  href={`mailto:${contactEmail}`}
                  class="contact-email-card__link"
                  data-qa="contact-email-link"
                >
                  {contactEmail}
                </a>
                <p>
                  Najprościej napisać kilka zdań o temacie, kontekście i
                  oczekiwanym terminie rozmowy.
                </p>
                <div class="contact-email-card__actions">
                  <a href={`mailto:${contactEmail}`} class="hero-button hero-button-primary">
                    <span aria-hidden="true"></span>
                    Napisz e-mail
                  </a>
                </div>
              </>
            ) : (
              <p class="contact-email-card__link">Dane kontaktowe zostaną dodane wkrótce.</p>
            )
          }
        </div>
      </div>
    </header>

    <section class="lovable-section contact-grid" aria-labelledby="contact-topics-title">
      <div class="lovable-container contact-grid__inner">
        <div class="compact-heading">
          <p class="eyebrow">Sprawy</p>
          <h2 id="contact-topics-title">W jakich sprawach</h2>
        </div>
        <ul class="contact-list">
          <li>konsulting i uporządkowanie używania AI w organizacji</li>
          <li>warsztaty i wystąpienia</li>
          <li>komentarz ekspercki lub medialny</li>
          <li>rozmowy badawcze i współpraca merytoryczna</li>
          <li>projekty z obszaru AI, komunikacji, marketingu i twórczości</li>
        </ul>
      </div>
    </section>

    <section class="lovable-section contact-grid contact-grid--compact" aria-labelledby="contact-context-title">
      <div class="lovable-container contact-grid__inner">
        <div class="compact-heading">
          <p class="eyebrow">Kontekst</p>
          <h2 id="contact-context-title">Co warto napisać</h2>
        </div>
        <ul class="contact-list">
          <li>czego dotyczy sprawa</li>
          <li>z jakiej organizacji lub kontekstu piszesz</li>
          <li>jaki jest termin</li>
          <li>czy chodzi o konsultację, warsztat, komentarz czy rozmowę</li>
        </ul>
      </div>
    </section>

    <section class="contact-closing" aria-label="Informacja o odpowiedzi">
      <div class="lovable-container">
        <p>
          Staram się odpowiadać na wiadomości możliwie uważnie. Napisz krótko,
          czego dotyczy sprawa, w jakim jesteś kontekście i czy jest jakiś termin.
        </p>
      </div>
    </section>
  </div>
</BaseLayout>

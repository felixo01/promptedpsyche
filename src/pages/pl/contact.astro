---
import Icon from '../../components/Icon.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { site } from '../../lib/site';

const contactEmail = site.email?.trim();
---

<BaseLayout
  lang="pl"
  title="Kontakt"
  description="Kontakt w sprawie konsultingu, warsztatów, wystąpień, komentarzy medialnych albo rozmów badawczych."
>
  <section class="page-shell two-column">
    <div>
      <p class="eyebrow">Kontakt</p>
      <h1>Kontakt w sprawie konsultingu, warsztatów, wystąpień albo rozmów badawczych.</h1>
    </div>

    <div>
      <div class="prose">
        <p>
          W sprawach konsultingu, warsztatów, wystąpień, komentarzy medialnych albo
          rozmów badawczych przygotuj krótką wiadomość z kontekstem, terminem i rodzajem
          wsparcia, którego szukasz.
        </p>
        <p>
          Prompted Psyche jest obecnie w trybie pre-launch, więc publiczne dane
          kontaktowe mogą się jeszcze zmienić.
        </p>
        {
          contactEmail ? (
            <p>
              Email: <a href={`mailto:${contactEmail}`}>{contactEmail}</a>
            </p>
          ) : (
            <p>Dane kontaktowe zostaną dodane wkrótce.</p>
          )
        }
      </div>

      <div class="panel">
        <h2>Możesz napisać szczególnie w sprawach</h2>
        <ul class="plain-list icon-list">
          <li><Icon name="dialogue" /><span>konsultingu dla organizacji</span></li>
          <li><Icon name="work" /><span>warsztatów i briefingów</span></li>
          <li><Icon name="spark" /><span>wystąpień i wykładów</span></li>
          <li><Icon name="article" /><span>komentarzy medialnych</span></li>
          <li><Icon name="concept" /><span>rozmów badawczych</span></li>
          <li><Icon name="trust" /><span>współpracy przy treściach lub projektach związanych z AI i cyberpsychologią</span></li>
        </ul>
      </div>
    </div>
  </section>
</BaseLayout>

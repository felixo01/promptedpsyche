---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { site } from '../../lib/site';

const contactEmail = site.email?.trim();
const emailSubject = encodeURIComponent('Prompted Psyche - zapytanie o pracę z AI');
const emailBody = encodeURIComponent(
  'Zespół lub organizacja:\nGdzie używamy AI:\nCo chcemy uporządkować:\nInteresuje nas: audyt / warsztat / rozmowa wstępna\nIstotny termin:'
);
const guidedMailto = contactEmail
  ? `mailto:${contactEmail}?subject=${emailSubject}&body=${emailBody}`
  : undefined;
---

<BaseLayout
  lang="pl"
  title="Kontakt"
  description="Kontakt z Feliksem Mamczurem w sprawie audytu wykorzystania AI, warsztatu albo rozmowy konsultacyjnej dla zespołu kreatywnego, marketingowego lub komunikacyjnego."
>
  <div class="lovable-page contact-page">
    <header class="lovable-page-hero contact-hero">
      <div class="lovable-container contact-hero__inner">
        <div class="lovable-heading-narrow">
          <p class="eyebrow">Kontakt</p>
          <h1>Napisz do mnie</h1>
          <p class="lede">
            Jeśli interesuje cię audyt wykorzystania AI, warsztat albo rozmowa
            wstępna, napisz krótko o zespole, miejscu używania AI i problemie,
            który chcesz uporządkować.
          </p>
        </div>

        <div class="contact-email-card" data-qa="contact-email-card">
          <p class="eyebrow">E-mail</p>
          {
            contactEmail ? (
              <>
                <a
                  href={`mailto:${contactEmail}`}
                  class="contact-email-card__link"
                  data-qa="contact-email-link"
                >
                  {contactEmail}
                </a>
                <p>
                  Wystarczy konkretny opis sytuacji. Nie musisz przed napisaniem
                  wybierać dokładnego formatu współpracy.
                </p>
                <div class="contact-email-card__actions">
                  <a
                    href={guidedMailto}
                    class="hero-button hero-button-primary"
                    data-qa="contact-guided-email"
                    data-cta="contact-email"
                  >
                    <span aria-hidden="true"></span>
                    Opisz swój zespół
                  </a>
                </div>
              </>
            ) : (
              <p class="contact-email-card__link">Dane kontaktowe zostaną dodane wkrótce.</p>
            )
          }
        </div>
      </div>
    </header>

    <section class="lovable-section contact-grid" aria-labelledby="contact-topics-title">
      <div class="lovable-container contact-grid__inner">
        <div class="compact-heading">
          <p class="eyebrow">Sprawy</p>
          <h2 id="contact-topics-title">W jakich sprawach</h2>
        </div>
        <ul class="contact-list">
          <li>audyt wykorzystania AI w zespole kreatywnym, marketingowym lub komunikacyjnym</li>
          <li>warsztaty i rozmowy konsultacyjne o odpowiedzialnym używaniu AI</li>
          <li>komentarz ekspercki lub medialny</li>
          <li>rozmowy badawcze i współpraca merytoryczna</li>
          <li>projekty z obszaru AI, komunikacji, marketingu i twórczości</li>
        </ul>
      </div>
    </section>

    <section class="lovable-section contact-grid contact-grid--compact" aria-labelledby="contact-context-title">
      <div class="lovable-container contact-grid__inner">
        <div class="compact-heading">
          <p class="eyebrow">Kontekst</p>
          <h2 id="contact-context-title">Co warto napisać</h2>
        </div>
        <ul class="contact-list" data-qa="contact-guidance-list">
          <li>jaki to zespół lub organizacja</li>
          <li>gdzie i w jaki sposób zespół już używa AI</li>
          <li>jaki problem, niepewność albo brak odpowiedzialności chcecie uporządkować</li>
          <li>czy interesuje was audyt, warsztat czy rozmowa wstępna</li>
          <li>czy jest istotny termin</li>
        </ul>
      </div>
    </section>

    <section class="contact-closing" aria-label="Informacja o odpowiedzi">
      <div class="lovable-container">
        <p>
          Na podstawie tego kontekstu ocenię, czy najbardziej użyteczny będzie
          audyt, warsztat czy pojedyncza rozmowa konsultacyjna.
        </p>
      </div>
    </section>
  </div>
</BaseLayout>

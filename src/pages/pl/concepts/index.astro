---
import { getCollection } from 'astro:content';
import EntryList from '../../../components/EntryList.astro';
import VisualPlate from '../../../components/VisualPlate.astro';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { onlyPublicEntriesByLang, sortByDateDesc } from '../../../lib/content';

const concepts = sortByDateDesc(onlyPublicEntriesByLang(await getCollection('concepts'), 'pl'));
---

<BaseLayout
  lang="pl"
  title="Pojęcia"
  description="Słownik pojęć Prompted Psyche o ludzkiej stronie AI."
>
  <section class="page-shell">
    <header class="page-header">
      <div>
        <p class="eyebrow">Pojęcia</p>
        <h1>Pojęcia</h1>
      </div>
      <p>
        Słownik Prompted Psyche porządkuje pojęcia potrzebne do rozmowy o ludzkiej
        stronie AI: zaufaniu, decyzjach, komunikacji, pracy i relacji człowiek-AI.
      </p>
    </header>

    <EntryList
      entries={concepts}
      basePath="/pl/concepts"
      label="Pojęcie"
      dateLocale="pl"
      emptyLabel="Pojęcia"
      emptyMessage="Słownik pojęć jest w przygotowaniu."
      emptyNote="Będzie porządkował pojęcia potrzebne do rozmowy o ludzkiej stronie AI."
      emptyIcon="concept"
    />

    <section class="empty-followup" aria-labelledby="concepts-followup-title">
      <VisualPlate variant="concept-map" lang="pl" class="empty-state-visual" />
      <h2 id="concepts-followup-title">Roboczy język pojęć</h2>
      <p>
        To małe publiczne MVP słownika. Będzie rozwijane ostrożnie wraz z kolejnymi
        tekstami, notatkami i pojęciami.
      </p>
    </section>
  </section>
</BaseLayout>

---
import { getCollection } from 'astro:content';
import ConceptList from '../../../components/ConceptList.astro';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { onlyPublicEntriesByLang } from '../../../lib/content';

const concepts = onlyPublicEntriesByLang(await getCollection('concepts'), 'pl').sort((a, b) =>
  a.data.title.localeCompare(b.data.title, 'pl')
);
---

<BaseLayout
  lang="pl"
  title="Pojęcia"
  description="Słownik pojęć Prompted Psyche o ludzkiej stronie AI."
>
  <section class="page-shell">
    <header class="page-header">
      <div>
        <p class="eyebrow">Pojęcia</p>
        <h1>Pojęcia</h1>
      </div>
      <p>
        Słownik Prompted Psyche porządkuje pojęcia potrzebne do rozmowy o ludzkiej
        stronie AI: zaufaniu, decyzjach, komunikacji, pracy i relacji człowiek-AI.
      </p>
    </header>

    <ConceptList
      entries={concepts}
      basePath="/pl/concepts"
      label="Pojęcie"
      linkLabel="Czytaj pojęcie"
      emptyLabel="Pojęcia"
      emptyMessage="Słownik pojęć jest w przygotowaniu."
    />

    <section class="concept-library-note" aria-labelledby="concepts-followup-title">
      <h2 id="concepts-followup-title">Roboczy język pojęć</h2>
      <p>
        To małe publiczne MVP słownika. Będzie rozwijane ostrożnie wraz z kolejnymi
        tekstami, notatkami i pojęciami.
      </p>
    </section>
  </section>
</BaseLayout>

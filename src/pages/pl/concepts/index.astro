---
import { getCollection } from 'astro:content';
import ConceptList from '../../../components/ConceptList.astro';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { sortConceptsForIndex } from '../../../lib/conceptOrder';
import { onlyPublicEntriesByLang } from '../../../lib/content';

const concepts = sortConceptsForIndex(onlyPublicEntriesByLang(await getCollection('concepts'), 'pl'));
const tags = Array.from(new Set(concepts.flatMap((concept) => concept.data.tags ?? []))).slice(0, 7);
---

<BaseLayout
  lang="pl"
  title="Pojęcia"
  description="Słownik pojęć Prompted Psyche o ludzkiej stronie AI."
>
  <div class="lovable-page concepts-page">
    <header class="lovable-page-hero">
      <div class="lovable-container">
        <div class="lovable-heading-narrow">
          <p class="eyebrow">Pojęcia</p>
          <h1>Pojęcia</h1>
          <p class="lede">
            Słownik Prompted Psyche porządkuje pojęcia potrzebne do rozmowy o ludzkiej
            stronie AI: zaufaniu, decyzjach, komunikacji, pracy i relacji człowiek-AI.
          </p>
        </div>
        <div class="concept-filter-row" aria-label="Tematy pojęć">
          <span>Filtr</span>
          {tags.map((tag) => <span>{tag}</span>)}
        </div>
      </div>
    </header>

    <section class="lovable-section">
      <div class="lovable-container">
        <div class="concept-index-heading">
          <h2>Roboczy język pojęć</h2>
          <span>{concepts.length} haseł</span>
        </div>
        <ConceptList
          entries={concepts}
          basePath="/pl/concepts"
          label="Pojęcie"
          linkLabel="Czytaj dalej"
          emptyLabel="Pojęcia"
          emptyMessage="Słownik pojęć jest w przygotowaniu."
        />
      </div>
    </section>
  </div>
</BaseLayout>

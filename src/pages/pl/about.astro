---
import { getCollection } from 'astro:content';
import AuthorPublicProfiles from '../../components/AuthorPublicProfiles.astro';
import AuthorPortrait from '../../components/AuthorPortrait.astro';
import SelectedPublications from '../../components/SelectedPublications.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getSelectedAuthorPublications } from '../../lib/authorPublications';
import { AUTHOR_ENTITY_ID, WEBSITE_ENTITY_ID, absoluteUrl, getAuthorEntity } from '../../lib/site';

const pageDescription =
  'Feliks Mamczur — autor i twórca Prompted Psyche. Pisze o AI, cyberpsychologii, zaufaniu, komunikacji i ludzkiej stronie inteligentnych systemów.';
const selectedPublications = getSelectedAuthorPublications(await getCollection('articles'), 'pl');
const profileStructuredData = {
  '@id': absoluteUrl('/pl/about/#profile-page'),
  '@type': 'ProfilePage',
  name: 'Feliks Mamczur — autor Prompted Psyche',
  description: pageDescription,
  url: absoluteUrl('/pl/about/'),
  inLanguage: 'pl',
  isPartOf: {
    '@id': WEBSITE_ENTITY_ID
  },
  mainEntity: getAuthorEntity('pl'),
  hasPart: selectedPublications.map((publication) => ({
    '@type': 'Article',
    headline: publication.title,
    url: absoluteUrl(publication.href),
    datePublished: publication.publishedAt.toISOString(),
    author: {
      '@id': AUTHOR_ENTITY_ID
    },
    ...(publication.identifierDoi
      ? {
          identifier: {
            '@type': 'PropertyValue',
            propertyID: 'DOI',
            value: publication.identifierDoi
          }
        }
      : {})
  }))
};
---

<BaseLayout
  lang="pl"
  title="Feliks Mamczur — autor Prompted Psyche"
  appendSiteName={false}
  description={pageDescription}
  structuredData={profileStructuredData}
>
  <article class="lovable-page about-page">
    <header class="about-hero">
      <div class="lovable-container about-hero__inner">
        <div class="about-hero__copy">
          <p class="eyebrow">Autor Prompted Psyche</p>
          <h1>Feliks Mamczur</h1>
          <p class="lede">
            Nazywam się Feliks Mamczur. Jestem autorem i twórcą Prompted Psyche —
            niezależnej platformy publikacyjnej o AI, cyberpsychologii i Human-AI
            Interaction.
          </p>
          <p class="hero-subnote">
            Piszę o tym, jak AI zmienia myślenie, zaufanie, komunikację, uczenie
            się, twórczość i pracę, a także prowadzę konsultacje dotyczące
            korzystania z tych systemów. Korzystam przy tym z doświadczenia
            filmowego oraz pracy z obrazem, komunikacją i narracją.
          </p>
          <p class="hero-subnote">
            W centrum Prompted Psyche jest człowiek i jego relacja z inteligentnymi
            systemami. Odwołuję się do cyberpsychologii i Human-AI Interaction,
            pytając o zaufanie, emocje, uwagę, sprawczość i skłonność do
            przypisywania maszynom intencji.
          </p>
        </div>

        <aside class="about-hero__aside" aria-labelledby="about-summary-title">
          <AuthorPortrait lang="pl" variant="about" />
          <div class="about-summary-card">
            <h2 id="about-summary-title">W skrócie</h2>
            <ul>
              <li>AI i ludzkie doświadczenie</li>
              <li>Zaufanie, emocje i komunikacja</li>
              <li>Cyberpsychologia i Human-AI Interaction</li>
              <li>Twórczość, decyzje i praca</li>
              <li>Artykuły, notatki i pojęcia</li>
            </ul>
          </div>
        </aside>
      </div>
    </header>

    <div class="lovable-container about-section-list">
      <section class="about-section">
        <div class="about-section__meta">
          <span>01</span>
          <p>Ludzka strona</p>
        </div>
        <div class="about-section__body">
          <h2>Dlaczego piszę o AI</h2>
          <div class="editorial-copy">
            <p>
              Rozmowa o AI często skupia się na tym, co potrafią narzędzia. Ja
              przyglądam się temu, jak te systemy zmieniają sposób, w jaki szukamy
              informacji, podejmujemy decyzje, piszemy, tworzymy i komunikujemy się
              z innymi — oraz którym odpowiedziom ufamy.
            </p>
            <p>
              Prompted Psyche nie jest blogiem o narzędziach ani katalogiem
              promptów. Publikuję tu artykuły i notatki oraz objaśniam pojęcia
              związane z psychologicznymi, poznawczymi, komunikacyjnymi i
              kulturowymi skutkami korzystania ze sztucznej inteligencji.
              Przyglądam się również sytuacjom, w których system zaczyna sprawiać
              wrażenie rozmówcy, towarzysza lub wiarygodnego doradcy.
            </p>
          </div>
        </div>
      </section>

      <section class="about-section">
        <div class="about-section__meta">
          <span>02</span>
          <p>Stanowisko</p>
        </div>
        <div class="about-section__body">
          <h2>Punkt wyjścia</h2>
          <div class="editorial-copy">
            <p>
              Pytanie o to, czy AI jest dobre, czy złe, niewiele wyjaśnia.
              Ważniejsze jest dla mnie to, jak technologia zmienia myślenie,
              podejmowanie decyzji, budowanie zaufania, komunikację i pracę.
            </p>
            <p>
              Dlatego w Prompted Psyche analizuję te zmiany uważnie, bez tonu
              promocyjnego i katastroficznych uproszczeń. Skupiam się na człowieku,
              kontekście i odpowiedzialności.
            </p>
          </div>
        </div>
      </section>

      <section class="about-section">
        <div class="about-section__meta">
          <span>03</span>
          <p>Perspektywa</p>
        </div>
        <div class="about-section__body">
          <h2>Moja perspektywa</h2>
          <div class="editorial-copy">
            <p>
              Łączę doświadczenie w komunikacji i pracy twórczej z namysłem nad
              tym, jak ludzie wchodzą w relacje z technologią. Cyberpsychologia i
              Human-AI Interaction pomagają mi opisywać to, co już widać w
              codziennym korzystaniu z AI: płynne odpowiedzi wzbudzają zaufanie,
              systemy konwersacyjne zmieniają ton rozmowy i sposób przypisywania
              odpowiedzialności, a narzędzia stopniowo stają się częścią procesu
              podejmowania decyzji.
            </p>
            <p>
              Cyberpsychologia pozostaje podstawą Prompted Psyche. Z czasem chcę
              rozszerzyć to spojrzenie o zagadnienia Human-Machine Interaction:
              interfejsy, inteligentne systemy i technologie, które przetwarzają
              obraz, reagują, mówią lub pomagają podejmować decyzje.
            </p>
            <p>
              W praktycznej pracy z AI zajmuję się tekstem, źródłami i kontekstem,
              a także wersjami, metadanymi, wyszukiwaniem i weryfikacją. Dzięki temu
              w Prompted Psyche skupiam się na tym, jak ludzie rzeczywiście
              korzystają z tych systemów, a nie wyłącznie na abstrakcyjnych
              dyskusjach czy sposobach formułowania promptów.
            </p>
          </div>
        </div>
      </section>

      <section class="about-section">
        <div class="about-section__meta">
          <span>04</span>
          <p>Komunikacja</p>
        </div>
        <div class="about-section__body">
          <h2>Doświadczenie w komunikacji</h2>
          <div class="editorial-copy">
            <p>
              Przez wiele lat pracowałem w marketingu i dużych agencjach
              reklamowych, realizując projekty dla rozpoznawalnych marek. Ta praca
              nauczyła mnie patrzeć nie tylko na samą treść, lecz także na to, jak
              obraz, emocje i kontekst kierują uwagą oraz wpływają na decyzje.
            </p>
            <p>
              Pracuję jako reżyser, montażysta i producent. Jestem członkiem{' '}
              <a
                class="inline-text-link"
                href="https://www.europeanfilmawards.eu/talent/feliks-mamczur/"
                rel="me noopener"
                >Europejskiej Akademii Filmowej</a
              >. Praca filmowa nauczyła mnie zwracać uwagę na kadr, rytm,
              następstwo ujęć, emocje i sposób, w jaki odbiorca buduje znaczenie.
              Tę perspektywę wykorzystuję dziś w analizie systemów generatywnych i
              pracy twórczej z AI. Na felixmamczur.com można znaleźć{' '}
              <a
                class="inline-text-link"
                href="https://felixmamczur.com/"
                rel="me noopener"
                title="Feliks Mamczur — projekty wizualne i filmowe"
                >projekty wizualne i filmowe</a
              >.
            </p>
            <p>
              W części wcześniejszych napisów filmowych i baz branżowych moje
              nazwisko występuje również jako Feliks Mirosław Mamczur, Mirosław
              Mamczur lub Felix Mamczur. Wszystkie te zapisy dotyczą mnie.
            </p>
            <p>
              Dziś łączę te doświadczenia, analizując wpływ AI na poznanie,
              zaufanie, obecność społeczną, komunikację i podejmowanie decyzji.
              Odwołuję się przy tym do Human-AI Interaction i źródeł naukowych, a
              także do doświadczenia w komunikacji, narracji i pracy z zespołami
              kreatywnymi. Wyraźnie oddzielam analizę i konsulting od diagnozy,
              terapii i porad klinicznych.
            </p>
          </div>
        </div>
      </section>

      <section class="about-section">
        <div class="about-section__meta">
          <span>05</span>
          <p>Publikacje</p>
        </div>
        <div class="about-section__body">
          <h2>Co tu znajdziesz</h2>
          <div class="editorial-copy">
            <p>
              Na stronie publikuję dłuższe artykuły, krótsze notatki i słownik
              pojęć. Każdy z tych formatów pomaga porządkować sposób mówienia o AI,
              psychologii, zaufaniu, emocjach, pracy i kulturze.
            </p>
            <p>
              <a class="inline-text-link" href="/pl/topics/">Przewodniki tematyczne</a>{' '}
              łączą powiązane materiały i ułatwiają dalszą lekturę. Wybrane eseje
              mają angielskie wersje oznaczone DOI, co ułatwia stabilne cytowanie,
              a mój{' '}
              <a
                class="inline-text-link"
                href="https://orcid.org/0009-0001-0715-0517"
                rel="me noopener"
                >profil ORCID</a
              > zawiera publiczny wykaz publikacji. DOI wskazuje konkretną wersję
              tekstu, ale nie oznacza, że tekst przeszedł recenzję naukową.
            </p>
          </div>
          <div class="about-link-grid" aria-label="Publikacje">
            <a href="/pl/articles/">
              <span>Artykuły</span>
              <strong>Dłuższe eseje i analizy</strong>
            </a>
            <a href="/pl/notes/">
              <span>Notatki</span>
              <strong>Krótsze obserwacje i tropy</strong>
            </a>
            <a href="/pl/concepts/">
              <span>Pojęcia</span>
              <strong>Słownik języka Prompted Psyche</strong>
            </a>
          </div>
          <SelectedPublications lang="pl" publications={selectedPublications} />
          <AuthorPublicProfiles lang="pl" />
        </div>
      </section>

      <section class="about-section">
        <div class="about-section__meta">
          <span>06</span>
          <p>Konsulting</p>
        </div>
        <div class="about-section__body">
          <h2>Konsulting</h2>
          <div class="editorial-copy">
            <p>
              Te pytania mają też praktyczny wymiar w organizacjach. Pomagam
              zespołom uporządkować sposób korzystania z AI: ustalić, gdzie
              rzeczywiście wspiera pracę, które wyniki trzeba weryfikować, jak
              pracować ze źródłami i kontekstem oraz kiedy potrzebne są jasne
              zasady i odpowiedzialność.
            </p>
            <p>
              <a class="text-link" href="/pl/consulting/">Więcej o konsultingu</a>
            </p>
          </div>
        </div>
      </section>
    </div>
  </article>
</BaseLayout>

---
import CtaPanel from '../../components/CtaPanel.astro';
import Icon from '../../components/Icon.astro';
import IconCard from '../../components/IconCard.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  lang="pl"
  title="Ludzka strona sztucznej inteligencji"
  description="Prompted Psyche to projekt o tym, jak sztuczna inteligencja wpływa na myślenie, emocje, zaufanie, komunikację, twórczość i pracę."
>
  <div class="home-shell home-layout">
    <section class="home-hero" aria-labelledby="home-title">
      <div class="home-hero-copy">
        <p class="eyebrow">AI - Cyberpsychologia - Human-AI Interaction</p>
        <h1 id="home-title">Ludzka strona sztucznej inteligencji.</h1>
        <p class="lede">
          Piszę i konsultuję o tym, jak AI zmienia myślenie, emocje, zaufanie,
          komunikację, twórczość i pracę.
        </p>
        <div class="hero-actions" aria-label="Główne działania">
          <a href="/pl/consulting/">Konsulting dla organizacji</a>
          <a href="/pl/articles/">Czytaj teksty</a>
        </div>
      </div>

      <aside class="identity-panel dossier-panel" aria-label="Czym jest Prompted Psyche?">
        <span class="dossier-stamp" aria-hidden="true">PP</span>
        <p class="small-label">Czym jest Prompted Psyche?</p>
        <p>
          To mój projekt o ludzkiej stronie sztucznej inteligencji - o tym, jak AI wpływa
          na myślenie, emocje, zaufanie, komunikację, twórczość i pracę.
        </p>
        <ul class="identity-list" aria-label="Tematy projektu">
          <li>AI literacy</li>
          <li>zaufanie</li>
          <li>decyzje</li>
          <li>praca</li>
          <li>relacje człowiek-AI</li>
          <li>twórczość</li>
          <li>kultura</li>
        </ul>
        <p class="status-note">Strona jest w trybie pre-launch, a publiczne teksty są przygotowywane.</p>
      </aside>
    </section>

    <section class="home-section" aria-labelledby="entry-title">
      <SectionHeader kicker="Ścieżki wejścia" title="Trzy sposoby korzystania z projektu" id="entry-title">
        Prompted Psyche jest tworzone dla organizacji, czytelników i rozmów o ludzkiej stronie AI.
      </SectionHeader>
      <div class="path-grid">
        <IconCard icon="work" title="Dla organizacji" href="/pl/consulting/" linkLabel="Zobacz consulting" number="01">
          Analiza używania AI, mapowanie procesów, zasady pracy człowiek-AI, warsztaty i wystąpienia.
        </IconCard>
        <IconCard icon="article" title="Do czytania" href="/pl/articles/" linkLabel="Czytaj teksty" number="02">
          Artykuły i notatki o AI, psychologii, zaufaniu, emocjach, pracy i kulturze.
        </IconCard>
        <IconCard icon="dialogue" title="Do rozmowy" href="/pl/contact/" linkLabel="Napisz" number="03">
          Wystąpienia, komentarze medialne, rozmowy badawcze i współpraca przy treściach.
        </IconCard>
      </div>
    </section>

    <section class="home-section" aria-labelledby="areas-title">
      <SectionHeader kicker="Human-AI Observatory" title="Obszary tematyczne" id="areas-title">
        Mapa tematów dla artykułów, notatek, pojęć i konsultingu o ludzkiej stronie AI.
      </SectionHeader>
      <div class="topic-grid" aria-label="Obszary tematyczne">
        <IconCard icon="trust" title="Zaufanie">Kiedy odpowiedź AI zaczyna wydawać się wiarygodna.</IconCard>
        <IconCard icon="decision" title="Decyzje">Jak AI wpływa na osąd, odpowiedzialność i sprawdzanie informacji.</IconCard>
        <IconCard icon="work" title="Praca">Jak zespoły używają AI w codziennych procesach.</IconCard>
        <IconCard icon="emotion" title="Emocje">Jak rozmowa z systemem wpływa na komfort, lęk i poczucie zrozumienia.</IconCard>
        <IconCard icon="spark" title="Twórczość">Co dzieje się z autorstwem, stylem i kontrolą.</IconCard>
        <IconCard icon="culture" title="Kultura">Jak AI zmienia język, obrazy, narracje i komunikację publiczną.</IconCard>
      </div>
    </section>

    <section class="home-section consulting-teaser" aria-labelledby="consulting-title">
      <div>
        <p class="section-kicker">Studio konsultingowe</p>
        <h2 id="consulting-title">Konsulting dla organizacji</h2>
        <p class="section-lead">
          Pomagam firmom sprawdzić, gdzie AI może realnie wspierać pracę, a gdzie wymaga
          zasad, weryfikacji i ostrożności.
        </p>
      </div>
      <div class="teaser-panel">
        <ul class="check-list">
          <li><Icon name="check" />analiza używania AI w organizacji</li>
          <li><Icon name="check" />mapowanie procesów pracy</li>
          <li><Icon name="check" />modelowanie przepływów człowiek-AI</li>
          <li><Icon name="check" />zasady korzystania z AI</li>
          <li><Icon name="check" />warsztaty i wystąpienia</li>
        </ul>
        <a href="/pl/consulting/">Zobacz consulting</a>
      </div>
    </section>

    <section class="home-section" aria-labelledby="writing-title">
      <SectionHeader kicker="Research notebook" title="System publikacji jest w przygotowaniu" id="writing-title">
        Artykuły, notatki i pojęcia powstają jako spokojny, oparty na źródłach system redakcyjny.
      </SectionHeader>
      <div class="system-grid">
        <IconCard icon="article" title="Artykuły" href="/pl/articles/" linkLabel="Otwórz artykuły" number="01">
          Dłuższe teksty o AI, cyberpsychologii i Human-AI Interaction.
        </IconCard>
        <IconCard icon="note" title="Notatki" href="/pl/notes/" linkLabel="Otwórz notatki" number="02">
          Krótsze obserwacje, definicje i kierunki dalszego researchu.
        </IconCard>
        <IconCard icon="concept" title="Pojęcia" href="/pl/concepts/" linkLabel="Otwórz pojęcia" number="03">
          Słownik pojęć o ludzkiej stronie sztucznej inteligencji.
        </IconCard>
      </div>
    </section>

    <section class="home-section about-teaser" aria-labelledby="about-title">
      <div>
        <p class="section-kicker">Profil ekspercki</p>
        <h2 id="about-title">Feliks Mamczur</h2>
      </div>
      <p>
        Piszę i konsultuję na styku AI, cyberpsychologii i Human-AI Interaction. Z filmu
        biorę uważność na narrację, obraz, emocje i rytm komunikacji. W Prompted Psyche
        wykorzystuję tę perspektywę do opisywania tego, jak AI zmienia pracę, twórczość,
        decyzje i relacje między ludźmi.
      </p>
    </section>

    <CtaPanel kicker="Kontakt" title="Porozmawiajmy o AI w Twojej organizacji." href="/pl/contact/" linkLabel="Kontakt">
      Konsulting, warsztaty, wystąpienia i rozmowy o ludzkiej stronie adopcji AI.
    </CtaPanel>
  </div>
</BaseLayout>

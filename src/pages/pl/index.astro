---
import { getCollection } from 'astro:content';
import VisualPlate from '../../components/VisualPlate.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getArticlePath } from '../../lib/articleRoutes';
import { onlyPublicEntriesByLang } from '../../lib/content';
import { getNotePath } from '../../lib/noteRoutes';
import { getAuthorEntity } from '../../lib/site';

const publicArticles = onlyPublicEntriesByLang(await getCollection('articles'), 'pl');
const publicNotes = onlyPublicEntriesByLang(await getCollection('notes'), 'pl');
const conflictNote = publicNotes.find((entry) => entry.data.translationKey === 'ai-sycophancy-conflict');
const thinkingArticle = publicArticles.find((entry) => entry.data.translationKey === 'ai-thinking-practice');
const trustArticle = publicArticles.find((entry) => entry.data.translationKey === 'ai-path-to-knowledge');
const startHereEntries = [
  ...(conflictNote
    ? [{ entry: conflictNote, label: 'Notatka badawcza', cta: 'Czytaj notatkę', href: getNotePath(conflictNote, 'pl') }]
    : []),
  ...(thinkingArticle
    ? [{ entry: thinkingArticle, label: 'Artykuł', cta: 'Czytaj artykuł', href: getArticlePath(thinkingArticle, 'pl') }]
    : []),
  ...(trustArticle
    ? [{ entry: trustArticle, label: 'Artykuł', cta: 'Czytaj artykuł', href: getArticlePath(trustArticle, 'pl') }]
    : [])
];
---

<BaseLayout
  lang="pl"
  title="Ludzka strona AI"
  image="/images/social/prompted-psyche-home-social-1200x630.png"
  description="Prompted Psyche to oparta na źródłach platforma publikacyjna Feliksa Mamczura o ludzkiej stronie AI, z audytem wykorzystania AI dla zespołów kreatywnych, marketingowych i komunikacyjnych."
  structuredData={getAuthorEntity('pl')}
>
  <div>
    <section class="home-hero home-hero-publication" aria-labelledby="home-title">
      <div class="home-hero-copy" data-qa="hero-copy">
        <p class="eyebrow">AI - Psychologia poznawcza - Human-AI Interaction</p>
        <h1 id="home-title" data-qa="hero-title">Ludzka strona AI.</h1>
        <p class="lede">
          AI zmienia sposób, w jaki myślimy, podejmujemy decyzje, komunikujemy się i pracujemy.
        </p>
        <p class="hero-subnote">
          Prompted Psyche to niezależna platforma publikacyjna Feliksa Mamczura o
          ludzkiej stronie AI. Perspektywa oparta na źródłach wspiera również audyt
          wykorzystania AI dla zespołów kreatywnych, marketingowych i komunikacyjnych.
        </p>
        <div class="hero-actions" aria-label="Główne działania">
          <a href="#start-here" data-qa="home-reading-cta">Zacznij od najważniejszych tekstów</a>
          <a href="/pl/consulting/" data-qa="home-audit-cta" data-cta="home-audit">Zobacz audyt AI dla zespołów</a>
        </div>
      </div>

      <aside class="hero-sidecar" data-qa="hero-sidecar" aria-label="Czym jest Prompted Psyche?">
        <VisualPlate variant="field-map" lang="pl" class="hero-visual hero-visual-large" />
        <div class="hero-note">
          <p class="small-label">Publikacje oparte na źródłach</p>
          <p>
            Artykuły, notatki i pojęcia pokazują, jak AI zmienia poznanie, zaufanie,
            komunikację, twórczość i pracę. Audyt przenosi tę perspektywę do
            wybranych procesów zespołu.
          </p>
          <ul class="identity-list" aria-label="Formaty Prompted Psyche">
            <li>Artykuły</li>
            <li>Notatki</li>
            <li>Pojęcia</li>
          </ul>
        </div>
      </aside>
    </section>

    <section id="start-here" class="home-section home-writing home-start" aria-labelledby="writing-title" data-qa="home-start-here">
      <div class="editorial-section-header">
        <div>
          <p class="section-kicker">Zacznij tutaj</p>
          <h2 id="writing-title">Trzy ważne punkty wyjścia</h2>
        </div>
        <p>
          Zacznij od potakiwania modelu w konflikcie, sposobów myślenia, których
          przestajemy ćwiczyć, oraz zaufania do gotowych odpowiedzi.
        </p>
      </div>

      <div class="home-start-grid" aria-label="Polecane publikacje" data-qa="start-here-list">
        {startHereEntries.map((item) => (
          <article class="writing-card start-here-card" data-qa="start-here-entry">
            <p class="entry-index">{item.label}</p>
            <h3>{item.entry.data.title}</h3>
            <p>{item.entry.data.description}</p>
            <a class="text-link" href={item.href}>{item.cta}</a>
          </article>
        ))}
      </div>
      <div class="home-start-footer">
        <a class="text-link" href="/pl/articles/">Wszystkie artykuły</a>
        <a class="text-link" href="/pl/notes/">Wszystkie notatki</a>
      </div>
    </section>

    <section class="home-section author-strip home-bio" aria-labelledby="about-title">
      <div>
        <p class="section-kicker">Autor</p>
        <h2 id="about-title">Feliks Mamczur</h2>
      </div>
      <div class="author-note">
        <p>
          W Prompted Psyche pisze o ludzkiej stronie AI: o tym, jak modele językowe
          wpływają na uwagę, decyzje, zaufanie, emocje i pracę z informacją.
        </p>
        <p>
          Korzysta z doświadczenia w marketingu, komunikacji, filmie i
          postprodukcji: pracy z narracją, obrazem, rytmem, emocjami odbiorcy i
          sposobem, w jaki ludzie nadają znaczenie treściom.
        </p>
        <a class="text-link" href="/pl/about/">Więcej o mnie</a>
      </div>
    </section>

    <section class="home-section home-compact-feature home-practice" aria-labelledby="practice-title" data-qa="home-practice">
      <div>
        <p class="section-kicker">Praktyka</p>
        <h2 id="practice-title">Jak rozmawiać ze sztuczną inteligencją</h2>
      </div>
      <div class="compact-feature-copy">
        <p>
          Ćwiczenia dotyczące kontekstu, źródeł, niepewności, interpretacji i
          odpowiedzialnych decyzji.
        </p>
        <a class="text-link" href="/pl/practice/">Przejdź do praktyki</a>
      </div>
    </section>

    <section class="home-section home-compact-feature home-concepts" aria-labelledby="concepts-title">
      <div>
        <p class="section-kicker">Pojęcia</p>
        <h2 id="concepts-title">Ważne pojęcia</h2>
      </div>
      <div class="compact-feature-copy">
        <p>
          Słownik pomaga porządkować język Prompted Psyche: AI literacy, poznanie,
          zaufanie, odpowiedź modelu, antropomorfizację i komunikację
          zapośredniczoną przez AI.
        </p>
        <a class="text-link" href="/pl/concepts/">Zobacz pojęcia</a>
      </div>
    </section>

    <section
      class="home-section home-compact-feature home-consulting"
      data-qa="consulting-teaser"
      aria-labelledby="consulting-title"
    >
      <div>
        <p class="section-kicker">Konsulting</p>
        <h2 id="consulting-title">Audyt wykorzystania AI w zespole</h2>
      </div>
      <div class="compact-feature-copy">
        <p>
          Dla zespołów kreatywnych, marketingowych i komunikacyjnych, które już
          używają generatywnej AI i potrzebują jasnych zasad weryfikacji, zaufania
          oraz odpowiedzialności.
        </p>
        <a class="text-link" href="/pl/consulting/">Zobacz audyt</a>
      </div>
    </section>
  </div>
</BaseLayout>

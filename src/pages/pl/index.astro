---
import CtaPanel from '../../components/CtaPanel.astro';
import Icon from '../../components/Icon.astro';
import IconCard from '../../components/IconCard.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  lang="pl"
  title="Ludzka strona sztucznej inteligencji"
  description="Prompted Psyche to projekt o tym, jak sztuczna inteligencja wpływa na myślenie, emocje, zaufanie, komunikację, twórczość i pracę."
>
  <div class="home-shell home-layout">
    <section class="home-hero" aria-labelledby="home-title">
      <div class="home-hero-copy">
        <p class="eyebrow">AI - Cyberpsychologia - Human-AI Interaction</p>
        <h1 id="home-title">Ludzka strona sztucznej inteligencji.</h1>
        <p class="lede">
          Rozwijam Prompted Psyche jako projekt o tym, jak AI zmienia myślenie, emocje,
          zaufanie, komunikację, twórczość i pracę.
        </p>
        <div class="hero-actions" aria-label="Główne działania">
          <a href="/pl/about/">O projekcie</a>
          <a href="/pl/consulting/">Konsulting</a>
        </div>
      </div>

      <aside class="identity-panel dossier-panel" aria-label="Czym jest Prompted Psyche?">
        <span class="dossier-stamp" aria-hidden="true">PP</span>
        <p class="small-label">Czym jest Prompted Psyche?</p>
        <p>
          Prompted Psyche to mój projekt o ludzkiej stronie sztucznej inteligencji -
          rozwijany przez teksty, pojęcia i notatki badawcze. Interesuje mnie nie tylko
          to, co AI potrafi zrobić, ale to, co dzieje się z człowiekiem, gdy zaczyna jej
          ufać.
        </p>
        <ul class="identity-list" aria-label="Tematy projektu">
          <li>kompetencje pracy z AI</li>
          <li>zaufanie</li>
          <li>decyzje</li>
          <li>praca</li>
          <li>relacje człowiek-AI</li>
          <li>twórczość</li>
          <li>kultura</li>
        </ul>
        <p class="status-note">Strona jest w trybie pre-launch, a publiczne teksty są przygotowywane.</p>
      </aside>
    </section>

    <section class="home-section" aria-labelledby="entry-title">
      <SectionHeader kicker="Ścieżki wejścia" title="Dla kogo jest Prompted Psyche" id="entry-title">
        To miejsce dla organizacji, czytelników i osób, które chcą rozmawiać o ludzkiej stronie AI bez hype'u i uproszczeń.
      </SectionHeader>
      <div class="path-grid">
        <IconCard icon="article" title="Teksty i pojęcia" href="#writing-title" linkLabel="Zobacz publikacje">
          Artykuły, notatki i słownik pojęć o AI, psychologii, zaufaniu, emocjach, pracy i kulturze.
        </IconCard>
        <IconCard icon="work" title="Dla organizacji" href="/pl/consulting/" linkLabel="Zobacz consulting">
          Analiza używania AI, mapowanie procesów, zasady pracy człowiek-AI, warsztaty i wystąpienia.
        </IconCard>
        <IconCard icon="dialogue" title="Wystąpienia i współpraca" href="/pl/contact/" linkLabel="Napisz">
          Komentarze medialne, wykłady, rozmowy badawcze i współpraca przy treściach o ludzkiej stronie AI.
        </IconCard>
      </div>
    </section>

    <section class="home-section" aria-labelledby="areas-title">
      <SectionHeader kicker="Mapa projektu" title="Obszary" id="areas-title">
        Mapa tematów dla artykułów, notatek, pojęć i konsultingu o ludzkiej stronie AI.
      </SectionHeader>
      <div class="topic-map" aria-label="Obszary tematyczne">
        <IconCard icon="trust" title="Zaufanie">Kiedy odpowiedź AI zaczyna wydawać się wiarygodna.</IconCard>
        <IconCard icon="emotion" title="Emocje">Jak systemy konwersacyjne wpływają na komfort, lęk i poczucie bycia zrozumianym.</IconCard>
        <IconCard icon="dialogue" title="Przywiązanie">Dlaczego system może sprawiać wrażenie bliskiego, bezpiecznego albo zawsze dostępnego.</IconCard>
        <IconCard icon="work" title="Praca">Jak AI zmienia sposób pisania, sprawdzania, decydowania i brania odpowiedzialności.</IconCard>
        <IconCard icon="decision" title="Decyzje">Kiedy AI wspiera osąd, a kiedy zaczyna go zastępować.</IconCard>
        <IconCard icon="spark" title="Twórczość">Co dzieje się z autorstwem, stylem i kontrolą, gdy AI wchodzi do procesu twórczego.</IconCard>
        <IconCard icon="culture" title="Kultura">Co AI pokazuje o języku, mediach, tożsamości i władzy.</IconCard>
      </div>
    </section>

    <section class="home-section consulting-teaser" aria-labelledby="consulting-title">
      <div>
        <p class="section-kicker">Praktyczne zastosowanie projektu</p>
        <h2 id="consulting-title">Zastosowanie w organizacjach</h2>
        <p class="section-lead">
          Jeśli chcesz przełożyć tę perspektywę na pracę zespołu, pomagam analizować
          używanie AI, mapować procesy, projektować zasady i rozmawiać o zaufaniu,
          odpowiedzialności oraz weryfikacji.
        </p>
      </div>
      <div class="teaser-panel">
        <ul class="teaser-chips" aria-label="Obszary konsultingu">
          <li><Icon name="check" />analiza używania AI</li>
          <li><Icon name="check" />mapowanie procesów</li>
          <li><Icon name="check" />model pracy człowiek-AI</li>
          <li><Icon name="check" />zasady dla zespołu</li>
        </ul>
        <a href="/pl/consulting/">Zobacz consulting</a>
      </div>
    </section>

    <section class="home-section" aria-labelledby="writing-title">
      <SectionHeader kicker="Teksty i notatki" title="Publikacje są w przygotowaniu" id="writing-title">
        Artykuły, notatki i pojęcia otworzą spokojne, oparte na źródłach archiwum redakcyjne.
      </SectionHeader>
      <div class="system-grid">
        <IconCard icon="article" title="Artykuły" href="/pl/articles/" linkLabel="Otwórz artykuły">
          Dłuższe teksty o AI, cyberpsychologii i Human-AI Interaction.
        </IconCard>
        <IconCard icon="note" title="Notatki" href="/pl/notes/" linkLabel="Otwórz notatki">
          Krótsze obserwacje, definicje i kierunki dalszych badań.
        </IconCard>
        <IconCard icon="concept" title="Pojęcia" href="/pl/concepts/" linkLabel="Otwórz pojęcia">
          Słownik pojęć o ludzkiej stronie sztucznej inteligencji.
        </IconCard>
      </div>
    </section>

    <section class="home-section about-teaser" aria-labelledby="about-title">
      <div>
        <p class="section-kicker">Perspektywa autora</p>
        <h2 id="about-title">Feliks Mamczur</h2>
      </div>
      <p>
        Piszę i konsultuję na styku AI, cyberpsychologii i Human-AI Interaction. Z filmu
        biorę uważność na narrację, obraz, emocje i rytm komunikacji. W Prompted Psyche
        wykorzystuję tę perspektywę do opisywania tego, jak AI zmienia pracę, twórczość,
        decyzje i relacje między ludźmi.
      </p>
    </section>

    <CtaPanel kicker="Kontakt" title="Porozmawiajmy o AI w Twojej organizacji." href="/pl/contact/" linkLabel="Kontakt">
      Konsulting, warsztaty, wystąpienia i rozmowy o ludzkiej stronie adopcji AI.
    </CtaPanel>
  </div>
</BaseLayout>

---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import EntryList from '../../../components/EntryList.astro';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import EntryLayout from '../../../layouts/EntryLayout.astro';
import { onlyEntriesByLang, sortByDateDesc } from '../../../lib/content';
import { showPractice } from '../../../lib/features';
import { getPracticeAlternates } from '../../../lib/practiceRoutes';

type PracticeEntry = CollectionEntry<'practice'>;

const practiceIndexAlternates = {
  en: '/practice/',
  pl: '/pl/practice/',
  xDefault: '/practice/'
};

export async function getStaticPaths() {
  if (!showPractice) {
    return [];
  }

  const allPractice = await getCollection('practice');
  const entries = sortByDateDesc(onlyEntriesByLang(allPractice, 'pl'));

  return [
    {
      params: { slug: undefined },
      props: { pageKind: 'index', entries }
    },
    ...entries.map((entry) => ({
      params: { slug: entry.id },
      props: {
        pageKind: 'entry',
        entry,
        alternateLinks: getPracticeAlternates(entry, allPractice)
      }
    }))
  ];
}

const { pageKind, entries = [], entry, alternateLinks } = Astro.props as {
  pageKind: 'index' | 'entry';
  entries?: PracticeEntry[];
  entry?: PracticeEntry;
  alternateLinks?: typeof practiceIndexAlternates;
};

const rendered = entry ? await render(entry) : undefined;
const Content = rendered?.Content;
---

{
  pageKind === 'entry' && entry ? (
    <EntryLayout
      entry={entry}
      label="Praktyka"
      lang="pl"
      alternateLinks={alternateLinks}
    >
      {Content && <Content />}
    </EntryLayout>
  ) : (
    <BaseLayout
      title="Praktyka"
      description="Krótkie ćwiczenia pomagające myśleć z AI ostrożniej: źródła, niepewność, założenia, kontrargumenty i decyzje."
      lang="pl"
      alternateLinks={practiceIndexAlternates}
    >
      <section class="page-shell practice-index">
        <header class="page-header practice-index__header">
          <div>
            <p class="eyebrow">Praktyka</p>
            <h1>Praktyka</h1>
          </div>
          <p>
            Praktyka to krótkie, praktyczne scenariusze pracy z AI - nie baza
            promptów, ale przewodniki po rozsądnym użyciu modeli w konkretnych
            sytuacjach.
          </p>
        </header>

        <section class="practice-discovery" aria-labelledby="practice-discovery-title">
          <div class="editorial-section-header">
            <div>
              <p class="section-kicker">Praktyka</p>
              <h2 id="practice-discovery-title">Wybierz sytuację</h2>
            </div>
            <p>
              Krótkie, praktyczne scenariusze pracy z AI - sprawdzanie odpowiedzi,
              źródeł, niepewności, tekstów i decyzji bez oddawania modelowi
              odpowiedzialności.
            </p>
          </div>
          <EntryList
            entries={entries}
            basePath="/pl/practice"
            label="Praktyka"
            dateLocale="pl"
            ctaLabel="Otwórz scenariusz"
          />
        </section>
      </section>
    </BaseLayout>
  )
}

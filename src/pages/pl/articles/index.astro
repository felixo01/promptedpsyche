---
import { getCollection } from 'astro:content';
import EntryList from '../../../components/EntryList.astro';
import VisualPlate from '../../../components/VisualPlate.astro';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { onlyPublicEntriesByLang, sortByDateDesc } from '../../../lib/content';

const articles = sortByDateDesc(onlyPublicEntriesByLang(await getCollection('articles'), 'pl'));
---

<BaseLayout
  lang="pl"
  title="Artykuły"
  description="Dłuższe teksty Prompted Psyche o AI, cyberpsychologii i Human-AI Interaction."
>
  <section class="page-shell">
    <header class="page-header">
      <div>
        <p class="eyebrow">Artykuły</p>
        <h1>Artykuły</h1>
      </div>
      <p>
        Dłuższe teksty o ludzkiej stronie AI: kompetencjach, zaufaniu, pracy,
        odpowiedzialności i społecznych skutkach narzędzi generatywnych.
      </p>
    </header>

    <EntryList
      entries={articles}
      basePath="/pl/articles"
      label="Artykuł"
      dateLocale="pl"
      emptyIcon="article"
      emptyLabel="Artykuły"
      emptyMessage="Artykuły są w przygotowaniu."
      emptyNote="Pierwsze teksty będą dotyczyć kompetencji pracy z AI, zaufania, decyzji, komunikacji i odpowiedzialności przy narzędziach generatywnych."
    />

    {articles.length === 0 && (
      <section class="empty-followup" aria-labelledby="first-directions-title">
        <VisualPlate variant="note-stack" lang="pl" class="empty-state-visual" />
        <h2 id="first-directions-title">Pierwsze tematy</h2>
        <ul>
          <li>kompetencje pracy z AI</li>
          <li>zaufanie do odpowiedzi modeli</li>
          <li>decyzje z udziałem AI</li>
          <li>odpowiedzialność w pracy człowiek-AI</li>
        </ul>
      </section>
    )}
  </section>
</BaseLayout>

---
import { getCollection } from 'astro:content';
import EntryList from '../../../components/EntryList.astro';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { onlyPublicEntriesByLang, sortByDateDesc } from '../../../lib/content';

const articles = sortByDateDesc(onlyPublicEntriesByLang(await getCollection('articles'), 'pl'));
---

<BaseLayout
  lang="pl"
  title="Artykuły"
  description="Artykuły Prompted Psyche o AI, cyberpsychologii i Human-AI Interaction."
>
  <section class="page-shell">
    <header class="page-header">
      <div>
        <p class="eyebrow">Artykuły</p>
        <h1>Artykuły</h1>
      </div>
      <p>
        Dłuższe teksty o AI, cyberpsychologii i relacjach człowiek-AI.
      </p>
    </header>

    <EntryList
      entries={articles}
      basePath="/pl/articles"
      label="Artykuł"
      dateLocale="pl"
      emptyLabel="Artykuły"
      emptyMessage="Artykuły są w przygotowaniu."
      emptyNote="Pierwsze teksty będą dotyczyć kompetencji pracy z AI, zaufania, decyzji, odpowiedzi modeli w pracy zespołów i psychologicznych konsekwencji używania narzędzi generatywnych."
    />
  </section>
</BaseLayout>

---
import { getCollection, render } from 'astro:content';
import EntryLayout from '../../../layouts/EntryLayout.astro';
import { getArticleAlternates } from '../../../lib/articleRoutes';
import { withArticlePublicationMetadata } from '../../../lib/articlePublicationMetadata';
import { onlyPublicEntries, onlyPublicEntriesByLang } from '../../../lib/content';
import { getExplorationLinks } from '../../../lib/topics';

export async function getStaticPaths() {
  const publicArticles = onlyPublicEntries(await getCollection('articles'));
  const articles = onlyPublicEntriesByLang(publicArticles, 'pl');

  return articles.map((entry) => ({
    params: { slug: entry.id },
    props: { entry, alternateLinks: getArticleAlternates(entry, publicArticles) }
  }));
}

const { entry, alternateLinks } = Astro.props;
const publicationEntry = withArticlePublicationMetadata(entry, 'pl');
const explorationLinks = getExplorationLinks('article', entry.data.translationKey, 'pl');
const { Content } = await render(entry);
---

<EntryLayout
  entry={publicationEntry}
  label="Artykuł"
  lang="pl"
  alternateLinks={alternateLinks}
  explorationLinks={explorationLinks}
>
  <Content />
</EntryLayout>

---
import CtaPanel from '../../components/CtaPanel.astro';
import IconCard from '../../components/IconCard.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  lang="pl"
  title="Konsulting"
  description="Konsulting, warsztaty i analizy używania AI w organizacjach."
>
  <section class="page-shell service-shell">
    <header class="page-header service-hero">
      <div>
        <p class="eyebrow">Konsulting</p>
        <h1>Konsulting, warsztaty i analizy używania AI w organizacjach.</h1>
      </div>
      <p>
        Pomagam firmom sprawdzić, gdzie AI może realnie wspierać codzienną pracę - w
        komunikacji, decyzjach, przepływie informacji, procesach twórczych i organizacji
        pracy zespołów.
      </p>
    </header>

    <section aria-labelledby="services-title">
      <SectionHeader kicker="Usługi" title="Z czym mogę pomóc" id="services-title">
        Praktyczne, oparte na źródłach wsparcie dla zespołów, które potrzebują zasad,
        nawyków weryfikacji i czytelniejszych przepływów człowiek-AI.
      </SectionHeader>
      <div class="service-card-grid">
        <IconCard icon="decision" title="Analiza używania AI">
          Sprawdzenie, jak zespół już korzysta z AI i gdzie wsparcie jest realne.
        </IconCard>
        <IconCard icon="concept" title="Mapowanie procesów">
          Opis zadań, przepływu informacji, przekazań i miejsc, w których AI wchodzi do pracy.
        </IconCard>
        <IconCard icon="work" title="Model pracy człowiek-AI">
          Projektowanie praktycznych przepływów: co wspiera AI, a za co odpowiada człowiek.
        </IconCard>
        <IconCard icon="trust" title="Zasady dla zespołu">
          Wspólne reguły zaufania, weryfikacji, świadomości danych i odpowiedzialności.
        </IconCard>
        <IconCard icon="article" title="AI literacy">
          Wspólny język pracy z narzędziami generatywnymi bez hype'u i listy trików.
        </IconCard>
        <IconCard icon="dialogue" title="Warsztaty i wystąpienia">
          Briefingi, warsztaty i wykłady o AI, cyberpsychologii i Human-AI Interaction.
        </IconCard>
      </div>
    </section>

    <section aria-labelledby="situations-title">
      <SectionHeader kicker="Typowe sytuacje" title="Kiedy ta praca jest potrzebna" id="situations-title">
        Często problemem nie jest brak promptów, tylko niejasny osąd, odpowiedzialność
        i niespójne używanie AI w zespole.
      </SectionHeader>
      <ul class="scenario-list scenario-grid">
        <li>Zespół używa AI, ale każdy robi to inaczej.</li>
        <li>Firma chce wprowadzić AI, ale nie ma zasad.</li>
        <li>Ludzie wklejają dane do narzędzi bez refleksji.</li>
        <li>AI przyspiesza pisanie, ale nie wiadomo, kto odpowiada za wynik.</li>
        <li>Liderzy nie wiedzą, które zadania można wspierać AI.</li>
        <li>Organizacja chce przygotować prostą politykę używania AI.</li>
      </ul>
    </section>

    <section aria-labelledby="process-title">
      <SectionHeader kicker="Proces" title="Jak może wyglądać współpraca" id="process-title">
        Forma może być kompaktowa, ale powinna odnosić się do realnych zadań, ryzyk
        i punktów decyzyjnych.
      </SectionHeader>
      <ol class="process-list process-steps">
        <li>
          <strong>Rozpoznanie</strong>
          <p>gdzie AI pojawia się dziś i co trzeba uporządkować</p>
        </li>
        <li>
          <strong>Mapa procesów</strong>
          <p>które etapy można wspierać AI i gdzie są przekazania</p>
        </li>
        <li>
          <strong>Ryzyka i odpowiedzialność</strong>
          <p>co wymaga weryfikacji, świadomości danych, kontroli albo drugiej osoby</p>
        </li>
        <li>
          <strong>Model pracy człowiek-AI</strong>
          <p>jak może wyglądać sensowny przepływ w codziennej pracy</p>
        </li>
        <li>
          <strong>Zasady i następne kroki</strong>
          <p>co przetestować, opisać albo doprecyzować</p>
        </li>
      </ol>
    </section>

    <section class="panel consulting-note" aria-labelledby="not-title">
      <h2 id="not-title">Czym to nie jest</h2>
      <ul class="plain-list">
        <li>nie porada prawna</li>
        <li>nie porada kliniczna</li>
        <li>nie gwarancja ROI</li>
        <li>nie pełna realizacja IT od początku do końca</li>
        <li>nie lista promptowych trików</li>
      </ul>
    </section>

    <CtaPanel kicker="Kontakt" title="Porozmawiajmy o używaniu AI w Twojej organizacji." href="/pl/contact/" linkLabel="Kontakt">
      Napisz krótko o zespole, obecnym używaniu AI i rodzaju wsparcia, którego szukasz.
    </CtaPanel>
  </section>
</BaseLayout>

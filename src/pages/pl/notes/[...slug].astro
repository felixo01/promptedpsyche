---
import { getCollection, render } from 'astro:content';
import EntryLayout from '../../../layouts/EntryLayout.astro';
import { onlyPublicEntriesByLang } from '../../../lib/content';

export async function getStaticPaths() {
  const notes = onlyPublicEntriesByLang(await getCollection('notes'), 'pl');

  return notes.map((entry) => ({
    params: { slug: entry.id },
    props: { entry }
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<EntryLayout entry={entry} label="Notatka" lang="pl">
  <Content />
</EntryLayout>

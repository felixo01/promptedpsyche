---
import Icon from '../../../components/Icon.astro';
import VisualPlate from '../../../components/VisualPlate.astro';
import BaseLayout from '../../../layouts/BaseLayout.astro';
---

<BaseLayout
  lang="pl"
  title="Notatki"
  description="Notatki Prompted Psyche o AI, cyberpsychologii i Human-AI Interaction."
>
  <section class="page-shell">
    <header class="page-header">
      <div>
        <p class="eyebrow">Notatki</p>
        <h1>Notatki</h1>
      </div>
      <p>
        Krótsze obserwacje o AI, zachowaniu człowieka, zaufaniu, pracy, twórczości
        i kulturze cyfrowej.
      </p>
    </header>

    <div class="empty-state publication-empty">
      <span class="dossier-stamp" aria-hidden="true">PP</span>
      <Icon name="note" />
      <p class="small-label">Notatki</p>
      <p>Notatki są w przygotowaniu.</p>
      <p class="empty-state-note">
        Będą zbierać krótsze obserwacje o AI, zachowaniu człowieka, zaufaniu, pracy,
        twórczości i kulturze cyfrowej.
      </p>
    </div>

    <section class="empty-followup" aria-labelledby="notes-followup-title">
      <VisualPlate variant="note-stack" lang="pl" class="empty-state-visual" />
      <h2 id="notes-followup-title">Co będą zbierać notatki</h2>
      <p>
        Notatki będą zbierać krótsze obserwacje, definicje i tropy do dalszych tekstów.
      </p>
    </section>
  </section>
</BaseLayout>

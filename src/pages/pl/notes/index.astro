---
import { getCollection } from 'astro:content';
import EntryList from '../../../components/EntryList.astro';
import VisualPlate from '../../../components/VisualPlate.astro';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { onlyPublicEntriesByLang, sortByDateDesc } from '../../../lib/content';

const notes = sortByDateDesc(onlyPublicEntriesByLang(await getCollection('notes'), 'pl'));
---

<BaseLayout
  lang="pl"
  title="Notatki"
  description="Notatki badawcze, explainery i krótsze analizy porządkujące konkretne problemy związane z AI."
>
  <section class="page-shell">
    <header class="page-header">
      <div>
        <p class="eyebrow">Notatki</p>
        <h1>Notatki</h1>
      </div>
      <p>
        Notatki badawcze, explainery i krótsze analizy porządkujące konkretne
        problemy związane z AI.
      </p>
    </header>

    <EntryList
      entries={notes}
      basePath="/pl/notes"
      label="Notatka"
      dateLocale="pl"
      emptyLabel="Notatki"
      emptyMessage="Notatki są w przygotowaniu."
      emptyNote="Będą zbierać krótsze obserwacje, definicje i tropy do przyszłych artykułów."
      emptyIcon="note"
      ctaLabel="Czytaj notatkę"
    />

    {notes.length === 0 && (
      <section class="empty-followup" aria-labelledby="notes-followup-title">
        <VisualPlate variant="note-stack" lang="pl" class="empty-state-visual" />
        <h2 id="notes-followup-title">Po co są notatki</h2>
        <p>
          Notatki pozwolą zatrzymać mniejsze pytania, zanim staną się dłuższymi tekstami.
        </p>
      </section>
    )}
  </section>
</BaseLayout>

---
import VisualPlate from '../components/VisualPlate.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="About"
  description="About Prompted Psyche, my research-informed project on AI, cyberpsychology and Human-AI Interaction."
>
  <section class="page-shell about-editorial">
    <header class="page-header about-hero">
      <div>
        <p class="eyebrow">About</p>
        <h1>About Prompted Psyche</h1>
      </div>
      <p>
        Prompted Psyche is my project on the human side of artificial intelligence:
        essays, concepts, talks and consulting on how AI changes thought, trust,
        communication, creativity and work.
      </p>
    </header>

    <section class="about-intro" aria-label="Project introduction">
      <p>
        I am interested not only in what AI can do, but in what happens to people
        when they start to use it: trust model outputs, delegate tasks, create with
        AI and communicate through AI-shaped systems.
      </p>
    </section>

    <section class="about-section about-perspective-section" aria-labelledby="perspective-title">
      <div class="about-section-heading">
        <p class="section-kicker">Perspective</p>
        <h2 id="perspective-title">How I look at AI</h2>
        <p>
          I connect the psychology of AI use with questions about communication,
          work, responsibility, creativity and culture.
        </p>
      </div>

      <div class="about-perspective-list" aria-label="Perspective areas">
        <article class="about-perspective-item">
          <span aria-hidden="true">01</span>
          <div>
            <h3>Trust and decisions</h3>
            <p>
              When does an AI output begin to feel credible? How does it shape
              judgment, verification and responsibility?
            </p>
          </div>
        </article>
        <article class="about-perspective-item">
          <span aria-hidden="true">02</span>
          <div>
            <h3>Communication and emotion</h3>
            <p>
              How do AI systems change language, validation, perceived understanding
              and the rhythm of interaction?
            </p>
          </div>
        </article>
        <article class="about-perspective-item about-perspective-item-wide">
          <span aria-hidden="true">03</span>
          <div>
            <h3>Work and creativity</h3>
            <p>
              How does AI enter writing, research, decision-making, image-making and
              creative authorship?
            </p>
          </div>
        </article>
      </div>
    </section>

    <section class="about-section about-film-section" aria-labelledby="film-perspective-title">
      <div class="about-section-heading">
        <p class="section-kicker">Interpretive lens</p>
        <h2 id="film-perspective-title">Film, attention and AI</h2>
      </div>
      <div class="about-film-grid">
        <div class="about-section-copy">
          <p>
            My background in film, editing and post-production shapes how I think
            about AI: through narrative, attention, image, emotion and the way
            technologies reorganize creative and communicative work.
          </p>
          <p>
            It gives me a way to read AI not only as a tool, but as something that
            changes attention, context, authorship and the conditions of communication.
          </p>
        </div>
        <VisualPlate variant="attention-frame" class="about-attention-visual" />
      </div>
    </section>

    <section class="about-section about-research-section" aria-labelledby="research-background-title">
      <div class="about-section-heading">
        <p class="section-kicker">Research background</p>
        <h2 id="research-background-title">Research background</h2>
      </div>
      <div class="about-research-copy">
        <p>
          I am developing registered research projects in progress on psychological
          and creative aspects of human-AI relations, including AI chatbot use,
          authorship, authenticity and creative control in AI-supported practice.
        </p>
        <p>
          This work is ongoing and forms part of the background of Prompted Psyche.
          Public essays and concepts are source-informed, but they should not be
          presented as finished peer-reviewed research.
        </p>
        <p class="about-orcid">
          <span>ORCID:</span>
          <a href="https://orcid.org/0009-0001-0715-0517" rel="me noopener">
            https://orcid.org/0009-0001-0715-0517
          </a>
          <a class="about-orcid-link" href="https://orcid.org/0009-0001-0715-0517" rel="me noopener">
            View ORCID profile
          </a>
        </p>
      </div>
    </section>

    <section class="about-next-steps" aria-labelledby="about-next-title">
      <div>
        <p class="section-kicker">Next step</p>
        <h2 id="about-next-title">Where to go next</h2>
        <p>
          Start with the concept library to see the language of the project, or go
          to consulting to see how this perspective can be applied in organizations.
        </p>
      </div>
      <div class="about-next-links" aria-label="Next links">
        <a href="/concepts/">Explore concepts</a>
        <a href="/consulting/">See consulting</a>
      </div>
    </section>
  </section>
</BaseLayout>

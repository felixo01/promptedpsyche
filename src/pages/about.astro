---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="About"
  description="About Prompted Psyche and Feliks Mamczur."
>
  <section class="page-shell two-column">
    <div>
      <p class="eyebrow">About</p>
      <h1>Prompted Psyche studies AI as a psychological environment.</h1>
    </div>

    <div class="prose">
      <p>
        Prompted Psyche is an expert publication and consulting hub by Feliks Mamczur
        focused on AI, cyberpsychology and Human-AI Interaction.
      </p>
      <p>
        The project starts from a simple observation: AI systems are not only tools that
        answer prompts. They also change how people ask, decide, trust, create, communicate
        and understand themselves.
      </p>
      <p>
        The editorial focus is research-driven and practical: what AI does to attention,
        emotion, confidence, expertise, social norms and organizational life.
      </p>
    </div>
  </section>
</BaseLayout>

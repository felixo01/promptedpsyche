---
import Icon from '../components/Icon.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="About"
  description="About Feliks Mamczur and Prompted Psyche, a research-informed project on AI, cyberpsychology and Human-AI Interaction."
>
  <section class="page-shell about-shell">
    <header class="page-header">
      <div>
        <p class="eyebrow">About</p>
        <h1>AI, cyberpsychology and Human-AI Interaction.</h1>
      </div>
      <p>
        Prompted Psyche is the public research and consulting home of Feliks Mamczur:
        writing, talks and advisory work on the human side of artificial intelligence.
      </p>
    </header>

    <div class="about-layout">
      <div class="prose">
        <p>
          Feliks Mamczur writes and consults on AI, cyberpsychology and Human-AI
          Interaction.
        </p>
        <p>
          Prompted Psyche is a research-informed publication and consulting platform on the
          human side of artificial intelligence: how AI shapes thought, emotion, trust,
          communication, creativity and work.
        </p>
        <p>
          The project is interested in AI as a lived, social and psychological technology,
          not only as software. It asks what changes when people begin to think with AI,
          trust AI, delegate work to AI, create with AI and communicate through AI-shaped
          systems.
        </p>
      </div>

      <aside class="soft-panel about-aside" aria-label="About Prompted Psyche">
        <p class="small-label">Project lens</p>
        <p>
          A calm, source-based view of how AI changes judgment, language, creative work
          and relationships between people and systems.
        </p>
      </aside>
    </div>

    <div class="icon-grid about-perspective" aria-label="Perspective">
      <article class="icon-card">
        <Icon name="concept" />
        <h2>AI, cyberpsychology and HAI</h2>
        <p>Core concepts for understanding how people relate to AI systems.</p>
      </article>
      <article class="icon-card">
        <Icon name="dialogue" />
        <h2>Psychology and communication</h2>
        <p>Attention to trust, emotion, language, validation and decision-making.</p>
      </article>
      <article class="icon-card">
        <Icon name="spark" />
        <h2>Creative practice</h2>
        <p>Film, editing and post-production shape attention to narrative, image, emotion and workflow.</p>
      </article>
      <article class="icon-card">
        <Icon name="article" />
        <h2>Research profile</h2>
        <p>
          Ongoing research work informs the background of Prompted Psyche.
          <a href="https://orcid.org/0009-0001-0715-0517" rel="me noopener">ORCID</a>
        </p>
      </article>
    </div>

    <section class="panel about-note" aria-labelledby="film-perspective-title">
      <h2 id="film-perspective-title">Film, attention and AI</h2>
      <p>
        My background in film, editing and post-production shapes how I think about AI:
        through narrative, attention, image, emotion and the way technologies reorganize
        creative and communicative work.
      </p>
    </section>
  </section>
</BaseLayout>

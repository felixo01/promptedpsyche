---
import AuthorPortrait from '../components/AuthorPortrait.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { absoluteUrl, getAuthorEntity, site } from '../lib/site';

const pageDescription =
  'About Feliks Mamczur, author of Prompted Psyche, a publication about AI, trust, communication and the human side of intelligent systems.';
const profileStructuredData = {
  '@context': 'https://schema.org',
  '@type': 'ProfilePage',
  name: 'About Feliks Mamczur',
  description: pageDescription,
  url: absoluteUrl('/about/'),
  inLanguage: 'en',
  isPartOf: {
    '@type': 'WebSite',
    name: site.name,
    url: site.url
  },
  mainEntity: getAuthorEntity('en')
};
---

<BaseLayout
  title="About the author"
  description={pageDescription}
  structuredData={profileStructuredData}
>
  <article class="lovable-page about-page">
    <header class="about-hero">
      <div class="lovable-container about-hero__inner">
        <div class="about-hero__copy">
          <p class="eyebrow">Author</p>
          <h1>About the author</h1>
          <p class="lede">
            Prompted Psyche is where I write about how artificial intelligence
            changes the way people think, trust, communicate, work, create and relate
            to one another.
          </p>
          <p class="hero-subnote">
            I created Prompted Psyche as a place to write about the human side of
            AI, cyberpsychology, Human-AI Interaction and intelligent systems.
          </p>
          <p class="hero-subnote">
            I am interested not only in what models can do, but in what happens on
            the human side: why we trust answers, when we attribute intention to
            machines, and how technology shapes decisions, emotion, attention and
            agency. The project is rooted in cyberpsychology, Human-AI Interaction
            and the broader relationship between people and intelligent systems.
          </p>
        </div>

        <aside class="about-hero__aside" aria-labelledby="about-summary-title">
          <AuthorPortrait lang="en" variant="about" />
          <div class="about-summary-card">
            <h2 id="about-summary-title">In brief</h2>
            <ul>
              <li>AI and human experience</li>
              <li>Trust, emotion and communication</li>
              <li>Cyberpsychology and Human-AI Interaction</li>
              <li>Creativity, decisions and work</li>
              <li>Essays, notes and concepts</li>
            </ul>
          </div>
        </aside>
      </div>
    </header>

    <div class="lovable-container about-section-list">
      <section class="about-section">
        <div class="about-section__meta">
          <span>01</span>
          <p>Human side</p>
        </div>
        <div class="about-section__body">
          <h2>Why I write about AI</h2>
          <div class="editorial-copy">
            <p>
              AI is usually discussed as a tool, a market force or a technical
              infrastructure. I am interested in another layer: what happens to people
              when AI enters thinking, writing, decision-making, emotion and
              communication.
            </p>
            <p>
              Prompted Psyche is where I organize that perspective through essays,
              notes and concepts. The project asks how people trust AI, how they
              delegate judgment, how conversational systems shape emotion and social
              presence, and how generative tools reorganize creative and professional
              work.
            </p>
          </div>
        </div>
      </section>

      <section class="about-section">
        <div class="about-section__meta">
          <span>02</span>
          <p>Stance</p>
        </div>
        <div class="about-section__body">
          <h2>Starting point</h2>
          <div class="editorial-copy">
            <p>
              I am less interested in asking whether AI is simply good or bad. I am
              interested in what the technology changes in how people think, make
              decisions, build trust, communicate and work.
            </p>
            <p>
              Prompted Psyche is a place for careful analysis: without promotional
              language, without catastrophic shortcuts, and with attention to people,
              context and responsibility.
            </p>
          </div>
        </div>
      </section>

      <section class="about-section">
        <div class="about-section__meta">
          <span>03</span>
          <p>Perspective</p>
        </div>
        <div class="about-section__body">
          <h2>My perspective</h2>
          <div class="editorial-copy">
            <p>
              I come to these questions through communication, creative practice and
              the study of how people relate to technology. Cyberpsychology and
              Human-AI Interaction give me a language for patterns that already
              appear in everyday work with AI: fluent answers that feel trustworthy,
              conversational systems that change tone and responsibility, and tools
              that quietly become part of decisions.
            </p>
            <p>
              My practical work with AI is also close to writing, sources, context,
              versions, metadata, search and review. That keeps Prompted Psyche
              grounded in what people actually do with these systems, not only in
              abstract debate or prompt technique.
            </p>
          </div>
        </div>
      </section>

      <section class="about-section">
        <div class="about-section__meta">
          <span>04</span>
          <p>Communication</p>
        </div>
        <div class="about-section__body">
          <h2>Experience in communication</h2>
          <div class="editorial-copy">
            <p>
              For many years, I worked in marketing, advertising agencies and
              communication projects for major brands. That experience taught me to
              look at communication not only as content, but as a system of
              attention, emotion, decisions, image and context.
            </p>
            <p>
              My earlier work with image, narrative, emotion and attention remains
              part of how I look at technology, but it is not the main label of this
              site. You can find my{' '}
              <a
                class="inline-text-link"
                href="https://felixmamczur.com/"
                title="Feliks Mamczur - earlier visual and film projects"
                >earlier visual and film projects</a
              >
              {' '}at felixmamczur.com.
            </p>
          </div>
        </div>
      </section>

      <section class="about-section">
        <div class="about-section__meta">
          <span>05</span>
          <p>Publishing</p>
        </div>
        <div class="about-section__body">
          <h2>What to read here</h2>
          <div class="editorial-copy">
            <p>
              The site brings together long-form articles, shorter notes and a concept
              library. These formats help build a shared language for AI, psychology,
              trust, emotion, work and culture.
            </p>
          </div>
          <div class="about-link-grid" aria-label="Publications">
            <a href="/articles/">
              <span>Articles</span>
              <strong>Long-form essays and analysis</strong>
            </a>
            <a href="/notes/">
              <span>Notes</span>
              <strong>Short observations and working ideas</strong>
            </a>
            <a href="/concepts/">
              <span>Concepts</span>
              <strong>The language of Prompted Psyche</strong>
            </a>
          </div>
        </div>
      </section>

      <section class="about-section">
        <div class="about-section__meta">
          <span>06</span>
          <p>Consulting</p>
        </div>
        <div class="about-section__body">
          <h2>Consulting</h2>
          <div class="editorial-copy">
            <p>
              Consulting, workshops and talks grow from the same perspective. I help
              organizations think more clearly about AI literacy, Human-AI
              Interaction, trust, decision-making, source checking and practical
              AI-assisted workflows.
            </p>
            <p>
              <a class="text-link" href="/consulting/">See consulting</a>
            </p>
          </div>
        </div>
      </section>
    </div>
  </article>
</BaseLayout>

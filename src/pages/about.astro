---
import IconCard from '../components/IconCard.astro';
import SectionHeader from '../components/SectionHeader.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="About"
  description="About Prompted Psyche, my research-informed project on AI, cyberpsychology and Human-AI Interaction."
>
  <section class="page-shell about-shell">
    <header class="page-header">
      <div>
        <p class="eyebrow">About</p>
        <h1>AI, cyberpsychology and Human-AI Interaction.</h1>
      </div>
      <p>
        Prompted Psyche is my public research and consulting home: writing, talks and
        advisory work on the human side of artificial intelligence.
      </p>
    </header>

    <section class="about-layout" aria-labelledby="who-title">
      <div class="prose">
        <p class="section-kicker" id="who-title">Who I am</p>
        <p>
          I write and consult at the intersection of AI, cyberpsychology and Human-AI
          Interaction.
        </p>
        <p>
          Prompted Psyche is my project on the human side of artificial intelligence:
          how AI changes thinking, emotion, trust, communication, creativity and work.
        </p>
        <p>
          I look at AI through psychology, communication and creative practice. The
          project asks what changes when people begin to think with AI, trust AI,
          delegate work to AI, create with AI and communicate through AI-shaped systems.
        </p>
      </div>

      <aside class="soft-panel about-aside" aria-label="Project lens">
        <p class="small-label">What Prompted Psyche is</p>
        <p>
          A personal expert platform that combines research notebook, editorial magazine,
          consulting studio and public profile.
        </p>
      </aside>
    </section>

    <section aria-labelledby="perspective-title">
      <SectionHeader kicker="Perspective" title="AI, psychology, communication and creative practice" id="perspective-title">
        Prompted Psyche connects the psychology of AI use with practical questions about
        work, trust, culture and responsibility.
      </SectionHeader>
      <div class="icon-grid about-perspective" aria-label="Perspective areas">
        <IconCard icon="concept" title="AI, cyberpsychology and HAI">
          I use concepts that help describe how people relate to AI systems.
        </IconCard>
        <IconCard icon="dialogue" title="Psychology and communication">
          Attention to trust, emotion, language, validation and decision-making.
        </IconCard>
        <IconCard icon="spark" title="Film as interpretive advantage">
          Narrative, attention, image and emotion as tools for reading human-AI change.
        </IconCard>
        <IconCard icon="article" title="Research profile">
          My ongoing research work informs the background of Prompted Psyche.
        </IconCard>
      </div>
    </section>

    <section class="panel about-note" aria-labelledby="film-perspective-title">
      <h2 id="film-perspective-title">Film, attention and AI</h2>
      <p>
        My background in film, editing and post-production shapes how I think about AI:
        through narrative, attention, image, emotion and the way technologies reorganize
        creative and communicative work.
      </p>
    </section>

    <section class="panel about-note" aria-labelledby="research-profile-title">
      <h2 id="research-profile-title">Research profile</h2>
      <p>
        I am developing registered research projects in progress on psychological and
        creative aspects of human-AI relations, including AI chatbot use, anxiety,
        authorship, authenticity and creative control in AI-supported practice.
      </p>
      <p>
        ORCID:{' '}
        <a href="https://orcid.org/0009-0001-0715-0517" rel="me noopener">
          https://orcid.org/0009-0001-0715-0517
        </a>
      </p>
    </section>
  </section>
</BaseLayout>

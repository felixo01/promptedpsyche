---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="About"
  description="About Feliks Mamczur and Prompted Psyche, a research-driven project on AI, cyberpsychology and Human-AI Interaction."
>
  <section class="page-shell two-column">
    <div>
      <p class="eyebrow">About</p>
      <h1>AI, cyberpsychology and Human-AI Interaction.</h1>
    </div>

    <div>
      <div class="prose">
        <p>
          Feliks Mamczur writes and consults on AI, cyberpsychology and Human-AI
          Interaction.
        </p>
        <p>
          Prompted Psyche is a research-driven publication and consulting platform on the
          human side of artificial intelligence: how AI shapes thought, emotion, trust,
          communication, creativity and work.
        </p>
        <p>
          The project is interested in AI as a lived, social and psychological technology,
          not only as software. It asks what changes when people begin to think with AI,
          trust AI, delegate work to AI, create with AI and communicate through AI-shaped
          systems.
        </p>
      </div>

      <div class="panel">
        <h2>Perspective</h2>
        <div class="prose">
          <p>
            Feliks approaches AI through psychology, communication and creative practice.
            His background in film, editing and post-production shapes how he thinks
            about AI: through narrative, attention, image, emotion and the way
            technologies reorganize creative and communicative work.
          </p>
        </div>
      </div>

      <div class="panel">
        <h2>Research profile</h2>
        <div class="prose">
          <p>
            Feliks is developing registered research projects in progress on the
            psychological and creative dimensions of Human-AI Interaction, including AI
            chatbot use, anxiety, authorship, authenticity and creative control in
            AI-assisted practice.
          </p>
          <p>
            These projects are ongoing and form part of the research background behind
            Prompted Psyche.
          </p>
          <p>
            ORCID:{' '}
            <a href="https://orcid.org/0009-0001-0715-0517" rel="me noopener">
              https://orcid.org/0009-0001-0715-0517
            </a>
          </p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="About"
  description="About Prompted Psyche and Feliks Mamczur."
>
  <section class="page-shell two-column">
    <div>
      <p class="eyebrow">About</p>
      <h1>A research-driven expert platform about the human side of AI.</h1>
    </div>

    <div class="prose">
      <p>
        Feliks Mamczur writes and consults on AI, cyberpsychology and Human-AI Interaction.
      </p>
      <p>
        His work focuses on how artificial intelligence shapes thought, emotion, trust,
        communication, relationships, creativity and work.
      </p>
      <p>
        His background in film and post-production informs his understanding of narrative,
        attention, image, emotion and creative workflows, but Prompted Psyche is not a film
        portfolio. It is a research-driven expert platform about the human side of AI.
      </p>
    </div>
  </section>
</BaseLayout>

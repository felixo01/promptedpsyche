---
import { getCollection } from 'astro:content';
import EntryList from '../../components/EntryList.astro';
import VisualPlate from '../../components/VisualPlate.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { onlyPublicEntriesByLang, sortByDateDesc } from '../../lib/content';

const concepts = sortByDateDesc(onlyPublicEntriesByLang(await getCollection('concepts'), 'en'));
---

<BaseLayout
  title="Concepts"
  description="A field guide to core concepts in AI, cyberpsychology and Human-AI Interaction."
>
  <section class="page-shell">
    <header class="page-header">
      <div>
        <p class="eyebrow">Concepts</p>
        <h1>Concepts</h1>
      </div>
      <p>
        The Prompted Psyche concept library organizes terms for thinking about the
        human side of AI: trust, decisions, communication, work and human-AI
        relations.
      </p>
    </header>

    <EntryList
      entries={concepts}
      basePath="/concepts"
      label="Concept"
      emptyLabel="Concepts"
      emptyMessage="The concept library is in preparation."
      emptyNote="It will organize terms for thinking about trust, decisions, communication, work and human-AI relations."
      emptyIcon="concept"
    />

    <section class="empty-followup" aria-labelledby="concepts-followup-title">
      <VisualPlate variant="concept-map" class="empty-state-visual" />
      <h2 id="concepts-followup-title">A working vocabulary</h2>
      <p>
        This is a small public MVP of the library. It will grow carefully as new
        essays, notes and concepts are prepared.
      </p>
    </section>
  </section>
</BaseLayout>

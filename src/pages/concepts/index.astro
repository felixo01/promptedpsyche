---
import { getCollection } from 'astro:content';
import EntryList from '../../components/EntryList.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { onlyPublicEntries, sortByDateDesc } from '../../lib/content';

const concepts = sortByDateDesc(onlyPublicEntries(await getCollection('concepts')));
---

<BaseLayout
  title="Concepts"
  description="A field guide to core concepts in AI, cyberpsychology and Human-AI Interaction."
>
  <section class="page-shell">
    <header class="page-header">
      <div>
        <p class="eyebrow">Concepts</p>
        <h1>A glossary for the human side of AI</h1>
      </div>
      <p>
        A growing glossary of concepts for understanding the human side of AI.
      </p>
    </header>

    <EntryList entries={concepts} basePath="/concepts" label="Concept" />
  </section>
</BaseLayout>

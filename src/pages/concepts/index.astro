---
import { getCollection } from 'astro:content';
import ConceptList from '../../components/ConceptList.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { sortConceptsForIndex } from '../../lib/conceptOrder';
import { onlyPublicEntriesByLang } from '../../lib/content';

const concepts = sortConceptsForIndex(onlyPublicEntriesByLang(await getCollection('concepts'), 'en'));
---

<BaseLayout
  title="Concepts"
  description="A field guide to core concepts in AI, cyberpsychology and Human-AI Interaction."
>
  <section class="page-shell">
    <header class="page-header">
      <div>
        <p class="eyebrow">Concepts</p>
        <h1>Concepts</h1>
      </div>
      <p>
        The Prompted Psyche concept library organizes terms for thinking about the
        human side of AI: trust, decisions, communication, work and human-AI
        relations.
      </p>
    </header>

    <ConceptList
      entries={concepts}
      basePath="/concepts"
      label="Concept"
      linkLabel="Read more"
      emptyLabel="Concepts"
      emptyMessage="The concept library is in preparation."
    />

    <section class="concept-library-note" aria-labelledby="concepts-followup-title">
      <h2 id="concepts-followup-title">A working vocabulary</h2>
      <p>
        This is a small public MVP of the library. It will grow carefully as new
        essays, notes and concepts are prepared.
      </p>
    </section>
  </section>
</BaseLayout>

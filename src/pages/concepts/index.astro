---
import { getCollection } from 'astro:content';
import EntryList from '../../components/EntryList.astro';
import VisualPlate from '../../components/VisualPlate.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { onlyPublicEntries, sortByDateDesc } from '../../lib/content';

const concepts = sortByDateDesc(onlyPublicEntries(await getCollection('concepts')));
---

<BaseLayout
  title="Concepts"
  description="A field guide to core concepts in AI, cyberpsychology and Human-AI Interaction."
>
  <section class="page-shell">
    <header class="page-header">
      <div>
        <p class="eyebrow">Concepts</p>
        <h1>Concepts</h1>
      </div>
      <p>
        A living glossary for the human side of AI, cyberpsychology and Human-AI
        Interaction.
      </p>
    </header>

    <EntryList
      entries={concepts}
      basePath="/concepts"
      label="Concept"
      emptyLabel="Concepts"
      emptyMessage="The concept library is in preparation."
      emptyNote="It will organize terms such as AI literacy, calibrated trust, cognitive offloading, AI companions, Human-AI Interaction and automation bias."
      emptyIcon="concept"
    />

    {concepts.length === 0 && (
      <section class="empty-followup" aria-labelledby="concepts-followup-title">
        <VisualPlate variant="concept-map" class="empty-state-visual" />
        <h2 id="concepts-followup-title">Concept language</h2>
        <p>
          Concepts will organize the vocabulary of Prompted Psyche: AI literacy,
          calibrated trust, cognitive offloading, AI companions, Human-AI Interaction
          and automation bias.
        </p>
      </section>
    )}
  </section>
</BaseLayout>

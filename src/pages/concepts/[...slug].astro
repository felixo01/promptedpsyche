---
import { getCollection, render } from 'astro:content';
import EntryLayout from '../../layouts/EntryLayout.astro';
import { getConceptAlternates, getConceptSlug } from '../../lib/conceptRoutes';
import { onlyPublicEntries, onlyPublicEntriesByLang } from '../../lib/content';

export async function getStaticPaths() {
  const publicConcepts = onlyPublicEntries(await getCollection('concepts'));
  const concepts = onlyPublicEntriesByLang(publicConcepts, 'en');

  return concepts.map((entry) => ({
    params: { slug: getConceptSlug(entry) },
    props: { entry, alternateLinks: getConceptAlternates(entry, publicConcepts) }
  }));
}

const { entry, alternateLinks } = Astro.props;
const { Content } = await render(entry);
---

<EntryLayout entry={entry} label="Concept" lang="en" alternateLinks={alternateLinks} showPublishedAt={false}>
  <Content />
</EntryLayout>

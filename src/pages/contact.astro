---
import Icon from '../components/Icon.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../lib/site';

const contactEmail = site.email?.trim();
---

<BaseLayout
  title="Contact"
  description="Contact Feliks Mamczur about consulting, talks, workshops, media, collaboration or research conversations."
>
  <section class="page-shell two-column">
    <div>
      <p class="eyebrow">Contact</p>
      <h1>For consulting, talks, workshops, media or research conversations.</h1>
    </div>

    <div>
      <div class="prose">
        <p>
          For consulting, talks, workshops, media or research conversations, send a concise
          note with context, timeline and the kind of support you are looking for.
        </p>
        <p>
          Prompted Psyche is currently in pre-launch, so response paths and public contact
          details may still change.
        </p>
        {
          contactEmail ? (
            <p>
              Email: <a href={`mailto:${contactEmail}`}>{contactEmail}</a>
            </p>
          ) : (
            <p>Contact details will be added soon.</p>
          )
        }
      </div>

      <div class="panel">
        <h2>Relevant inquiries</h2>
        <ul class="plain-list icon-list">
          <li><Icon name="dialogue" /><span>Consulting</span></li>
          <li><Icon name="spark" /><span>Talks</span></li>
          <li><Icon name="work" /><span>Workshops</span></li>
          <li><Icon name="concept" /><span>Research conversations</span></li>
          <li><Icon name="article" /><span>Media / commentary</span></li>
          <li><Icon name="trust" /><span>Collaboration</span></li>
        </ul>
      </div>
    </div>
  </section>
</BaseLayout>

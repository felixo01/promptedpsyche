---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../lib/site';
---

<BaseLayout
  title="Contact"
  description="Contact Feliks Mamczur about Prompted Psyche, consulting, writing or research."
>
  <section class="page-shell two-column">
    <div>
      <p class="eyebrow">Contact</p>
      <h1>For early consulting, speaking or research inquiries.</h1>
    </div>

    <div class="prose">
      <p>
        Prompted Psyche is still in pre-launch. A simple contact path is available for
        early conversations about AI literacy, Human-AI Interaction and the psychology of
        working with AI.
      </p>
      <p>
        Email: <a href={`mailto:${site.email}`}>{site.email}</a>
      </p>
      <p>
        Include a short note about the context, format and timeline.
      </p>
    </div>
  </section>
</BaseLayout>

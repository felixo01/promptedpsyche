---
import Icon from '../components/Icon.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../lib/site';

const contactEmail = site.email?.trim();
---

<BaseLayout
  title="Contact"
  description="Contact Feliks Mamczur about consulting, talks, workshops, media, collaboration or research conversations."
>
  <section class="page-shell contact-shell">
    <header class="page-header">
      <div>
        <p class="eyebrow">Contact</p>
        <h1>For consulting, talks, workshops, media or research conversations.</h1>
      </div>
      <p>
        Send a concise note with context, timeline and the kind of support you are looking
        for.
      </p>
    </header>

    <div class="hero-panel contact-intro">
      <div class="prose">
        <p>
          Prompted Psyche is currently in pre-launch, so response paths and public contact
          details may still change.
        </p>
        {
          contactEmail ? (
            <p>
              Email: <a href={`mailto:${contactEmail}`}>{contactEmail}</a>
            </p>
          ) : (
            <p>Contact details will be added soon.</p>
          )
        }
      </div>
    </div>

    <section aria-labelledby="contact-categories-title">
      <div class="compact-section-header">
        <p class="section-kicker">Relevant inquiries</p>
        <h2 id="contact-categories-title">What to write about</h2>
      </div>
      <div class="contact-grid">
        <article class="icon-card">
          <Icon name="dialogue" />
          <h2>Organizational consulting</h2>
        </article>
        <article class="icon-card">
          <Icon name="work" />
          <h2>Workshops and briefings</h2>
        </article>
        <article class="icon-card">
          <Icon name="spark" />
          <h2>Talks and lectures</h2>
        </article>
        <article class="icon-card">
          <Icon name="article" />
          <h2>Media commentary</h2>
        </article>
        <article class="icon-card">
          <Icon name="concept" />
          <h2>Research conversations</h2>
        </article>
        <article class="icon-card">
          <Icon name="trust" />
          <h2>Content and project collaboration</h2>
        </article>
      </div>
    </section>
  </section>
</BaseLayout>

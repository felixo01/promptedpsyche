---
import IconCard from '../components/IconCard.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../lib/site';

const contactEmail = site.email?.trim();
---

<BaseLayout
  title="Contact"
  description="Contact Feliks Mamczur about consulting, talks, workshops, media, collaboration or research conversations."
>
  <section class="page-shell contact-shell">
    <header class="page-header">
      <div>
        <p class="eyebrow">Contact</p>
        <h1>What would you like to talk about?</h1>
      </div>
      <p>
        Send a short note with the context, the type of support you are looking for and
        any relevant timing.
      </p>
    </header>

    <div class="contact-grid">
      <IconCard icon="dialogue" title="Organizational consulting">
        AI use analysis, principles, process mapping and human-AI workflows.
      </IconCard>
      <IconCard icon="work" title="Workshops and briefings">
        Practical sessions for teams, leaders and institutions.
      </IconCard>
      <IconCard icon="spark" title="Talks and lectures">
        Public or internal talks on AI, cyberpsychology and Human-AI Interaction.
      </IconCard>
      <IconCard icon="article" title="Media commentary">
        Commentary on the human, psychological and cultural side of AI.
      </IconCard>
      <IconCard icon="concept" title="Research conversations">
        Conversations around concepts, questions and emerging research directions.
      </IconCard>
      <IconCard icon="trust" title="Content and project collaboration">
        Source-informed content, reviews and collaboration around AI and cyberpsychology.
      </IconCard>
    </div>

    <section class="hero-panel contact-intro" aria-label="Contact details">
      <p>
        You can get in touch about consulting, workshops and briefings, talks and
        lectures, media commentary, research conversations or content and project
        collaboration.
      </p>
      {
        contactEmail ? (
          <p>
            Email: <a href={`mailto:${contactEmail}`}>{contactEmail}</a>
          </p>
        ) : (
          <p>Contact details will be added soon.</p>
        )
      }
      <p>
        Prompted Psyche is currently in pre-launch, so response paths and public contact
        details may still change.
      </p>
    </section>
  </section>
</BaseLayout>

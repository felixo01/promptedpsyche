---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../lib/site';

const contactEmail = site.email?.trim();
const emailSubject = encodeURIComponent('Prompted Psyche - AI work inquiry');
const emailBody = encodeURIComponent(
  'Team or organisation:\nWhere we use AI:\nWhat we want the audit to clarify:\nRelevant timing:'
);
const guidedMailto = contactEmail
  ? `mailto:${contactEmail}?subject=${emailSubject}&body=${emailBody}`
  : undefined;
---

<BaseLayout
  title="Contact"
  description="Contact Feliks Mamczur about an AI Use Audit for a creative, marketing or communication team."
>
  <div class="lovable-page contact-page">
    <header class="lovable-page-hero contact-hero">
      <div class="lovable-container contact-hero__inner">
        <div class="lovable-heading-narrow">
          <p class="eyebrow">Contact</p>
          <h1>Get in touch</h1>
          <p class="lede">
            If you are considering an AI Use Audit, send a short note about your
            team, where AI enters the work and what you want to clarify.
          </p>
        </div>

        <div class="contact-email-card" data-qa="contact-email-card">
          <p class="eyebrow">Email</p>
          {
            contactEmail ? (
              <>
                <a
                  href={`mailto:${contactEmail}`}
                  class="contact-email-card__link"
                  data-qa="contact-email-link"
                >
                  {contactEmail}
                </a>
                <p>
                  A short, concrete description is enough. You do not need to know
                  the exact audit scope before writing.
                </p>
                <div class="contact-email-card__actions">
                  <a
                    href={guidedMailto}
                    class="hero-button hero-button-primary"
                    data-qa="contact-guided-email"
                    data-cta="contact-email"
                  >
                    <span aria-hidden="true"></span>
                    Write about your team
                  </a>
                </div>
              </>
            ) : (
              <p class="contact-email-card__link">Contact details will be added soon.</p>
            )
          }
        </div>
      </div>
    </header>

    <section class="lovable-section contact-grid" aria-labelledby="contact-topics-title">
      <div class="lovable-container contact-grid__inner">
        <div class="compact-heading">
          <p class="eyebrow">Topics</p>
          <h2 id="contact-topics-title">What to write about</h2>
        </div>
        <ul class="contact-list">
          <li>AI use audits for creative, marketing and communication teams</li>
          <li>workshops and talks</li>
          <li>expert or media commentary</li>
          <li>research conversations and editorial collaboration</li>
          <li>projects around AI, communication, marketing and creativity</li>
        </ul>
      </div>
    </section>

    <section class="lovable-section contact-grid contact-grid--compact" aria-labelledby="contact-context-title">
      <div class="lovable-container contact-grid__inner">
        <div class="compact-heading">
          <p class="eyebrow">Context</p>
          <h2 id="contact-context-title">What to include</h2>
        </div>
        <ul class="contact-list" data-qa="contact-guidance-list">
          <li>what kind of team or organization it is</li>
          <li>where and how the team already uses AI</li>
          <li>what problem, uncertainty or responsibility gap needs attention</li>
          <li>which workflow or use case matters most</li>
          <li>any timing that matters</li>
        </ul>
      </div>
    </section>

    <section class="contact-closing" aria-label="Response note">
      <div class="lovable-container">
        <p>
          I will use that context to assess whether the AI Use Audit is a useful
          next step and what scope would be proportionate.
        </p>
      </div>
    </section>
  </div>
</BaseLayout>

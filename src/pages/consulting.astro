---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Consulting"
  description="Consulting on AI literacy, Human-AI Interaction and psychologically informed AI adoption."
>
  <section class="page-shell">
    <header class="page-header">
      <div>
        <p class="eyebrow">Consulting</p>
        <h1>Consulting, workshops and talks are being shaped.</h1>
      </div>
      <p>
        Prompted Psyche is being developed as a public research and writing platform.
      </p>
    </header>

    <div class="two-column">
      <div class="prose">
        <p>
          Consulting, workshops and talks will focus on the psychological and organizational
          realities of working with AI, without treating adoption as a purely technical
          problem.
        </p>
        <p>
          For early consulting or speaking inquiries, contact Feliks Mamczur.
        </p>
      </div>

      <div>
        <div class="panel">
          <h3>Focus areas</h3>
          <ul class="plain-list">
            <li>AI literacy for organizations</li>
            <li>Human-AI Interaction</li>
            <li>Trust and decision-making with AI</li>
            <li>Psychology of working with generative tools</li>
            <li>AI in communication, creativity and culture</li>
          </ul>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import EntryList from '../../components/EntryList.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import EntryLayout from '../../layouts/EntryLayout.astro';
import { onlyEntriesByLang, sortByDateDesc } from '../../lib/content';
import { showPractice } from '../../lib/features';
import { getPracticeAlternates } from '../../lib/practiceRoutes';

type PracticeEntry = CollectionEntry<'practice'>;

const practiceIndexAlternates = {
  en: '/practice/',
  pl: '/pl/practice/',
  xDefault: '/practice/'
};

export async function getStaticPaths() {
  if (!showPractice) {
    return [];
  }

  const allPractice = await getCollection('practice');
  const entries = sortByDateDesc(onlyEntriesByLang(allPractice, 'en'));

  return [
    {
      params: { slug: undefined },
      props: { pageKind: 'index', entries }
    },
    ...entries.map((entry) => ({
      params: { slug: entry.id },
      props: {
        pageKind: 'entry',
        entry,
        alternateLinks: getPracticeAlternates(entry, allPractice)
      }
    }))
  ];
}

const { pageKind, entries = [], entry, alternateLinks } = Astro.props as {
  pageKind: 'index' | 'entry';
  entries?: PracticeEntry[];
  entry?: PracticeEntry;
  alternateLinks?: typeof practiceIndexAlternates;
};

const rendered = entry ? await render(entry) : undefined;
const Content = rendered?.Content;
---

{
  pageKind === 'entry' && entry ? (
    <EntryLayout
      entry={entry}
      label="Practice"
      lang="en"
      alternateLinks={alternateLinks}
    >
      {Content && <Content />}
    </EntryLayout>
  ) : (
    <BaseLayout
      title="Practice"
      description="Short exercises for thinking with AI more carefully: sources, uncertainty, assumptions, counterarguments and decisions."
      lang="en"
      alternateLinks={practiceIndexAlternates}
    >
      <section class="page-shell practice-index">
        <header class="page-header practice-index__header">
          <div>
            <p class="eyebrow">Practice</p>
            <h1>Practice</h1>
          </div>
          <p>
            Practice is a collection of short scenarios for working with AI more
            deliberately. Each entry combines an example instruction with checks,
            limits and questions to consider before using the result.
          </p>
        </header>

        <section class="practice-discovery" aria-labelledby="practice-discovery-title">
          <div class="editorial-section-header">
            <div>
              <p class="section-kicker">Practice</p>
              <h2 id="practice-discovery-title">Choose a situation</h2>
            </div>
            <p>
              Work through sources, uncertainty, assumptions, counterarguments,
              text and decisions without handing judgment or responsibility to the
              model.
            </p>
          </div>
          <EntryList
            entries={entries}
            basePath="/practice"
            label="Practice"
            ctaLabel="Open scenario"
          />
        </section>
      </section>
    </BaseLayout>
  )
}

---
import { getCollection } from 'astro:content';
import EntryList from '../../components/EntryList.astro';
import VisualPlate from '../../components/VisualPlate.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { onlyPublicEntriesByLang, sortByDateDesc } from '../../lib/content';

const articles = sortByDateDesc(onlyPublicEntriesByLang(await getCollection('articles'), 'en'));
---

<BaseLayout
  title="Articles"
  description="Long-form essays and analyses with a clear argument, evidence base and authorial perspective."
>
  <section class="page-shell">
    <header class="page-header">
      <div>
        <p class="eyebrow">Articles</p>
        <h1>Articles</h1>
      </div>
      <p>
        Long-form essays and analyses with a clear argument, evidence base and
        authorial perspective.
      </p>
    </header>

    <aside class="topic-discovery-callout" aria-label="Explore articles by topic">
      <p class="small-label">Topic guides</p>
      <p>Follow curated paths through trust, cognition, agency and responsibility.</p>
      <a class="text-link" href="/topics/">Explore topics</a>
    </aside>

    <EntryList
      entries={articles}
      basePath="/articles"
      label="Article"
      emptyLabel="Articles"
      emptyMessage="Articles are in preparation."
      emptyNote="The first essays will focus on AI literacy, trust, decision-making, communication and responsibility with generative tools."
      emptyIcon="article"
      ctaLabel="Read article"
    />

    {articles.length === 0 && (
      <section class="empty-followup" aria-labelledby="first-directions-title">
        <VisualPlate variant="note-stack" class="empty-state-visual" />
        <h2 id="first-directions-title">First themes</h2>
        <ul>
          <li>AI literacy</li>
          <li>trust and model outputs</li>
          <li>decision-making with AI</li>
          <li>responsibility in human-AI work</li>
        </ul>
      </section>
    )}
  </section>
</BaseLayout>

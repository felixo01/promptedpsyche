---
import { getCollection } from 'astro:content';
import EntryList from '../../components/EntryList.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { onlyPublicEntries, sortByDateDesc } from '../../lib/content';

const articles = sortByDateDesc(onlyPublicEntries(await getCollection('articles')));
---

<BaseLayout
  title="Articles"
  description="Research-driven essays on AI, cyberpsychology and Human-AI Interaction."
>
  <section class="page-shell">
    <header class="page-header">
      <div>
        <p class="eyebrow">Articles</p>
        <h1>Long-form essays</h1>
      </div>
      <p>
        Long-form essays on AI, cyberpsychology and Human-AI Interaction.
      </p>
    </header>

    <EntryList entries={articles} basePath="/articles" label="Article" />
  </section>
</BaseLayout>

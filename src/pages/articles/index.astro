---
import { getCollection } from 'astro:content';
import EntryList from '../../components/EntryList.astro';
import VisualPlate from '../../components/VisualPlate.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { onlyPublicEntriesByLang, sortByDateDesc } from '../../lib/content';

const articles = sortByDateDesc(onlyPublicEntriesByLang(await getCollection('articles'), 'en'));
---

<BaseLayout
  title="Articles"
  description="Research-informed essays on AI, cyberpsychology and Human-AI Interaction."
>
  <section class="page-shell">
    <header class="page-header">
      <div>
        <p class="eyebrow">Articles</p>
        <h1>Articles</h1>
      </div>
      <p>
        Long-form essays on AI literacy, trust, decision-making, model outputs in team
        work and the psychological consequences of using generative tools.
      </p>
    </header>

    <EntryList
      entries={articles}
      basePath="/articles"
      label="Article"
      emptyLabel="Articles"
      emptyMessage="Long-form essays are in preparation."
      emptyNote="They will focus on AI literacy, trust, decision-making, model outputs in team work and the psychological consequences of using generative tools."
      emptyIcon="article"
    />

    {articles.length === 0 && (
      <section class="empty-followup" aria-labelledby="first-directions-title">
        <VisualPlate variant="note-stack" class="empty-state-visual" />
        <h2 id="first-directions-title">First directions</h2>
        <ul>
          <li>AI literacy</li>
          <li>trust in model outputs</li>
          <li>decision-making and responsibility with AI</li>
          <li>psychological consequences of using generative tools</li>
        </ul>
      </section>
    )}
  </section>
</BaseLayout>

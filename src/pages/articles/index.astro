---
import { getCollection } from 'astro:content';
import EntryList from '../../components/EntryList.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { onlyPublicEntriesByLang, sortByDateDesc } from '../../lib/content';

const articles = sortByDateDesc(onlyPublicEntriesByLang(await getCollection('articles'), 'en'));
---

<BaseLayout
  title="Articles"
  description="Research-driven essays on AI, cyberpsychology and Human-AI Interaction."
>
  <section class="page-shell">
    <header class="page-header">
      <div>
        <p class="eyebrow">Articles</p>
        <h1>Articles</h1>
      </div>
      <p>
        Long-form essays on AI, cyberpsychology and Human-AI Interaction.
      </p>
    </header>

    <EntryList
      entries={articles}
      basePath="/articles"
      label="Article"
      emptyLabel="Articles"
      emptyMessage="Public articles are being prepared."
      emptyNote="The first essays will focus on AI literacy, trust, decision-making, human-AI workflows and the psychological consequences of working with generative tools."
    />
  </section>
</BaseLayout>

---
import { getCollection, render } from 'astro:content';
import EntryLayout from '../../layouts/EntryLayout.astro';
import { getArticleAlternates } from '../../lib/articleRoutes';
import { onlyPublicEntries, onlyPublicEntriesByLang } from '../../lib/content';

export async function getStaticPaths() {
  const publicArticles = onlyPublicEntries(await getCollection('articles'));
  const articles = onlyPublicEntriesByLang(publicArticles, 'en');

  return articles.map((entry) => ({
    params: { slug: entry.id },
    props: { entry, alternateLinks: getArticleAlternates(entry, publicArticles) }
  }));
}

const { entry, alternateLinks } = Astro.props;
const { Content } = await render(entry);
---

<EntryLayout entry={entry} label="Article" lang="en" alternateLinks={alternateLinks}>
  <Content />
</EntryLayout>

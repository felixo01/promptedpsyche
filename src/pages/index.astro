---
import { getCollection } from 'astro:content';
import VisualPlate from '../components/VisualPlate.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { getArticlePath } from '../lib/articleRoutes';
import { onlyPublicEntriesByLang } from '../lib/content';
import { getNotePath } from '../lib/noteRoutes';

const publicArticles = onlyPublicEntriesByLang(await getCollection('articles'), 'en');
const publicNotes = onlyPublicEntriesByLang(await getCollection('notes'), 'en');
const conflictNote = publicNotes.find((entry) => entry.data.translationKey === 'ai-sycophancy-conflict');
const thinkingArticle = publicArticles.find((entry) => entry.data.translationKey === 'ai-thinking-practice');
const trustArticle = publicArticles.find((entry) => entry.data.translationKey === 'ai-path-to-knowledge');
const startHereEntries = [
  ...(conflictNote
    ? [{ entry: conflictNote, label: 'Research note', cta: 'Read the note', href: getNotePath(conflictNote, 'en') }]
    : []),
  ...(thinkingArticle
    ? [{ entry: thinkingArticle, label: 'Article', cta: 'Read the article', href: getArticlePath(thinkingArticle, 'en') }]
    : []),
  ...(trustArticle
    ? [{ entry: trustArticle, label: 'Article', cta: 'Read the article', href: getArticlePath(trustArticle, 'en') }]
    : [])
];
---

<BaseLayout
  title="The human side of AI"
  description="Prompted Psyche is Feliks Mamczur's platform on the human side of AI, combining research-informed writing with AI use audits for creative and marketing teams."
  image="/images/social/prompted-psyche-home-social-1200x630.png"
>
  <div>
    <section class="home-hero home-hero-publication" aria-labelledby="home-title">
      <div class="home-hero-copy" data-qa="hero-copy">
        <p class="eyebrow">AI - Cognitive Psychology - Human-AI Interaction</p>
        <h1 id="home-title" data-qa="hero-title">The human side of AI.</h1>
        <p class="lede">
          AI is changing how we think, make decisions, communicate and work.
        </p>
        <p class="hero-subnote">
          Prompted Psyche is Feliks Mamczur's platform about the human side of AI
          and a consulting practice for teams that want to use AI more deliberately
          and responsibly.
        </p>
        <div class="hero-actions" aria-label="Main actions">
          <a href="/consulting/" data-qa="home-audit-cta" data-cta="home-audit">See the AI audit for teams</a>
          <a href="#start-here" data-qa="home-reading-cta">Start with essential reading</a>
        </div>
      </div>

      <aside class="hero-sidecar" data-qa="hero-sidecar" aria-label="What is Prompted Psyche?">
        <VisualPlate variant="field-map" class="hero-visual hero-visual-large" />
        <div class="hero-note">
          <p class="small-label">Publication and applied work</p>
          <p>
            Research-informed writing provides the perspective. The AI Use Audit
            applies it to real workflows in creative, marketing and communication
            teams.
          </p>
          <ul class="identity-list" aria-label="Prompted Psyche formats">
            <li>Articles</li>
            <li>Notes</li>
            <li>Team audit</li>
          </ul>
        </div>
      </aside>
    </section>

    <section id="start-here" class="home-section home-writing home-start" aria-labelledby="writing-title" data-qa="home-start-here">
      <div class="editorial-section-header">
        <div>
          <p class="section-kicker">Start here</p>
          <h2 id="writing-title">Three places to begin</h2>
        </div>
        <p>
          Begin with model agreement in conflict, the habits of thinking we stop
          practising, and the trust we place in ready-made answers.
        </p>
      </div>

      <div class="home-start-grid" aria-label="Recommended publications" data-qa="start-here-list">
        {startHereEntries.map((item) => (
          <article class="writing-card start-here-card" data-qa="start-here-entry">
            <p class="entry-index">{item.label}</p>
            <h3>{item.entry.data.title}</h3>
            <p>{item.entry.data.description}</p>
            <a class="text-link" href={item.href}>{item.cta}</a>
          </article>
        ))}
      </div>
      <div class="home-start-footer">
        <a class="text-link" href="/articles/">Browse all articles</a>
        <a class="text-link" href="/notes/">Browse all notes</a>
      </div>
    </section>

    <section class="home-section author-strip home-bio" aria-labelledby="about-title">
      <div>
        <p class="section-kicker">Author</p>
        <h2 id="about-title">Feliks Mamczur</h2>
      </div>
      <div class="author-note">
        <p>
          Through Prompted Psyche, he writes about the human side of AI through the
          lens of cognitive psychology, cyberpsychology, Human-AI Interaction,
          communication and creative practice. He is interested in how language
          models affect attention, decisions, trust, emotion and the way people work
          with information.
        </p>
        <p>
          He draws on experience in marketing, communication, film and
          post-production: working with narrative, image, rhythm, audience emotion
          and the way people make meaning from content.
        </p>
        <a class="text-link" href="/about/">More about the author</a>
      </div>
    </section>

    <section class="home-section home-compact-feature home-concepts" aria-labelledby="concepts-title">
      <div>
        <p class="section-kicker">Concepts</p>
        <h2 id="concepts-title">The project vocabulary</h2>
      </div>
      <div class="compact-feature-copy">
        <p>
          The concept library helps organize the language of Prompted Psyche: AI
          literacy, cognition, trust, model output, anthropomorphism and AI-mediated
          communication.
        </p>
        <a class="text-link" href="/concepts/">Explore concepts</a>
      </div>
    </section>

    <section
      class="home-section home-compact-feature home-consulting"
      data-qa="consulting-teaser"
      aria-labelledby="consulting-title"
    >
      <div>
        <p class="section-kicker">Consulting</p>
        <h2 id="consulting-title">AI Use Audit for Teams</h2>
      </div>
      <div class="compact-feature-copy">
        <p>
          For creative, marketing and communication teams that already use
          generative AI and need clearer rules for verification, trust and
          responsibility.
        </p>
        <a class="text-link" href="/consulting/">See the audit</a>
      </div>
    </section>
  </div>
</BaseLayout>

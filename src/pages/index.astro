---
import CtaPanel from '../components/CtaPanel.astro';
import Icon from '../components/Icon.astro';
import IconCard from '../components/IconCard.astro';
import SectionHeader from '../components/SectionHeader.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout>
  <div class="home-shell home-layout">
    <section class="home-hero" aria-labelledby="home-title">
      <div class="home-hero-copy">
        <p class="eyebrow">AI - Cyberpsychology - Human-AI Interaction</p>
        <h1 id="home-title">The human side of artificial intelligence.</h1>
        <p class="lede">
          I write and consult on how AI shapes thought, emotion, trust, communication,
          creativity and work.
        </p>
        <div class="hero-actions" aria-label="Main actions">
          <a href="/consulting/">Consulting for organizations</a>
          <a href="/about/">About the project</a>
        </div>
      </div>

      <aside class="identity-panel dossier-panel" aria-label="What is Prompted Psyche?">
        <span class="dossier-stamp" aria-hidden="true">PP</span>
        <p class="small-label">What is Prompted Psyche?</p>
        <p>
          Prompted Psyche is my project on the human side of artificial intelligence -
          how AI affects thinking, emotion, trust, communication, creativity and work.
        </p>
        <ul class="identity-list" aria-label="Project topics">
          <li>AI literacy</li>
          <li>trust</li>
          <li>decisions</li>
          <li>work</li>
          <li>human-AI relations</li>
          <li>creativity</li>
          <li>culture</li>
        </ul>
        <p class="status-note">This site is in pre-launch. Public writing is being prepared.</p>
      </aside>
    </section>

    <section class="home-section" aria-labelledby="entry-title">
      <SectionHeader kicker="Ways in" title="Who Prompted Psyche is for" id="entry-title">
        A place for organizations, readers and conversations about the human side of AI
        without hype or oversimplification.
      </SectionHeader>
      <div class="path-grid">
        <IconCard icon="work" title="For organizations" href="/consulting/" linkLabel="See consulting">
          AI use analysis, process mapping, human-AI work principles, workshops and talks.
        </IconCard>
        <IconCard icon="article" title="Essays and concepts" href="#writing-title" linkLabel="Explore publications">
          Articles, notes and a concept library on AI, psychology, trust, emotion, work and culture.
        </IconCard>
        <IconCard icon="dialogue" title="Talks and collaboration" href="/contact/" linkLabel="Get in touch">
          Media commentary, lectures, research conversations and content collaboration on the human side of AI.
        </IconCard>
      </div>
    </section>

    <section class="home-section" aria-labelledby="areas-title">
      <SectionHeader kicker="Human-AI observatory" title="Areas of focus" id="areas-title">
        A working map for essays, notes, concepts and consulting around the human side of AI.
      </SectionHeader>
      <div class="topic-map" aria-label="Research areas">
        <IconCard icon="trust" title="Trust">How people decide when AI feels credible.</IconCard>
        <IconCard icon="emotion" title="Emotion">How conversational systems shape comfort, anxiety and validation.</IconCard>
        <IconCard icon="dialogue" title="Attachment">Why AI can feel close, safe or emotionally available.</IconCard>
        <IconCard icon="work" title="Work">How AI changes habits, workflow and responsibility.</IconCard>
        <IconCard icon="decision" title="Decisions">Where human judgment is supported, weakened or outsourced.</IconCard>
        <IconCard icon="spark" title="Creativity">How AI changes authorship, style and creative confidence.</IconCard>
        <IconCard icon="culture" title="Culture">What AI reveals about language, media, identity and power.</IconCard>
      </div>
    </section>

    <section class="home-section consulting-teaser" aria-labelledby="consulting-title">
      <div>
        <p class="section-kicker">Consulting studio</p>
        <h2 id="consulting-title">Consulting for organizations</h2>
        <p class="section-lead">
          I help organizations understand where AI can meaningfully support work and where
          it requires principles, verification and caution.
        </p>
      </div>
      <div class="teaser-panel">
        <ul class="teaser-chips" aria-label="Consulting focus areas">
          <li><Icon name="check" />AI use analysis</li>
          <li><Icon name="check" />process mapping</li>
          <li><Icon name="check" />human-AI workflow</li>
          <li><Icon name="check" />team principles</li>
        </ul>
        <a href="/consulting/">See consulting</a>
      </div>
    </section>

    <section class="home-section" aria-labelledby="writing-title">
      <SectionHeader kicker="Essays and notes" title="Writing is being prepared" id="writing-title">
        Articles, notes and concepts will open as a source-based editorial archive.
      </SectionHeader>
      <div class="system-grid">
        <IconCard icon="article" title="Articles" href="/articles/" linkLabel="Open archive">
          Long-form essays on AI, cyberpsychology and Human-AI Interaction.
        </IconCard>
        <IconCard icon="note" title="Notes" href="/notes/" linkLabel="Open notes">
          Short observations, definitions and research directions.
        </IconCard>
        <IconCard icon="concept" title="Concepts" href="/concepts/" linkLabel="Open concepts">
          A growing vocabulary for the human side of AI.
        </IconCard>
      </div>
    </section>

    <section class="home-section about-teaser" aria-labelledby="about-title">
      <div>
        <p class="section-kicker">Expert profile</p>
        <h2 id="about-title">Feliks Mamczur</h2>
      </div>
      <p>
        I write and consult at the intersection of AI, cyberpsychology and Human-AI
        Interaction. My background in film, editing and post-production shapes how I think
        about AI: through narrative, attention, image, emotion and the way technologies
        reorganize creative and communicative work.
      </p>
    </section>

    <CtaPanel kicker="Contact" title="Let's talk about AI in your organization." href="/contact/" linkLabel="Contact">
      Consulting, workshops, talks and research-informed conversations about the human
      side of AI adoption.
    </CtaPanel>
  </div>
</BaseLayout>

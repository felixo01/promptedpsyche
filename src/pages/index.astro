---
import VisualPlate from '../components/VisualPlate.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Articles and notes on the human side of AI"
  description="Prompted Psyche is Feliks Mamczur's project on the psychological, communicative and cultural consequences of AI use."
>
  <div>
    <section class="home-hero home-hero-publication" aria-labelledby="home-title">
      <div class="home-hero-copy" data-qa="hero-copy">
        <p class="eyebrow">AI - Cyberpsychology - Human-AI Interaction</p>
        <h1 id="home-title" data-qa="hero-title">Articles and notes on the human side of AI.</h1>
        <p class="lede">
          I write about how AI changes thought, trust, communication, creativity and work.
        </p>
        <p class="hero-subnote">
          Prompted Psyche is Feliks Mamczur's project on the psychological,
          communicative and cultural consequences of AI use.
        </p>
        <div class="hero-actions" aria-label="Main actions">
          <a href="/articles/">Articles</a>
          <a href="/about/">About</a>
        </div>
      </div>

      <aside class="hero-sidecar" data-qa="hero-sidecar" aria-label="What is Prompted Psyche?">
        <VisualPlate variant="field-map" class="hero-visual hero-visual-large" />
        <div class="hero-note">
          <p class="small-label">What is Prompted Psyche?</p>
          <p>
            An independent publication platform about what happens when people begin to
            use AI, trust its outputs and fold it into their work.
          </p>
          <ul class="identity-list" aria-label="Publication formats">
            <li>Articles</li>
            <li>Notes</li>
            <li>Concepts</li>
          </ul>
        </div>
      </aside>
    </section>

    <section class="home-section home-writing" aria-labelledby="writing-title">
      <div class="editorial-section-header">
        <div>
          <p class="section-kicker">Writing</p>
          <h2 id="writing-title">Articles and notes</h2>
        </div>
        <p>
          The first texts are in preparation. This is where longer articles and
          shorter notes on AI work, trust, decisions, communication and responsibility
          will appear.
        </p>
      </div>

      <div class="home-writing-grid" aria-label="Publication sections">
        <article class="writing-card" data-qa="writing-card">
          <p class="entry-index">Articles</p>
          <h3>Long-form essays</h3>
          <p>
            Source-based essays on AI, cyberpsychology and Human-AI Interaction.
          </p>
          <a class="text-link" href="/articles/">Articles</a>
        </article>
        <article class="writing-card" data-qa="writing-card">
          <p class="entry-index">Notes</p>
          <h3>Shorter observations</h3>
          <p>
            Notes for definitions, research directions and questions that may become
            essays.
          </p>
          <a class="text-link" href="/notes/">Notes</a>
        </article>
      </div>
    </section>

    <section class="home-section home-compact-feature home-concepts" aria-labelledby="concepts-title">
      <div>
        <p class="section-kicker">Concepts</p>
        <h2 id="concepts-title">The project vocabulary</h2>
      </div>
      <div class="compact-feature-copy">
        <p>
          The concept library organizes the language of Prompted Psyche: AI literacy,
          trust, model output, anthropomorphism and AI-mediated communication.
        </p>
        <a class="text-link" href="/concepts/">Explore concepts</a>
      </div>
    </section>

    <section class="home-section author-strip home-bio" aria-labelledby="about-title">
      <div>
        <p class="section-kicker">Author</p>
        <h2 id="about-title">Feliks Mamczur</h2>
      </div>
      <div class="author-note">
        <p>
          Feliks Mamczur writes about the human side of AI, combining cyberpsychology,
          communication and creative practice. He develops Prompted Psyche as an
          independent publication and expert platform.
        </p>
        <a class="text-link" href="/about/">About</a>
      </div>
    </section>

    <section
      class="home-section home-compact-feature home-consulting"
      data-qa="consulting-teaser"
      aria-labelledby="consulting-title"
    >
      <div>
        <p class="section-kicker">Consulting</p>
        <h2 id="consulting-title">Applied in organizations</h2>
      </div>
      <div class="compact-feature-copy">
        <p>
          I help teams make AI use more deliberate: where it supports work, and where
          it requires principles, verification and responsibility.
        </p>
        <a class="text-link" href="/consulting/">Consulting</a>
      </div>
    </section>
  </div>
</BaseLayout>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../lib/site';
---

<BaseLayout>
  <section class="page-shell prelaunch" aria-labelledby="home-title">
    <h1 id="home-title">Prompted Psyche</h1>
    <p class="prelaunch-tagline">{site.tagline}</p>
    <p class="lede">
      A research-driven project by Feliks Mamczur on how artificial intelligence shapes
      thought, emotion, trust, communication, relationships and work.
    </p>
    <p class="quiet">This site is currently being developed.</p>
  </section>
</BaseLayout>

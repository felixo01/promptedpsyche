---
import Icon from '../components/Icon.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../lib/site';
---

<BaseLayout>
  <div class="home-shell">
    <section class="prelaunch" aria-labelledby="home-title">
      <p class="eyebrow masthead-context">
        <span>Prompted Psyche</span>
        <span>by Feliks Mamczur</span>
      </p>
      <h1 id="home-title">The human side of artificial intelligence.</h1>
      <p class="prelaunch-tagline">{site.tagline}</p>
      <p class="lede">
        A research-informed publication and consulting platform by Feliks Mamczur on how
        artificial intelligence shapes thought, emotion, trust, communication, creativity
        and work.
      </p>
      <div class="hero-actions" aria-label="Next steps">
        <a href="/consulting/">Consulting</a>
        <a href="/about/">About the project</a>
      </div>
      <div class="project-card identity-panel">
        <p class="small-label">What is Prompted Psyche?</p>
        <p>
          A research-informed expert platform by Feliks Mamczur on AI, cyberpsychology and
          Human-AI Interaction.
        </p>
        <ul class="identity-list" aria-label="Project focus">
          <li>AI literacy</li>
          <li>Cyberpsychology</li>
          <li>Human-AI Interaction</li>
        </ul>
        <p class="status-note">This site is in pre-launch. Public writing is being prepared.</p>
      </div>
    </section>

    <section class="home-section" aria-labelledby="about-project-title">
      <div class="section-kicker">Project</div>
      <div class="section-header">
        <h2 id="about-project-title">What this project is about</h2>
        <p>
          AI is not only a tool. It is becoming part of how people think, decide, write,
          trust and work together.
        </p>
      </div>
      <div class="two-column">
        <div class="prose">
          <p>
            Prompted Psyche looks at AI not only as a tool, but as a psychological,
            cultural and communicative technology. It focuses on what happens when
            artificial intelligence enters everyday work, decision-making, relationships,
            creativity and public language.
          </p>
          <p>
            The project connects AI literacy, cyberpsychology and Human-AI Interaction
            with practical questions about judgment, responsibility, emotion, communication
            and creative practice.
          </p>
        </div>
        <div class="panel">
          <h3>Research-informed, not hype-driven</h3>
          <p>
            Public writing is being prepared through a source-based editorial system:
            claims, concepts and examples are reviewed before publication.
          </p>
        </div>
      </div>
    </section>

    <section class="home-section" aria-labelledby="areas-title">
      <div class="section-kicker">Human-AI observatory</div>
      <div class="section-header">
        <h2 id="areas-title">Areas of attention</h2>
        <p>
          A working map for future essays, notes and concepts about the human side of AI.
        </p>
      </div>
      <ul class="area-grid" aria-label="Research areas">
        <li>
          <span class="area-head"><span>01</span><Icon name="trust" /></span>
          <strong>Trust</strong>
          <p>How people decide when AI feels credible.</p>
        </li>
        <li>
          <span class="area-head"><span>02</span><Icon name="emotion" /></span>
          <strong>Emotion</strong>
          <p>How conversational systems shape comfort, anxiety and validation.</p>
        </li>
        <li>
          <span class="area-head"><span>03</span><Icon name="attachment" /></span>
          <strong>Attachment</strong>
          <p>Why AI can feel close, safe or emotionally available.</p>
        </li>
        <li>
          <span class="area-head"><span>04</span><Icon name="work" /></span>
          <strong>Work</strong>
          <p>How AI changes habits, workflow and responsibility.</p>
        </li>
        <li>
          <span class="area-head"><span>05</span><Icon name="decision" /></span>
          <strong>Decisions</strong>
          <p>Where human judgment is supported, weakened or outsourced.</p>
        </li>
        <li>
          <span class="area-head"><span>06</span><Icon name="spark" /></span>
          <strong>Creativity</strong>
          <p>How AI changes authorship, style and creative confidence.</p>
        </li>
        <li>
          <span class="area-head"><span>07</span><Icon name="culture" /></span>
          <strong>Culture</strong>
          <p>What AI reveals about language, media, identity and power.</p>
        </li>
      </ul>
    </section>

    <section class="contact-band" aria-labelledby="consulting-title">
      <p class="small-label" id="consulting-title">Consulting, workshops and talks</p>
      <p>
        Feliks works with organizations, teams and institutions that need to understand the
        human side of AI adoption: AI literacy, trust, decision-making, communication,
        creative workflows and responsible use of generative tools.
      </p>
      <a href="/consulting/">Explore consulting</a>
    </section>

    <section class="publication-system" aria-labelledby="system-title">
      <p class="section-kicker">Writing and research notes</p>
      <h2 id="system-title">A source-based publication system is being prepared</h2>
      <p class="quiet">
        Articles, notes and concepts are being prepared as part of a source-based
        editorial system. Public writing will include long-form essays, shorter
        observations and concept explainers.
      </p>
      <div class="system-grid">
        <a href="/articles/">
          <Icon name="article" />
          <span>01</span>
          <strong>Articles</strong>
          <p>Long-form essays on AI, cyberpsychology and Human-AI Interaction.</p>
        </a>
        <a href="/notes/">
          <Icon name="note" />
          <span>02</span>
          <strong>Notes</strong>
          <p>Short observations, fragments and working thoughts.</p>
        </a>
        <a href="/concepts/">
          <Icon name="concept" />
          <span>03</span>
          <strong>Concepts</strong>
          <p>A living glossary for the human side of AI.</p>
        </a>
      </div>
    </section>
  </div>
</BaseLayout>

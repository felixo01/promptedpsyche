---
import VisualPlate from '../components/VisualPlate.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="The human side of AI"
  description="Prompted Psyche is Feliks Mamczur's author-led platform on how artificial intelligence affects cognition, trust, communication, creativity and work."
>
  <div>
    <section class="home-hero home-hero-publication" aria-labelledby="home-title">
      <div class="home-hero-copy" data-qa="hero-copy">
        <p class="eyebrow">AI - Cognitive Psychology - Human-AI Interaction</p>
        <h1 id="home-title" data-qa="hero-title">The human side of AI.</h1>
        <p class="lede">
          Prompted Psyche is Feliks Mamczur's author-led platform on how artificial
          intelligence affects cognition, trust, communication, creativity and work.
        </p>
        <p class="hero-subnote">
          It brings together articles, notes and concepts about AI not only as a
          tool, but as a technology that changes attention, decisions, language,
          emotion and responsibility.
        </p>
        <div class="hero-actions" aria-label="Main actions">
          <a href="/articles/">Articles</a>
          <a href="/about/">Author</a>
        </div>
      </div>

      <aside class="hero-sidecar" data-qa="hero-sidecar" aria-label="What is Prompted Psyche?">
        <VisualPlate variant="field-map" class="hero-visual hero-visual-large" />
        <div class="hero-note">
          <p class="small-label">What is Prompted Psyche?</p>
          <p>
            An independent publication platform on the human side of AI: articles,
            notes and concepts about what happens when people begin to use AI, trust
            its outputs and fold it into thinking and work.
          </p>
          <ul class="identity-list" aria-label="Publication formats">
            <li>Articles</li>
            <li>Notes</li>
            <li>Concepts</li>
          </ul>
        </div>
      </aside>
    </section>

    <section class="home-section home-writing" aria-labelledby="writing-title">
      <div class="editorial-section-header">
        <div>
          <p class="section-kicker">Writing</p>
          <h2 id="writing-title">Writing that organizes AI work</h2>
        </div>
        <p>
          The first essays and notes are now live. Start with texts on prompts,
          context, AI as a mirror and trust in ready-made answers.
        </p>
      </div>

      <div class="home-writing-grid" aria-label="Publication sections">
        <article class="writing-card" data-qa="writing-card">
          <p class="entry-index">Articles</p>
          <h3>Articles</h3>
          <p>
            Longer essays and analyses on the psychological, communicative and
            cultural consequences of AI use.
          </p>
          <a class="text-link" href="/articles/">Go to articles</a>
        </article>
        <article class="writing-card" data-qa="writing-card">
          <p class="entry-index">Notes</p>
          <h3>Notes</h3>
          <p>
            Shorter observations, definitions and research directions.
          </p>
          <a class="text-link" href="/notes/">Go to notes</a>
        </article>
      </div>
    </section>

    <section class="home-section author-strip home-bio" aria-labelledby="about-title">
      <div>
        <p class="section-kicker">Author</p>
        <h2 id="about-title">Feliks Mamczur</h2>
      </div>
      <div class="author-note">
        <p>
          Feliks Mamczur writes about the human side of AI through the lens of
          cognitive psychology, cyberpsychology, Human-AI Interaction, communication
          and creative practice. He is interested in how language models affect
          attention, decisions, trust, emotion and the way people work with
          information.
        </p>
        <p>
          He draws on experience in marketing, communication, film and
          post-production: working with narrative, image, rhythm, audience emotion
          and the way people make meaning from content.
        </p>
        <a class="text-link" href="/about/">More about the author</a>
      </div>
    </section>

    <section class="home-section home-compact-feature home-concepts" aria-labelledby="concepts-title">
      <div>
        <p class="section-kicker">Concepts</p>
        <h2 id="concepts-title">The project vocabulary</h2>
      </div>
      <div class="compact-feature-copy">
        <p>
          The concept library helps organize the language of Prompted Psyche: AI
          literacy, cognition, trust, model output, anthropomorphism and AI-mediated
          communication.
        </p>
        <a class="text-link" href="/concepts/">Explore concepts</a>
      </div>
    </section>

    <section
      class="home-section home-compact-feature home-consulting"
      data-qa="consulting-teaser"
      aria-labelledby="consulting-title"
    >
      <div>
        <p class="section-kicker">Consulting</p>
        <h2 id="consulting-title">Applied in organizations</h2>
      </div>
      <div class="compact-feature-copy">
        <p>
          I help teams make AI use more deliberate: where it supports work, and where
          it requires principles, verification and responsibility.
        </p>
        <a class="text-link" href="/consulting/">Consulting</a>
      </div>
    </section>
  </div>
</BaseLayout>

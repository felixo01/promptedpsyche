---
import VisualPlate from '../components/VisualPlate.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout>
  <div>
    <section class="home-hero" aria-labelledby="home-title">
      <div class="home-hero-copy">
        <p class="eyebrow">AI - Cyberpsychology - Human-AI Interaction</p>
        <h1 id="home-title">The human side of artificial intelligence.</h1>
        <p class="lede">
          I develop Prompted Psyche as a research-informed project on the human side
          of AI: how it shapes thought, emotion, trust, communication, creativity and
          work.
        </p>
        <div class="hero-actions" aria-label="Main actions">
          <a href="/about/">About the project</a>
          <a href="/consulting/">Consulting</a>
        </div>
      </div>

      <aside class="identity-panel dossier-panel" aria-label="What is Prompted Psyche?">
        <div class="dossier-topline">
          <span class="dossier-stamp" aria-hidden="true">PP</span>
          <span class="dossier-number" aria-hidden="true">01</span>
        </div>
        <div class="dossier-copy">
          <p class="small-label">What is Prompted Psyche?</p>
          <p>
            A research-informed expert project by Feliks Mamczur on AI,
            cyberpsychology and Human-AI Interaction, with essays, notes, concepts and
            consulting on the human side of artificial intelligence.
          </p>
        </div>
        <VisualPlate variant="field-map" class="hero-visual" />
        <ul class="identity-list" aria-label="Project topics">
          <li>AI literacy</li>
          <li>trust</li>
          <li>decisions</li>
          <li>work</li>
          <li>human-AI relations</li>
          <li>creativity</li>
          <li>culture</li>
        </ul>
        <p class="status-note">Pre-launch site. Public writing is being prepared.</p>
      </aside>
    </section>

    <section class="home-section" aria-labelledby="entry-title">
      <div class="editorial-section-header">
        <div>
          <p class="section-kicker">Ways in</p>
          <h2 id="entry-title">Who Prompted Psyche is for</h2>
        </div>
        <p>
          A place for organizations, readers and conversations about the human side of AI
          without hype or oversimplification.
        </p>
      </div>

      <div class="entry-paths">
        <article class="entry-path">
          <p class="entry-index">I</p>
          <h3>Essays and concepts</h3>
          <p>Articles, notes and a concept library on AI, psychology, trust, emotion, work and culture.</p>
          <a class="text-link" href="#writing-title">Explore publications</a>
        </article>
        <article class="entry-path">
          <p class="entry-index">II</p>
          <h3>For organizations</h3>
          <p>AI use analysis, process mapping, human-AI work principles, workshops and talks.</p>
          <a class="text-link" href="/consulting/">See consulting</a>
        </article>
        <article class="entry-path">
          <p class="entry-index">III</p>
          <h3>Talks and collaboration</h3>
          <p>Media commentary, lectures, research conversations and content collaboration on the human side of AI.</p>
          <a class="text-link" href="/contact/">Get in touch</a>
        </article>
      </div>
    </section>

    <section class="home-section topic-section" aria-labelledby="areas-title">
      <div class="editorial-section-header">
        <div>
          <p class="section-kicker">Project map</p>
          <h2 id="areas-title">Areas of focus</h2>
        </div>
        <p>
          A working map for essays, notes, concepts and consulting around the human
          side of AI.
        </p>
      </div>

      <div class="topic-index" aria-label="Research areas">
        <div class="topic-column">
          <article class="topic-row">
            <span>01</span>
            <div>
              <h3>Trust</h3>
              <p>Verification vs. reliance</p>
            </div>
          </article>
          <article class="topic-row">
            <span>02</span>
            <div>
              <h3>Emotion</h3>
              <p>How systems seem to understand</p>
            </div>
          </article>
          <article class="topic-row">
            <span>03</span>
            <div>
              <h3>Attachment</h3>
              <p>Relations with non-relational partners</p>
            </div>
          </article>
          <article class="topic-row">
            <span>04</span>
            <div>
              <h3>Work</h3>
              <p>Who is accountable when AI is fast</p>
            </div>
          </article>
        </div>
        <div class="topic-column">
          <article class="topic-row">
            <span>05</span>
            <div>
              <h3>Decisions</h3>
              <p>What we outsource, and why</p>
            </div>
          </article>
          <article class="topic-row">
            <span>06</span>
            <div>
              <h3>Creativity</h3>
              <p>Selection as authorship</p>
            </div>
          </article>
          <article class="topic-row">
            <span>07</span>
            <div>
              <h3>Culture</h3>
              <p>Language shaped by the tool</p>
            </div>
          </article>
        </div>
      </div>
    </section>

    <section class="home-section process-teaser" aria-labelledby="consulting-title">
      <div class="editorial-section-header">
        <div>
          <p class="section-kicker">Practical application</p>
          <h2 id="consulting-title">Applying this perspective in organizations</h2>
        </div>
        <p>
          I help teams analyze AI use, map processes, design practical principles and
          discuss trust, responsibility and verification.
        </p>
      </div>
      <ol class="process-line" aria-label="Consulting process">
        <li><small>01</small><span>AI use</span></li>
        <li><small>02</small><span>Map</span></li>
        <li><small>03</small><span>Verify</span></li>
        <li><small>04</small><span>Responsibility</span></li>
        <li><small>05</small><span>Principles</span></li>
      </ol>
      <a class="text-link process-link" href="/consulting/">See consulting</a>
    </section>

    <section class="home-section" aria-labelledby="writing-title">
      <div class="editorial-section-header">
        <div>
          <p class="section-kicker">Essays and notes</p>
          <h2 id="writing-title">Writing is being prepared</h2>
        </div>
        <p>Articles, notes and concepts will open as a source-based editorial archive.</p>
      </div>

      <div class="archive-index" aria-label="Publication archive">
        <a class="archive-entry" href="/articles/">
          <span>Archive</span>
          <strong>Articles</strong>
          <p>Long-form essays on AI, cyberpsychology and Human-AI Interaction.</p>
        </a>
        <a class="archive-entry" href="/notes/">
          <span>Notebook</span>
          <strong>Notes</strong>
          <p>Short observations, definitions and research directions.</p>
        </a>
        <a class="archive-entry" href="/concepts/">
          <span>Library</span>
          <strong>Concepts</strong>
          <p>A growing vocabulary for the human side of AI.</p>
        </a>
      </div>
    </section>

    <section class="home-section author-strip" aria-labelledby="about-title">
      <div>
        <p class="section-kicker">Author perspective</p>
        <h2 id="about-title">Feliks Mamczur</h2>
        <a class="orcid-link" href="https://orcid.org/0009-0001-0715-0517" rel="me noopener">
          ORCID 0009-0001-0715-0517
        </a>
      </div>
      <div class="author-note">
        <p>
          I write and consult at the intersection of AI, cyberpsychology and Human-AI
          Interaction. My background in film, editing and post-production shapes how I
          think about AI: through narrative, attention, image, emotion and the way
          technologies reorganize creative and communicative work.
        </p>
        <blockquote>
          We prompt machines. Machines prompt us back.
        </blockquote>
        <a class="text-link" href="/about/">Read about the project</a>
      </div>
    </section>

    <section class="home-section home-final" aria-labelledby="final-title">
      <div>
        <p class="section-kicker">Contact</p>
        <h2 id="final-title">Where to go next</h2>
        <p>
          Start with the vocabulary, see how this perspective can support organizations
          or get in touch about a conversation.
        </p>
      </div>
      <nav class="final-link-list" aria-label="Next links">
        <a class="text-link" href="/concepts/">Concepts</a>
        <a class="text-link" href="/consulting/">Consulting</a>
        <a class="text-link" href="/contact/">Contact</a>
      </nav>
    </section>
  </div>
</BaseLayout>

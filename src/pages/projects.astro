---
import BaseLayout from '../layouts/BaseLayout.astro';

const projects = [
  {
    title: 'AI and psychoeducation',
    status: 'Status: direction of work',
    description:
      "A direction focused on how interaction with AI systems may support emotional organization, reflection and better naming of one's own reactions.",
    concerns:
      'I am interested in the language of human-AI conversation, boundaries of responsibility, risks of overtrust and the difference between preparing for a conversation with a human and replacing it in unsafe ways.',
    doesNotDo:
      'This is not therapy, diagnosis or a substitute for contact with a specialist.'
  },
  {
    title: 'AI-assisted diagnostic reasoning',
    status: 'Status: research-informed applied direction',
    description:
      'A direction focused on how AI may help organize information, questions, hypotheses and documentation in specialist work.',
    concerns:
      'The point is not AI-made diagnosis, but support for human reasoning: separating facts from hypotheses, identifying missing information, structuring material and preparing better questions.',
    doesNotDo:
      'AI does not make diagnostic decisions and does not replace the responsibility of a specialist.'
  },
  {
    title: 'HumanAI research',
    status: 'Status: research and analysis',
    description:
      'Studies and analyses of how people use AI, when they trust it, when they anthropomorphize it and how the technology affects work, creativity, communication and decision-making.',
    concerns:
      'This area includes surveys, behavioral analysis, source review and research questions at the intersection of cyberpsychology, Human-AI Interaction and cognitive psychology.',
    doesNotDo:
      'This is not a ranking of AI tools or a simplified judgment of whether AI is good or bad.'
  },
  {
    title: 'Prompted Psyche Concepts',
    status: 'Status: ongoing',
    description:
      'A developing vocabulary for thinking about the human side of AI: from AI literacy and Human-AI Interaction to trust, cognitive load, anthropomorphism and the context window.',
    concerns:
      'This is the conceptual layer of the project. It supports articles, notes, consulting and future research.',
    doesNotDo:
      'It is not meant to be a complete encyclopedia of AI. It is the working vocabulary of Prompted Psyche.',
    link: {
      href: '/concepts/',
      label: 'Explore concepts'
    }
  }
];
---

<BaseLayout
  title="Projects"
  description="Research-informed and applied project directions around AI, psychoeducation, diagnostic reasoning, HumanAI research and concept work."
>
  <div class="lovable-page projects-page">
    <header class="lovable-page-hero projects-hero">
      <div class="lovable-container projects-hero__inner">
        <div>
          <p class="eyebrow">Projects</p>
          <h1>Projects</h1>
          <p class="lede">
            Research-informed and applied directions around the human side of AI:
            psychoeducation, diagnostic reasoning, trust, communication,
            decision-making, creativity and work with specialist knowledge.
          </p>
          <p class="hero-subnote">
            Not all of these projects are commercial products. Some are studies,
            prototypes, conceptual models and tools for thinking. Publicly, I
            describe the direction of work, not the full mechanics of the solutions.
          </p>
        </div>

        <aside class="projects-principle" aria-labelledby="projects-principle-title">
          <p class="small-label">Principle</p>
          <h2 id="projects-principle-title">Boundaries of responsibility</h2>
          <p>
            These projects do not replace therapy, diagnosis or specialist decisions.
            I am interested in how AI can support reflection, information
            organization, responsible use of knowledge and better understanding of
            context.
          </p>
        </aside>
      </div>
    </header>

    <section class="lovable-section" aria-labelledby="projects-list-title">
      <div class="lovable-container">
        <div class="lovable-section-header">
          <h2 id="projects-list-title">Directions of work</h2>
          <p>
            These are public and intentionally high-level descriptions. They show the
            area of work, not private back-office details or the mechanics of
            prototypes.
          </p>
        </div>

        <div class="projects-grid">
          {
            projects.map((project) => (
              <article class="project-card">
                <p class="project-card__status">{project.status}</p>
                <h3>{project.title}</h3>
                <p>{project.description}</p>
                <div class="project-card__section">
                  <h4>What it concerns</h4>
                  <p>{project.concerns}</p>
                </div>
                <div class="project-card__section">
                  <h4>What it does not do</h4>
                  <p>{project.doesNotDo}</p>
                </div>
                {project.link && (
                  <a class="text-link" href={project.link.href}>{project.link.label}</a>
                )}
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section class="lovable-section projects-cta-section tinted-section" aria-labelledby="projects-cta-title">
      <div class="lovable-container projects-cta">
        <div>
          <p class="eyebrow">Collaboration</p>
          <h2 id="projects-cta-title">Collaboration</h2>
        </div>
        <div>
          <p>
            Some of these directions may become the basis for workshops, consulting,
            studies, publications or prototypes. The important part is to develop
            them responsibly: with clear boundaries, sources and awareness of
            consequences.
          </p>
          <div class="consulting-actions">
            <a class="hero-button hero-button-primary" href="/consulting/"><span aria-hidden="true"></span>Consulting</a>
            <a class="hero-button hero-button-secondary" href="/contact/">Contact</a>
          </div>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>

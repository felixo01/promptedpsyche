---
import BaseLayout from '../layouts/BaseLayout.astro';

const projectSections = [
  {
    eyebrow: 'Active directions',
    title: 'Directions that organize the next layer of work',
    description:
      'These areas are developed through writing, source analysis, conversations and careful prototyping. Publicly, they show the purpose of the work, not the private mechanics behind it.',
    projects: [
      {
        title: 'AI and psychoeducation',
        summary:
          'A direction about how AI may help people organize experience and prepare for human conversation without pretending to be therapy.',
        status: 'Research-informed applied direction',
        focus:
          'language in human-AI conversation, responsibility boundaries, overtrust and preparation for human dialogue',
        output:
          'articles, working models, workshops and careful educational prototypes',
        stage: 'developed through articles, notes and risk analysis',
        boundary:
          'This is not therapy, diagnosis or a substitute for contact with a specialist.',
        link: undefined
      },
      {
        title: 'AI-assisted diagnostic reasoning',
        summary:
          'A direction about using AI to organize information, questions and hypotheses in specialist work.',
        status: 'Research-informed applied direction',
        focus:
          'separating facts from hypotheses, missing information, documentation and control questions',
        output:
          'analysis frameworks, educational materials and formats that support human decision-making',
        stage: 'publicly described as a direction, not as a diagnostic system',
        boundary:
          'AI does not make diagnostic decisions and does not replace specialist responsibility.',
        link: undefined
      },
      {
        title: 'HumanAI research',
        summary:
          'An analytical direction on how people trust AI, anthropomorphize it and fold it into work, communication and decisions.',
        status: 'Research and analysis',
        focus:
          'trust, anthropomorphism, communication, creativity, decisions and work',
        output:
          'surveys, source reviews, analytical essays and public reports',
        stage: 'developed as research questions and a base for publication',
        boundary:
          'This is not an AI tool ranking or a simple judgment of whether AI is good or bad.',
        link: undefined
      }
    ]
  },
  {
    eyebrow: 'Format in development',
    title: 'Language for articles, Concepts and practice',
    description:
      'Not every project has to be a product. Part of Prompted Psyche is building shared language that makes articles, AI work and conversations about responsibility easier to understand.',
    projects: [
      {
        title: 'Prompted Psyche Concepts',
        summary:
          'A public format for organizing the concepts needed to talk about the human side of AI.',
        status: 'Ongoing public format',
        focus:
          'AI literacy, Human-AI Interaction, trust, cognitive load, anthropomorphism and the context window',
        output:
          'a concept library, linked definitions and shared language for writing and consulting',
        stage: 'published and developing',
        boundary:
          'It is not a complete AI encyclopedia or a formal research standard.',
        link: {
          href: '/concepts/',
          label: 'Explore concepts'
        }
      }
    ]
  }
];

const archivedProject = {
  title: 'HumanAI Lab',
  summary:
    'A completed research project on conversational AI, trust, emotional experience and everyday decision-making.',
  status: 'Archived · Recruitment closed',
  boundary:
    'Recruitment has ended, and the survey no longer accepts responses.',
  link: {
    href: '/projects/humanai-lab/',
    label: 'View archived project'
  }
};
---

<BaseLayout
  title="Projects"
  description="Public Prompted Psyche directions where articles, Concepts and practice begin to become research, tools and educational formats."
>
  <div class="lovable-page projects-page">
    <header class="lovable-page-hero projects-hero">
      <div class="lovable-container projects-hero__inner">
        <div>
          <p class="eyebrow">Projects</p>
          <h1>Projects</h1>
          <p class="lede">
            Projects show where the thinking behind Prompted Psyche starts to
            become research, tools, educational formats and applied practice.
          </p>
          <p class="hero-subnote">
            They are public working directions: mature enough to describe their
            purpose, not framed as finished products. They connect articles,
            Concepts and practical use of AI.
          </p>
        </div>

        <aside class="projects-principle" aria-labelledby="projects-principle-title">
          <p class="small-label">Boundary</p>
          <h2 id="projects-principle-title">Boundaries and maturity</h2>
          <p>
            Publicly, I show the problem, direction and possible output. I do not
            expose private mechanics, internal names or product promises.
          </p>
        </aside>
      </div>
    </header>

    <section class="lovable-section" aria-label="Project directions">
      <div class="lovable-container">
        {
          projectSections.map((section, sectionIndex) => (
            <section
              class="projects-section"
              aria-labelledby={`projects-section-${sectionIndex}`}
            >
              <div class="lovable-section-header projects-section__header">
                <div>
                  <p class="section-kicker">{section.eyebrow}</p>
                  <h2 id={`projects-section-${sectionIndex}`}>{section.title}</h2>
                </div>
                <p>{section.description}</p>
              </div>

              <div class="projects-grid">
                {
                  section.projects.map((project) => (
                    <article class="project-card">
                      <p class="project-card__status">{project.status}</p>
                      <h3>{project.title}</h3>
                      <p class="project-card__summary">{project.summary}</p>

                      <dl class="project-card__details">
                        <div>
                          <dt>Focus</dt>
                          <dd>{project.focus}</dd>
                        </div>
                        <div>
                          <dt>Possible output</dt>
                          <dd>{project.output}</dd>
                        </div>
                        <div>
                          <dt>Stage</dt>
                          <dd>{project.stage}</dd>
                        </div>
                      </dl>

                      <p class="project-card__boundary">{project.boundary}</p>

                      {project.link && (
                        <a class="text-link" href={project.link.href}>{project.link.label}</a>
                      )}
                    </article>
                  ))
                }
              </div>
            </section>
          ))
        }

        <section
          class="projects-section projects-section--archived"
          aria-labelledby="archived-projects-title"
        >
          <div class="lovable-section-header projects-section__header">
            <div>
              <p class="section-kicker">Project archive</p>
              <h2 id="archived-projects-title">Archived projects</h2>
            </div>
            <p>
              Completed initiatives are kept here as public records of their scope
              and status. They are not active recruitment pages.
            </p>
          </div>

          <div class="projects-grid">
            <article class="project-card project-card--archived">
              <p class="project-card__status">{archivedProject.status}</p>
              <h3>{archivedProject.title}</h3>
              <p class="project-card__summary">{archivedProject.summary}</p>
              <p class="project-card__boundary">{archivedProject.boundary}</p>
              <a class="text-link" href={archivedProject.link.href}>{archivedProject.link.label}</a>
            </article>
          </div>
        </section>
      </div>
    </section>

    <section class="lovable-section projects-cta-section tinted-section" aria-labelledby="projects-cta-title">
      <div class="lovable-container projects-cta">
        <div>
          <p class="eyebrow">Contact</p>
          <h2 id="projects-cta-title">Conversation and collaboration</h2>
        </div>
        <div>
          <p>
            If one of these directions fits your organization, the best place to
            begin is a conversation about context, risks and boundaries. Only then
            does it make sense to decide whether the right form is a workshop,
            consulting, publication, study or prototype.
          </p>
          <div class="consulting-actions">
            <a class="hero-button hero-button-primary" href="/consulting/"><span aria-hidden="true"></span>Consulting</a>
            <a class="hero-button hero-button-secondary" href="/contact/">Contact</a>
          </div>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>

---
import { getCollection, render } from 'astro:content';
import EntryLayout from '../../layouts/EntryLayout.astro';
import { onlyPublicEntries, onlyPublicEntriesByLang } from '../../lib/content';
import { getNoteAlternates } from '../../lib/noteRoutes';

export async function getStaticPaths() {
  const publicNotes = onlyPublicEntries(await getCollection('notes'));
  const notes = onlyPublicEntriesByLang(publicNotes, 'en');

  return notes.map((entry) => ({
    params: { slug: entry.id },
    props: { entry, alternateLinks: getNoteAlternates(entry, publicNotes) }
  }));
}

const { entry, alternateLinks } = Astro.props;
const { Content } = await render(entry);
---

<EntryLayout entry={entry} entryType="note" label="Note" lang="en" alternateLinks={alternateLinks}>
  <Content />
</EntryLayout>

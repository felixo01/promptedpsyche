---
import { getCollection } from 'astro:content';
import EntryList from '../../components/EntryList.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { onlyPublicEntries, sortByDateDesc } from '../../lib/content';

const notes = sortByDateDesc(onlyPublicEntries(await getCollection('notes')));
---

<BaseLayout
  title="Notes"
  description="Short observations and research notes from Prompted Psyche."
>
  <section class="page-shell">
    <header class="page-header">
      <div>
        <p class="eyebrow">Notes</p>
        <h1>Research notes</h1>
      </div>
      <p>
        Short research notes, observations and working thoughts.
      </p>
    </header>

    <EntryList entries={notes} basePath="/notes" label="Note" />
  </section>
</BaseLayout>

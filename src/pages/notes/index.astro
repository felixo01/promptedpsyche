---
import { getCollection } from 'astro:content';
import EntryList from '../../components/EntryList.astro';
import VisualPlate from '../../components/VisualPlate.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { onlyPublicEntriesByLang, sortByDateDesc } from '../../lib/content';

const notes = sortByDateDesc(onlyPublicEntriesByLang(await getCollection('notes'), 'en'));
---

<BaseLayout
  title="Notes"
  description="Research notes, explainers and focused analyses of specific questions about AI."
>
  <section class="page-shell">
    <header class="page-header">
      <div>
        <p class="eyebrow">Notes</p>
        <h1>Notes</h1>
      </div>
      <p>
        Research notes, explainers and focused analyses of specific questions about AI.
      </p>
    </header>

    <EntryList
      entries={notes}
      basePath="/notes"
      label="Note"
      emptyLabel="Notes"
      emptyMessage="Notes are in preparation."
      emptyNote="They will collect shorter observations, definitions and leads for future essays."
      emptyIcon="note"
      ctaLabel="Read note"
    />

    {notes.length === 0 && (
      <section class="empty-followup" aria-labelledby="notes-followup-title">
        <VisualPlate variant="note-stack" class="empty-state-visual" />
        <h2 id="notes-followup-title">What notes will do</h2>
        <p>
          Notes will keep smaller questions visible before they become longer essays.
        </p>
      </section>
    )}
  </section>
</BaseLayout>

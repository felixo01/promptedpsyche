---
import { getCollection } from 'astro:content';
import EntryList from '../../components/EntryList.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { onlyPublicEntries, sortByDateDesc } from '../../lib/content';

const notes = sortByDateDesc(onlyPublicEntries(await getCollection('notes')));
---

<BaseLayout
  title="Notes"
  description="Short observations and research notes from Prompted Psyche."
>
  <section class="page-shell">
    <header class="page-header">
      <div>
        <p class="eyebrow">Notes</p>
        <h1>Notes</h1>
      </div>
      <p>
        Short observations and research notes on AI use, human behavior, trust, work,
        creativity and digital culture.
      </p>
    </header>

    <EntryList
      entries={notes}
      basePath="/notes"
      label="Note"
      emptyLabel="Notes"
      emptyMessage="Notes are in preparation."
      emptyNote="They will collect shorter observations on AI, human behavior, trust, work, creativity and digital culture."
      emptyIcon="note"
    />

    {notes.length === 0 && (
      <section class="empty-followup" aria-labelledby="notes-followup-title">
        <h2 id="notes-followup-title">What notes will collect</h2>
        <p>
          Shorter observations, definitions and leads for future essays on AI,
          cyberpsychology and Human-AI Interaction.
        </p>
      </section>
    )}
  </section>
</BaseLayout>

---
import { getCollection } from 'astro:content';
import EntryList from '../../components/EntryList.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { onlyPublicEntries, sortByDateDesc } from '../../lib/content';

const notes = sortByDateDesc(onlyPublicEntries(await getCollection('notes')));
---

<BaseLayout
  title="Notes"
  description="Short observations and research notes from Prompted Psyche."
>
  <section class="page-shell">
    <header class="page-header">
      <div>
        <p class="eyebrow">Notes</p>
        <h1>Notes</h1>
      </div>
      <p>
        Short observations and research notes on AI use, human behavior, trust, work,
        creativity and digital culture.
      </p>
    </header>

    <EntryList
      entries={notes}
      basePath="/notes"
      label="Note"
      emptyLabel="Notes"
      emptyMessage="Public notes are being prepared."
      emptyNote="They will collect shorter observations on AI use, human behavior, trust, work, creativity and digital culture."
      emptyIcon="note"
    />
  </section>
</BaseLayout>

---
import { getCollection } from 'astro:content';
import EntryList from '../../components/EntryList.astro';
import VisualPlate from '../../components/VisualPlate.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { onlyPublicEntries, sortByDateDesc } from '../../lib/content';

const notes = sortByDateDesc(onlyPublicEntries(await getCollection('notes')));
---

<BaseLayout
  title="Notes"
  description="Short observations and research notes from Prompted Psyche."
>
  <section class="page-shell">
    <header class="page-header">
      <div>
        <p class="eyebrow">Notes</p>
        <h1>Notes</h1>
      </div>
      <p>
        Short observations on AI use, human behavior, trust, work, communication and
        digital culture.
      </p>
    </header>

    <EntryList
      entries={notes}
      basePath="/notes"
      label="Note"
      emptyLabel="Notes"
      emptyMessage="Notes are in preparation."
      emptyNote="They will collect shorter observations, definitions and leads for future essays."
      emptyIcon="note"
    />

    {notes.length === 0 && (
      <section class="empty-followup" aria-labelledby="notes-followup-title">
        <VisualPlate variant="note-stack" class="empty-state-visual" />
        <h2 id="notes-followup-title">What notes will do</h2>
        <p>
          Notes will keep smaller questions visible before they become longer essays.
        </p>
      </section>
    )}
  </section>
</BaseLayout>
